class OllamaClient:
def **init**(self, base_url: str = “http://localhost:11434”, model: str = “qwen3:32b”):
self.base_url = base_url.rstrip(”/”)
self.model = model

```
def chat(self, messages: list[dict], stream: bool = False) -> dict | Generator:
    url = f"{self.base_url}/api/chat"
    payload = {
        "model": self.model,
        "messages": messages,
        "stream": stream,
        "options": {
            "temperature": 0.3,   # low for consistent tool calling
            "top_p": 0.9,
            "num_ctx": 8192,
        }
    }
    response = requests.post(url, json=payload, timeout=300, stream=stream)
    response.raise_for_status()

    if stream:
        return self._stream_response(response)
    return response.json()

def _stream_response(self, response) -> Generator:
    for line in response.iter_lines():
        if line:
            try:
                yield json.loads(line)
            except json.JSONDecodeError:
                continue

def is_available(self) -> bool:
    try:
        r = requests.get(f"{self.base_url}/api/tags", timeout=5)
        return r.status_code == 200
    except Exception:
        return False

def list_models(self) -> list[str]:
    try:
        r = requests.get(f"{self.base_url}/api/tags", timeout=5)
        data = r.json()
        return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []
