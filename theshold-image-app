class AFMRenderer:

```
def render_raw(
    self,
    result: ProcessingResult,
    params: ProcessingParams,
    figsize: tuple = (5, 5),
) -> Figure:
    img = result.preprocessed_image
    if img is None:
        raise ValueError("No preprocessed image available.")

    vmin = float(np.min(img))
    vmax = float(np.max(img))
    if params.raw_min_enable:
        vmin = params.raw_vmin
    if params.raw_max_enable:
        vmax = params.raw_vmax
    if vmax <= vmin:
        vmax = vmin + 1e-9

    fig, ax = plt.subplots(figsize=figsize)
    im = ax.imshow(img, cmap=params.raw_colormap, vmin=vmin, vmax=vmax, interpolation="nearest")
    ax.set_title("Flattened / Preprocessed")
    self._apply_axes(ax, img.shape, result)
    cbar = fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    if result.data_unit:
        cbar.set_label(result.data_unit)
    fig.tight_layout()
    return fig

def render_threshold(
    self,
    result: ProcessingResult,
    params: ProcessingParams,
    figsize: tuple = (5, 5),
) -> Figure:
    lbl = result.label_image
    if lbl is None:
        raise ValueError("No threshold result available.")

    groups = int(np.max(lbl)) + 1
    vmax = max(1, groups - 1)

    fig, ax = plt.subplots(figsize=figsize)
    im = ax.imshow(lbl, cmap=params.threshold_colormap, vmin=0, vmax=vmax, interpolation="nearest")

    if params.show_boundaries and groups > 1:
        levels = np.arange(0.5, groups - 0.5 + 1e-9, 1.0)
        ax.contour(lbl, levels=levels,
                   colors=params.boundary_color,
                   linewidths=max(0.1, params.boundary_thickness))

    ax.set_title("Threshold Result")
    self._apply_axes(ax, lbl.shape, result)
    cbar = fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    cbar.set_ticks(np.arange(groups))
    fig.tight_layout()
    return fig

def render_raw_histogram(
    self,
    result: ProcessingResult,
    params: ProcessingParams,
    figsize: tuple = (6, 3),
) -> Figure:
    img = result.preprocessed_image
    if img is None:
        raise ValueError("No preprocessed image available.")

    values = img.ravel().astype(np.float32)
    values = values[np.isfinite(values)]

    fig, ax = plt.subplots(figsize=figsize)
    ax.hist(values, bins=256, color="#4c8cbf", alpha=0.8)

    mean_val = float(np.mean(values))
    std_val = float(np.std(values))
    ax.axvline(mean_val, linestyle="-", linewidth=1.4, color="red", label="Mean")
    ax.axvline(mean_val - std_val, linestyle=":", linewidth=1.2, color="orange", label="Mean ± Std")
    ax.axvline(mean_val + std_val, linestyle=":", linewidth=1.2, color="orange")

    unit = f" ({result.data_unit})" if result.data_unit else ""
    for i, t in enumerate(result.threshold_values):
        ax.axvline(t, linestyle="--", linewidth=1.2, label=f"T{i+1}={t:.4g}")

    stats_text = f"Mean = {mean_val:.4g}{unit}\nStd = {std_val:.4g}{unit}"
    ax.text(0.98, 0.98, stats_text, transform=ax.transAxes,
            ha="right", va="top", fontsize=9,
            bbox=dict(boxstyle="round", facecolor="white", alpha=0.75))

    ax.set_title("Raw / Preprocessed Histogram")
    ax.set_xlabel(f"Intensity{unit}")
    ax.set_ylabel("Count")
    ax.legend(fontsize=8, loc="upper left")
    fig.tight_layout()
    return fig

def render_threshold_histogram(
    self,
    result: ProcessingResult,
    params: ProcessingParams,
    figsize: tuple = (6, 3),
) -> Figure:
    lbl = result.label_image
    if lbl is None:
        raise ValueError("No threshold result available.")

    labels = lbl.ravel().astype(np.int32)
    groups = int(labels.max()) + 1 if labels.size else 0
    counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
    total = max(1, int(counts.sum()))
    percentages = [100.0 * c / total for c in counts]

    cmap = colormaps[params.threshold_colormap]
    norm = mcolors.Normalize(vmin=0, vmax=max(1, groups - 1))
    colors = [cmap(norm(i)) for i in range(groups)]

    fig, ax = plt.subplots(figsize=figsize)
    xs = np.arange(groups)
    bars = ax.bar(xs, counts, width=0.8, color=colors)
    ymax = counts.max() if counts.size else 1
    ax.set_ylim(0, ymax * 1.18 + 1)
    ax.set_xticks(xs)
    ax.set_title("Threshold Group Histogram")
    ax.set_xlabel("Group Label")
    ax.set_ylabel("Count")

    for bar, pct in zip(bars, percentages):
        ax.text(bar.get_x() + bar.get_width() / 2.0,
                bar.get_height() + max(1, ymax * 0.02),
                f"{pct:.1f}%", ha="center", va="bottom", fontsize=9)
    fig.tight_layout()
    return fig

def render_combined(
    self,
    result: ProcessingResult,
    params: ProcessingParams,
    show_raw: bool = True,
    show_threshold: bool = True,
    show_raw_hist: bool = False,
    show_threshold_hist: bool = False,
) -> Figure:
    """Render multiple panels in one figure."""
    panels = []
    if show_raw and result.preprocessed_image is not None:
        panels.append("raw")
    if show_threshold and result.label_image is not None:
        panels.append("threshold")
    if show_raw_hist and result.preprocessed_image is not None:
        panels.append("raw_hist")
    if show_threshold_hist and result.label_image is not None:
        panels.append("threshold_hist")

    n = len(panels)
    if n == 0:
        raise ValueError("Nothing to render.")

    cols = min(n, 2)
    rows = (n + cols - 1) // cols
    fig, axes = plt.subplots(rows, cols, figsize=(6 * cols, 5 * rows))
    if n == 1:
        axes = [axes]
    else:
        axes = list(np.array(axes).flatten())

    for ax, panel in zip(axes, panels):
        if panel == "raw":
            self._draw_raw_on_ax(ax, result, params)
        elif panel == "threshold":
            self._draw_threshold_on_ax(ax, result, params)
        elif panel == "raw_hist":
            self._draw_raw_hist_on_ax(ax, result)
        elif panel == "threshold_hist":
            self._draw_threshold_hist_on_ax(ax, result, params)

    for ax in axes[n:]:
        ax.set_visible(False)

    fig.tight_layout()
    return fig

# ── Helpers ──────────────────────────────

def _draw_raw_on_ax(self, ax, result, params):
    img = result.preprocessed_image
    vmin = float(np.min(img))
    vmax = float(np.max(img))
    if params.raw_min_enable:
        vmin = params.raw_vmin
    if params.raw_max_enable:
        vmax = params.raw_vmax
    if vmax <= vmin:
        vmax = vmin + 1e-9
    im = ax.imshow(img, cmap=params.raw_colormap, vmin=vmin, vmax=vmax, interpolation="nearest")
    ax.set_title("Flattened / Preprocessed")
    self._apply_axes(ax, img.shape, result)
    cbar = plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    if result.data_unit:
        cbar.set_label(result.data_unit)

def _draw_threshold_on_ax(self, ax, result, params):
    lbl = result.label_image
    groups = int(np.max(lbl)) + 1
    vmax = max(1, groups - 1)
    im = ax.imshow(lbl, cmap=params.threshold_colormap, vmin=0, vmax=vmax, interpolation="nearest")
    if params.show_boundaries and groups > 1:
        levels = np.arange(0.5, groups - 0.5 + 1e-9, 1.0)
        ax.contour(lbl, levels=levels,
                   colors=params.boundary_color,
                   linewidths=max(0.1, params.boundary_thickness))
    ax.set_title("Threshold Result")
    self._apply_axes(ax, lbl.shape, result)
    cbar = plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    cbar.set_ticks(np.arange(groups))

def _draw_raw_hist_on_ax(self, ax, result):
    values = result.preprocessed_image.ravel().astype(np.float32)
    values = values[np.isfinite(values)]
    ax.hist(values, bins=256, color="#4c8cbf", alpha=0.8)
    mean_val = float(np.mean(values))
    std_val = float(np.std(values))
    ax.axvline(mean_val, linestyle="-", linewidth=1.4, color="red", label="Mean")
    ax.axvline(mean_val - std_val, linestyle=":", linewidth=1.2, color="orange")
    ax.axvline(mean_val + std_val, linestyle=":", linewidth=1.2, color="orange")
    for i, t in enumerate(result.threshold_values):
        ax.axvline(t, linestyle="--", linewidth=1.0, label=f"T{i+1}")
    unit = f" ({result.data_unit})" if result.data_unit else ""
    ax.set_title("Intensity Histogram")
    ax.set_xlabel(f"Intensity{unit}")
    ax.set_ylabel("Count")
    ax.legend(fontsize=7)

def _draw_threshold_hist_on_ax(self, ax, result, params):
    labels = result.label_image.ravel().astype(np.int32)
    groups = int(labels.max()) + 1 if labels.size else 0
    counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
    total = max(1, int(counts.sum()))
    cmap = colormaps[params.threshold_colormap]
    norm = mcolors.Normalize(vmin=0, vmax=max(1, groups - 1))
    colors = [cmap(norm(i)) for i in range(groups)]
    xs = np.arange(groups)
    bars = ax.bar(xs, counts, width=0.8, color=colors)
    ymax = counts.max() if counts.size else 1
    ax.set_ylim(0, ymax * 1.18 + 1)
    ax.set_xticks(xs)
    ax.set_title("Group Histogram")
    ax.set_xlabel("Group Label")
    ax.set_ylabel("Count")
    for bar, c in zip(bars, counts):
        pct = 100.0 * c / total
        ax.text(bar.get_x() + bar.get_width() / 2.0,
                bar.get_height() + max(1, ymax * 0.02),
                f"{pct:.1f}%", ha="center", va="bottom", fontsize=8)

def _apply_axes(self, ax, shape, result: ProcessingResult):
    h, w = shape[:2]
    xticks = np.linspace(0, max(0, w - 1), num=min(6, max(2, w)))
    yticks = np.linspace(0, max(0, h - 1), num=min(6, max(2, h)))
    ax.set_xticks(xticks)
    ax.set_yticks(yticks)

    unit = result.xy_unit
    x_total = result.x_total
    y_total = result.y_total

    if unit and x_total and y_total and w > 1 and h > 1:
        # Auto-scale display unit
        max_total = max(abs(x_total), abs(y_total))
        if unit == "nm" and max_total >= 1000:
            disp_unit, factor = "um", 1000.0
        else:
            disp_unit, factor = unit, 1.0
        xvals = np.linspace(0, x_total / factor, num=len(xticks))
        yvals = np.linspace(0, y_total / factor, num=len(yticks))
        ax.set_xticklabels([f"{v:.3g}" for v in xvals])
        ax.set_yticklabels([f"{v:.3g}" for v in yvals])
        ax.set_xlabel(f"X ({disp_unit})")
        ax.set_ylabel(f"Y ({disp_unit})")
    else:
        ax.set_xticklabels([f"{int(round(x))}" for x in xticks])
        ax.set_yticklabels([f"{int(round(y))}" for y in yticks])
        ax.set_xlabel("X (pixel)")
        ax.set_ylabel("Y (pixel)")

def fig_to_pil(self, fig: Figure):
    """Convert matplotlib Figure to PIL Image for Gradio."""
    from PIL import Image
    buf = io.BytesIO()
    fig.savefig(buf, format="png", bbox_inches="tight", dpi=150)
    buf.seek(0)
    plt.close(fig)
    return Image.open(buf).copy()
