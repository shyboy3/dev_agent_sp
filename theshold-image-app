@property
def success(self) -> bool:
    return self.error is None and self.label_image is not None

def stats_summary(self) -> str:
    if self.preprocessed_image is None:
        return "No data processed yet."
    vals = self.preprocessed_image[np.isfinite(self.preprocessed_image)]
    unit = f" {self.data_unit}" if self.data_unit else ""
    lines = [
        "📊 **Statistics**",
        f"- Shape: {self.preprocessed_image.shape[1]} x {self.preprocessed_image.shape[0]} px",
        f"- Mean: {float(np.mean(vals)):.6g}{unit}",
        f"- Std:  {float(np.std(vals)):.6g}{unit}",
        f"- Min:  {float(np.min(vals)):.6g}{unit}",
        f"- Max:  {float(np.max(vals)):.6g}{unit}",
    ]
    if self.xy_unit and self.x_total and self.y_total:
        lines.append(f"- Scan size: {self.x_total:.4g} x {self.y_total:.4g} {self.xy_unit}")
    if self.threshold_values:
        thr_str = ", ".join(f"{t:.6g}{unit}" for t in self.threshold_values)
        lines.append(f"- Thresholds: {thr_str}")
    if self.group_percentages:
        for i, pct in enumerate(self.group_percentages):
            lines.append(f"  Group {i}: {pct:.2f}%")
    if self.afm_metrics:
        for k, v in self.afm_metrics.items():
            lines.append(f"- AFM {k}: {v:.6g}{unit}" if isinstance(v, (int, float)) else f"- AFM {k}: {v}")
    return "\n".join(lines)
