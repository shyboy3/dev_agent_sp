        counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
        xs = np.arange(groups)
        colors = self._get_threshold_hist_colors(groups)
        bars = ax.bar(xs, counts, width=0.85, color=colors)
        total = max(1, int(counts.sum()))
