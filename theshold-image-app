        self.ax_thr.text(0.5, 0.5, "No threshold result", ha="center", va="center")
        self.canvas.draw()
        return

    finite_vals = disp[finite_mask]
    fill_value = float(np.median(finite_vals))
    disp[~finite_mask] = fill_value

    if vmin is None:
        vmin = float(np.min(finite_vals))
    if vmax is None:
        vmax = float(np.max(finite_vals))
    if vmin == vmax:
        vmax = vmin + 1e-12

    if self.cbar_raw is not None:
        try:
            self.cbar_raw.remove()
        except Exception:
            pass
        self.cbar_raw = None

    if self.cbar_thr is not None:
