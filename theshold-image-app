# Agent

# ──────────────────────────────────────────────

class AFMAgent:

```
def __init__(
    self,
    ollama_url: str = "http://localhost:11434",
    model: str = "qwen3:32b",
    mode: str = "auto",         # "auto" | "debug"
):
    self.ollama = OllamaClient(base_url=ollama_url, model=model)
    self.executor = ToolExecutor()
    self.mode = mode
    self.conversation: list[dict] = []
    self._reset_system_prompt()

def _reset_system_prompt(self):
    self._system_prompt = build_system_prompt(self.mode)

def set_mode(self, mode: str):
    self.mode = mode
    self._reset_system_prompt()

def clear_history(self):
    self.conversation = []

# ── Main chat entry point ─────────────────

def chat(self, user_message: str) -> Generator[dict, None, None]:
    """
    Generator that yields event dicts:
      {"type": "thinking", "text": "..."}        - LLM is thinking
      {"type": "text", "text": "..."}            - LLM text response
      {"type": "tool_call", "tool": "...", "args": {...}}
      {"type": "tool_result", "success": bool, "message": "...", "data": ...}
      {"type": "image", "data": <PIL Image>}
      {"type": "done"}
    """
    self.conversation.append({"role": "user", "content": user_message})

    messages = [{"role": "system", "content": self._system_prompt}] + self.conversation

    # Get LLM response (non-streaming for reliability with tool parsing)
    try:
        yield {"type": "thinking", "text": "🤔 Analyzing request..."}
        response = self.ollama.chat(messages, stream=False)
        assistant_content = response.get("message", {}).get("content", "")
    except requests.exceptions.ConnectionError:
        yield {"type": "text", "text": "❌ Cannot connect to Ollama. Please ensure Ollama is running at the configured URL."}
        yield {"type": "done"}
        return
    except Exception as e:
        yield {"type": "text", "text": f"❌ LLM error: {e}"}
        yield {"type": "done"}
        return

    # Parse tool calls
    tool_calls = parse_tool_calls(assistant_content)
    display_text = strip_tool_calls(assistant_content)

    # Emit display text if any
    if display_text:
        yield {"type": "text", "text": display_text}

    # Execute tool calls
    tool_results_for_context = []
    for call in tool_calls:
        tool_name = call["tool"]
        arguments = call.get("arguments", {})

        yield {"type": "tool_call", "tool": tool_name, "args": arguments}

        tool_result: ToolResult = self.executor.execute(tool_name, arguments)

        yield {
            "type": "tool_result",
            "success": tool_result.success,
            "message": tool_result.message,
            "render_type": tool_result.render_type,
        }

        if tool_result.render_type == "image" and tool_result.data is not None:
            yield {"type": "image", "data": tool_result.data}

        tool_results_for_context.append(
            f"[Tool: {tool_name}] {'SUCCESS' if tool_result.success else 'FAILED'}: {tool_result.message[:300]}"
        )

    # If tools were called, feed results back to LLM for a follow-up response
    if tool_calls:
        self.conversation.append({"role": "assistant", "content": assistant_content})
        tool_context = "\n".join(tool_results_for_context)
        self.conversation.append({
            "role": "user",
            "content": f"[Tool results]\n{tool_context}\n\nPlease provide a brief summary of what was done."
        })

        messages2 = [{"role": "system", "content": self._system_prompt}] + self.conversation
        try:
            response2 = self.ollama.chat(messages2, stream=False)
            followup = response2.get("message", {}).get("content", "")
            followup_clean = strip_tool_calls(followup)
            if followup_clean.strip():
                yield {"type": "text", "text": followup_clean}
            self.conversation.append({"role": "assistant", "content": followup})
            # Remove the injected tool context message (keep history clean)
            self.conversation.pop(-2)
        except Exception as e:
            yield {"type": "text", "text": f"(Follow-up failed: {e})"}
    else:
        self.conversation.append({"role": "assistant", "content": assistant_content})

    yield {"type": "done"}
