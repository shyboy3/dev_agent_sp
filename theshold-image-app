agent = AFMAgent(
    ollama_url=ollama_url,
    model=default_model,
    mode=default_mode,
)

# ── Handlers ────────────────────────────

def chat(user_message, history, mode, url, model):
    if not user_message or not user_message.strip():
        yield history, None, ""
        return

    agent.ollama.base_url = url.rstrip("/")
    agent.ollama.model = model
    if agent.mode != mode.lower():
        agent.set_mode(mode.lower())

    history = _append_user(history, user_message)
    yield history, None, "Processing..."

    assistant_texts = []
    current_image = None

    for event in agent.chat(user_message):
        etype = event.get("type")

        if etype == "thinking":
            yield history, current_image, event["text"]

        elif etype == "text":
            text = event["text"].strip()
            if text:
                assistant_texts.append(text)
                combined = "\n\n".join(assistant_texts)
                history = _append_assistant(history, combined)
                yield history, current_image, "Responding..."

        elif etype == "tool_call":
            yield history, current_image, f"Calling: {event['tool']}..."

        elif etype == "tool_result":
            icon = "OK" if event["success"] else "FAIL"
            yield history, current_image, f"{icon}: {event['message'][:150]}"

        elif etype == "image":
            current_image = event["data"]
            yield history, current_image, "Image updated"

        elif etype == "done":
            yield history, current_image, "Done"

def clear_chat():
    agent.clear_history()
    return [], None, "History cleared"

def check_connection(url, model):
    client = OllamaClient(base_url=url, model=model)
    if not client.is_available():
        return f"❌ Cannot connect to Ollama at {url}"
    models = client.list_models()
    if model in models:
        return f"✅ Connected | '{model}' available"
    elif models:
        return f"⚠️ Connected but '{model}' not found. Available: {', '.join(models[:5])}"
    return f"⚠️ Connected. Run: ollama pull {model}"

def handle_upload(file_obj, history, mode, url, model):
    if file_obj is None:
        yield history, None, "No file"
        return
    path = file_obj if isinstance(file_obj, str) else file_obj.name
    yield from chat(f"이 파일을 로드하고 분석해줘: {path}", history, mode, url, model)

