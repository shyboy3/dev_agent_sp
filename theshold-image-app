    def export_histogram_txt(self):
        if self.preprocessed_image is None:
            messagebox.showinfo("Info", "No processed histogram data to export.")
            return
        default_name = "histograms.txt"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_histograms.txt"
        path = filedialog.asksaveasfilename(defaultextension=".txt", initialfile=default_name, filetypes=[("Text", "*.txt")])
        if not path:
            return

        values = self.preprocessed_image.ravel().astype(np.float64)
        values = values[np.isfinite(values)]
        if values.size == 0:
            messagebox.showinfo("Info", "No finite processed values available.")
            return
        counts, edges = np.histogram(values, bins=256)
        centers = 0.5 * (edges[:-1] + edges[1:])
        mean_val = float(np.mean(values))
        std_val = float(np.std(values))

        lines = []
        lines.append("[RAW_PREPROCESSED_HISTOGRAM]")
        lines.append(f"file={self.filepath if self.filepath else 'N/A'}")
        lines.append(f"data_unit={self.current_data_unit if self.current_data_unit else 'N/A'}")
        lines.append(f"mean={mean_val}")
        lines.append(f"std={std_val}")
        lines.append(f"bins={len(centers)}")
        lines.append("bin_center,count")
        for c, n in zip(centers, counts):
            lines.append(f"{c:.12g},{int(n)}")

        if self.last_hist_threshold_data is not None:
            lines.append("")
            lines.append("[THRESHOLD_GROUP_HISTOGRAM]")
            lines.append("group,count,percentage")
            groups = self.last_hist_threshold_data.get('groups', [])
            tc = self.last_hist_threshold_data.get('counts', [])
            tp = self.last_hist_threshold_data.get('percentages', [])
            for g, c, p in zip(groups, tc, tp):
                lines.append(f"{g},{int(c)},{p:.8f}")

        try:
            with open(path, 'w', encoding='utf-8') as f:
                f.write("\n".join(lines))
            self.status_var.set(f"Exported histogram TXT: {os.path.basename(path)}")
        except Exception as e:
            messagebox.showerror("Export Error", f"Failed to export histogram TXT:\n{e}")

    def export_histogram_csv(self):
        if self.preprocessed_image is None:
            messagebox.showinfo("Info", "No processed histogram data to export.")
            return

        default_name = "histograms.csv"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_histograms.csv"

        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            initialfile=default_name,
            filetypes=[("CSV", "*.csv")]
        )
        if not path:
            return

        values = self.preprocessed_image.ravel().astype(np.float64)
        values = values[np.isfinite(values)]
        if values.size == 0:
            messagebox.showinfo("Info", "No finite processed values available.")
            return

        counts, edges = np.histogram(values, bins=256)
        centers = 0.5 * (edges[:-1] + edges[1:])
        mean_val = float(np.mean(values))
        std_val = float(np.std(values))

        try:
            with open(path, 'w', newline='', encoding='utf-8-sig') as f:
                writer = csv.writer(f)

                writer.writerow(["[RAW_PREPROCESSED_HISTOGRAM]"])
                writer.writerow(["file", self.filepath if self.filepath else "N/A"])
                writer.writerow(["data_unit", self.current_data_unit if self.current_data_unit else "N/A"])
                writer.writerow(["mean", mean_val])
                writer.writerow(["std", std_val])
                writer.writerow(["bins", len(centers)])
                writer.writerow(["bin_center", "count"])

                for c, n in zip(centers, counts):
                    writer.writerow([f"{c:.12g}", int(n)])

                if self.last_hist_threshold_data is not None:
                    writer.writerow([])
                    writer.writerow(["[THRESHOLD_GROUP_HISTOGRAM]"])
                    writer.writerow(["group", "count", "percentage"])

                    groups = self.last_hist_threshold_data.get('groups', [])
                    tc = self.last_hist_threshold_data.get('counts', [])
                    tp = self.last_hist_threshold_data.get('percentages', [])

                    for g, c, p in zip(groups, tc, tp):
                        writer.writerow([g, int(c), f"{p:.8f}"])

            self.status_var.set(f"Exported histogram CSV: {os.path.basename(path)}")

        except Exception as e:
            messagebox.showerror("Export Error", f"Failed to export histogram CSV:\n{e}")

