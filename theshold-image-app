    )
    self.ax_raw.set_xlabel("X")
    self.ax_raw.set_ylabel("Y")
    self.cbar_raw = self.figure.colorbar(
        self.current_im_raw, ax=self.ax_raw, fraction=0.046, pad=0.04
    )

    self.ax_thr.set_title("Threshold Regions")
