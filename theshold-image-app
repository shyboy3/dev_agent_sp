    # I/O
    def load_images(self):
        paths = filedialog.askopenfilenames(
            title="Select image(s)",
            filetypes=[
                ("Supported", "*.png *.jpg *.jpeg *.tif *.tiff *.bmp *.npy *.csv *.txt *.spm"),
                ("All files", "*.*"),
            ]
        )
        if not paths:
            return
        added = 0
        for path in paths:
            if path not in self.filepaths:
                self.filepaths.append(path)
                self.file_listbox.insert(tk.END, os.path.basename(path))
                added += 1
        if self.filepaths:
            select_idx = len(self.filepaths) - 1
            self.file_listbox.selection_clear(0, tk.END)
            self.file_listbox.selection_set(select_idx)
            self.file_listbox.activate(select_idx)
            self.file_listbox.see(select_idx)
            self._set_current_file(select_idx)
        self.status_var.set(f"Loaded {added} new file(s). Total files: {len(self.filepaths)}")

    def on_file_select(self, event=None):
        selection = self.file_listbox.curselection()
        if not selection:
            return
        self._set_current_file(selection[0])

    def _set_current_file(self, idx):
        if idx < 0 or idx >= len(self.filepaths):
            return
        self.filepath = self.filepaths[idx]
        self._refresh_spm_channel_ui_for_current_file()
        self._read_current_file()

    def on_spm_channel_select(self, event=None):
        if not self.filepath or os.path.splitext(self.filepath)[1].lower() != ".spm":
            return
        self._read_current_file()

    def _refresh_spm_channel_ui_for_current_file(self):
        path = self.filepath
        if not path or os.path.splitext(path)[1].lower() != ".spm":
            self.selected_spm_channel_var.set("")
            if self.spm_channel_combo is not None:
                self.spm_channel_combo.configure(values=[], state="disabled")
            return

        channel_names = self._get_spm_channel_names(path)
        display_names = [str(name) for name in channel_names]
        if self.spm_channel_combo is not None:
            state = "readonly" if display_names else "disabled"
            self.spm_channel_combo.configure(values=display_names, state=state)

        current = self.selected_spm_channel_var.get().strip()
        if current in display_names:
            return

        preferred = self._choose_default_spm_channel(channel_names)
        self.selected_spm_channel_var.set(str(preferred) if preferred is not None else "")

    def _get_spm_channel_names(self, path):
        if path in self.spm_channels_by_path:
            return self.spm_channels_by_path[path]
        if not HAS_PYSPM:
            return []
        try:
            bruker = pySPM.Bruker(path)
            names = list(bruker.list_channels())
        except Exception:
            names = []
        self.spm_channels_by_path[path] = names
        return names

    def _choose_default_spm_channel(self, channel_names):
        preferred_order = [
            "Height Sensor", "Height", "ZSensor", "Z Sensor", "Topography",
            "Height Trace", "Topography Trace", "Height Retrace", "Topography Retrace"
        ]
        lowered = {str(name).strip().lower(): name for name in channel_names}
        for pref in preferred_order:
            match = lowered.get(pref.lower())
            if match is not None:
                return match
        for name in channel_names:
            lname = str(name).lower()
            if "height" in lname or "topography" in lname or "z" in lname:
                return name
        return channel_names[0] if channel_names else None

    def remove_selected_file(self):
        selection = self.file_listbox.curselection()
        if not selection:
            messagebox.showinfo("Info", "Select a file to remove.")
            return
        idx = selection[0]
        removed = self.filepaths.pop(idx)
        self.file_listbox.delete(idx)
        if self.filepath == removed:
            self.reset_processing(keep_image=False)
            if self.filepaths:
                new_idx = min(idx, len(self.filepaths) - 1)
                self.file_listbox.selection_set(new_idx)
                self.file_listbox.activate(new_idx)
                self._set_current_file(new_idx)
            else:
                self.file_label.config(text="No file selected")
                self._refresh_spm_channel_ui_for_current_file()
        self.status_var.set(f"Removed: {os.path.basename(removed)}")

    def clear_file_list(self):
        self.filepaths = []
        self.filepath = None
        self.file_listbox.delete(0, tk.END)
        self.reset_processing(keep_image=False)
        self.file_label.config(text="No file selected")
        self.raw_shape_var.set("Raw Shape: N/A")
        self.current_source_info = None
        self.selected_spm_channel_var.set("")
        self._refresh_spm_channel_ui_for_current_file()
        self.status_var.set("File list cleared")

    def reload_image(self):
        if not self.filepath:
            messagebox.showinfo("Info", "No file selected yet.")
            return
        self._read_current_file()

    def _read_current_file(self):
        try:
            path = self.filepath
            arr, source_info = self._load_array_from_path(path)

            arr = self._to_2d_float(arr)
            self.raw_image = arr
            self.current_source_info = source_info
            h, w = arr.shape
            self.raw_shape_var.set(f"Raw Shape: {h} x {w} (H x W)")
            if self.file_label is not None:
                self.file_label.config(text=path)
            # Preserve all user parameters across file changes.
            # Only initialize display min/max once when they still have their startup defaults.
            if (not self.raw_min_enable_var.get()) and (not self.raw_max_enable_var.get()) and float(self.raw_vmin_var.get()) == 0.0 and float(self.raw_vmax_var.get()) == 1.0:
                self.raw_vmin_var.set(float(np.min(arr)))
                self.raw_vmax_var.set(float(np.max(arr)))
            info_suffix = f" | {source_info}" if source_info else ""
            self.status_var.set(f"Loaded image: {os.path.basename(path)} | size={arr.shape[1]} x {arr.shape[0]}{info_suffix}")
            self.reset_processing(keep_image=True)
            self.process_all()
        except Exception as e:
            messagebox.showerror("Load Error", str(e))
            self.status_var.set("Failed to load image")

    def _load_array_from_path(self, path):
        ext = os.path.splitext(path)[1].lower()
        if ext == ".npy":
            return np.load(path), None
        if ext in [".csv", ".txt"]:
            return np.loadtxt(path, delimiter=',' if ext == '.csv' else None), None
        if ext == ".spm":
            return self._load_spm_file(path)
        return skio.imread(path), None

    def _load_spm_file(self, path):
        if not HAS_PYSPM:
            raise ImportError(
                "Loading .spm files requires pySPM. Install it with: pip install pySPM\n"
                f"Original import error: {PYSPM_IMPORT_ERROR}"
            )

        bruker = pySPM.Bruker(path)
        channel_names = self._get_spm_channel_names(path)
        if not channel_names:
            try:
                channel_names = list(bruker.list_channels())
                self.spm_channels_by_path[path] = channel_names
            except Exception:
                channel_names = []

        chosen_name = self.selected_spm_channel_var.get().strip()
        if not chosen_name or chosen_name not in [str(name) for name in channel_names]:
            default_name = self._choose_default_spm_channel(channel_names)
            chosen_name = str(default_name) if default_name is not None else chosen_name
            self.selected_spm_channel_var.set(chosen_name)

        if not chosen_name:
            raise ValueError("No readable image channel was found in this .spm file.")

        last_error = None
        image_obj = None
        for getter_args in [
            (chosen_name,),
            tuple(name for name in channel_names if str(name) == chosen_name)[:1],
            tuple(),
        ]:
            try:
                if len(getter_args) == 0:
                    continue
                image_obj = bruker.get_channel(*getter_args)
                if image_obj is not None:
                    break
            except Exception as exc:
                last_error = exc

        if image_obj is None:
            raise RuntimeError(f"Failed to read SPM channel '{chosen_name}': {last_error}")

        pixels = getattr(image_obj, "pixels", None)
        if pixels is None:
            raise ValueError(f"SPM channel '{chosen_name}' does not contain pixel data.")

        source_info = f"SPM channel: {chosen_name}"
        zscale = getattr(image_obj, "zscale", None)
        if zscale:
            source_info += f" | z-scale: {zscale}"
        return np.asarray(pixels), source_info

    def _to_2d_float(self, arr):
        arr = np.asarray(arr)
        if arr.ndim == 2:
            out = arr.astype(np.float32)
        elif arr.ndim == 3:
            if arr.shape[2] in [3, 4]:
                out = np.mean(arr[..., :3].astype(np.float32), axis=2)
            else:
                out = np.mean(arr.astype(np.float32), axis=0)
        else:
            raise ValueError(f"Unsupported array shape: {arr.shape}")

        if not np.isfinite(out).all():
            valid = out[np.isfinite(out)]
            fill = float(valid.mean()) if valid.size else 0.0
            out = np.nan_to_num(out, nan=fill, posinf=fill, neginf=fill)
        return out.astype(np.float32)

    # Processing pipeline
    def process_all(self):
        if self.raw_image is None:
            messagebox.showwarning("Warning", "Load an image first.")
            return
        try:
            self.cropped_image = self.get_cropped_image()
            self.preprocessed_image = self.apply_preprocessing(self.cropped_image)
            self.label_image, self.threshold_values = self.compute_threshold_labels(self.preprocessed_image)
            if self.bp_enable_var.get():
                p = max(0, int(self.bp_min_region_size_var.get()))
                self.label_image = self.replace_small_regions_with_neighbors(self.label_image, p)
            self.group_percentages = self.compute_group_percentages(self.label_image)
            self.update_image_panels()
            self.update_histograms()
            groups = int(np.max(self.label_image)) + 1 if self.label_image is not None else 0
            self.status_var.set(f"Processed successfully | groups={groups} | thresholds={np.round(self.threshold_values, 5).tolist()}")
        except Exception as e:
            messagebox.showerror("Process Error", str(e))
            self.status_var.set("Processing failed")

    def reset_processing(self, keep_image=False):
        self.cropped_image = None
        self.preprocessed_image = None
        self.label_image = None
        self.threshold_values = []
        self.group_percentages = []
        self.last_hist_raw = None
        self.last_hist_threshold = None
        self.last_raw_figure = None
        self.last_threshold_figure = None

        if not keep_image:
            self.raw_image = None
            self.filepath = None
            self.current_source_info = None
            self.raw_shape_var.set("Raw Shape: N/A")

        self.clear_canvas("raw")
        self.clear_canvas("threshold")
        self.clear_canvas("raw_hist")
        self.clear_canvas("threshold_hist")
        self.status_var.set("Ready")

    def clear_canvas(self, which):
        mapping = {
            "raw": "raw_canvas",
            "threshold": "threshold_canvas",
            "raw_hist": "raw_hist_canvas",
            "threshold_hist": "threshold_hist_canvas",
        }
        attr = mapping[which]
        obj = getattr(self, attr)
        if obj is not None:
            obj.get_tk_widget().destroy()
            setattr(self, attr, None)

    def get_cropped_image(self):
        img = self.raw_image
        if img is None:
            return None
        if not self.crop_enable_var.get():
            return img.copy()
        h, w = img.shape
        x = max(0, int(self.crop_x_var.get()))
        y = max(0, int(self.crop_y_var.get()))
        cw = max(1, int(self.crop_w_var.get()))
        ch = max(1, int(self.crop_h_var.get()))
        x = min(x, max(0, w - 1))
        y = min(y, max(0, h - 1))
        x2 = min(w, x + cw)
        y2 = min(h, y + ch)
        if x >= x2 or y >= y2:
            raise ValueError("Invalid crop range")
        return img[y:y2, x:x2].copy()

    def apply_preprocessing(self, image):
        out = image.astype(np.float32).copy()
        raw_order = self.pp_order_var.get().strip()
        order = [x.strip().lower() for x in raw_order.split('>')] if raw_order else ["median", "gaussian", "tv", "wavelet"]
        aliases = {
            "median": "median",
            "gaussian": "gaussian",
            "total variation": "tv",
            "tv": "tv",
            "wavelet": "wavelet",
            "wavelet denoising": "wavelet",
        }
        for name in order:
            method = aliases.get(name.lower())
            if method == "median" and self.pp_median_var.get():
                ksize = max(1, int(self.pp_median_size_var.get()))
                if ksize % 2 == 0:
                    ksize += 1
                out = ndi.median_filter(out, size=ksize)
            elif method == "gaussian" and self.pp_gaussian_var.get():
                sigma = max(0.0, float(self.pp_gaussian_sigma_var.get()))
                out = gaussian(out, sigma=sigma, preserve_range=self.pp_gaussian_preserve_range_var.get()).astype(np.float32)
            elif method == "tv" and self.pp_tv_var.get():
                weight = max(1e-8, float(self.pp_tv_weight_var.get()))
                eps = max(1e-12, float(self.pp_tv_eps_var.get()))
                n_iter = max(1, int(self.pp_tv_max_num_iter_var.get()))
                out = denoise_tv_chambolle(out, weight=weight, eps=eps, max_num_iter=n_iter).astype(np.float32)
            elif method == "wavelet" and self.pp_wavelet_var.get():
                sigma = max(0.0, float(self.pp_wavelet_sigma_var.get()))
                wavelet_name = self.pp_wavelet_wavelet_var.get().strip() or "db2"
                mode_name = self.pp_wavelet_mode_var.get().strip() or "soft"
                out = denoise_wavelet(out, sigma=sigma, wavelet=wavelet_name, mode=mode_name, rescale_sigma=self.pp_wavelet_rescale_sigma_var.get(), channel_axis=None).astype(np.float32)
        return out

    def _parse_manual_thresholds(self):
        text = self.manual_thresholds_var.get().strip()
        if not text:
            return []
        parts = [p.strip() for p in text.replace(';', ',').split(',') if p.strip()]
        return sorted(float(p) for p in parts)

    def suggest_thresholds(self):
        if self.raw_image is None:
            messagebox.showinfo("Info", "Load an image first.")
            return
        try:
            img = self.get_cropped_image()
            img = self.apply_preprocessing(img)
            thr = self.compute_auto_threshold_values(img)
            self.manual_thresholds_var.set(", ".join(f"{x:.6g}" for x in thr))
            self.status_var.set("Suggested thresholds updated in manual input field")
        except Exception as e:
            messagebox.showerror("Suggestion Error", str(e))

    def compute_auto_threshold_values(self, image):
        data = image.astype(np.float32)
        flat = data.reshape(-1, 1)
        count = max(1, int(self.threshold_count_var.get()))
        groups = count + 1
        method = self.threshold_method_var.get().strip().lower()

        if method == "otsu":
            return [float(threshold_otsu(data))]
        if method == "multi-otsu":
            return [float(x) for x in threshold_multiotsu(data, classes=groups)]
        if method == "k-means":
            km = KMeans(n_clusters=groups, random_state=int(self.kmeans_random_state_var.get()), n_init=max(1, int(self.kmeans_n_init_var.get())))
            km.fit(flat)
            centers = np.sort(km.cluster_centers_.flatten())
            return self._centers_to_thresholds(centers)
        if method == "gmm":
            gm = GaussianMixture(n_components=groups, covariance_type=self.gmm_covariance_type_var.get(), random_state=int(self.gmm_random_state_var.get()))
            gm.fit(flat)
            means = np.sort(gm.means_.flatten())
            return self._centers_to_thresholds(means)
        if method == "equal interval":
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            if p_high <= p_low:
                raise ValueError("Equal Interval: High percentile must be greater than low percentile.")
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            return [float(x) for x in np.linspace(low, high, groups + 1)[1:-1]]
        raise ValueError(f"Unknown threshold method: {self.threshold_method_var.get()}")

    def compute_threshold_labels(self, image):
        data = image.astype(np.float32)
        count = max(1, int(self.threshold_count_var.get()))
        if self.use_manual_thresholds_var.get():
            thr = self._parse_manual_thresholds()
            if not thr:
                raise ValueError("Manual thresholds are enabled, but no values were entered.")
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        thr = self.compute_auto_threshold_values(data)
        if self.threshold_method_var.get().strip().lower() == "otsu":
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        if len(thr) != count:
            raise ValueError(f"Threshold count mismatch: expected {count}, got {len(thr)}")
        labels = np.digitize(data, bins=thr).astype(np.int32)
        if self.threshold_method_var.get().strip().lower() == "equal interval":
            groups = len(thr) + 1
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            labels[data < low] = 0
            labels[data >= high] = groups - 1
        return labels, thr

    def _centers_to_thresholds(self, centers_sorted):
        centers_sorted = np.asarray(centers_sorted, dtype=np.float32)
        if centers_sorted.size <= 1:
            return []
        mids = 0.5 * (centers_sorted[:-1] + centers_sorted[1:])
        return [float(x) for x in mids]

    def replace_small_regions_with_neighbors(self, label_img, max_region_size):
        out = label_img.copy()
        structure = np.ones((3, 3), dtype=np.uint8)
        unique_vals = np.unique(out)
        for val in unique_vals:
            mask = out == val
            cc, n_cc = ndi.label(mask, structure=structure)
            for idx in range(1, n_cc + 1):
                region_mask = cc == idx
                area = int(region_mask.sum())
                if area <= max_region_size:
                    dilated = ndi.binary_dilation(region_mask, structure=structure)
                    border = dilated & (~region_mask)
                    neighbor_vals = out[border]
                    neighbor_vals = neighbor_vals[neighbor_vals != val]
                    if neighbor_vals.size == 0:
                        continue
                    replacement = mode(neighbor_vals, keepdims=False).mode
                    out[region_mask] = int(replacement)
        return out.astype(np.int32)

    def compute_group_percentages(self, label_img):
        if label_img is None:
            return []
        labels = label_img.ravel().astype(np.int32)
        groups = int(labels.max()) + 1 if labels.size else 0
        counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
        total = max(1, int(counts.sum()))
        return [100.0 * c / total for c in counts]

