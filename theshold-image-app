def refresh_display(self):
    if self.current_data is None:
        self._draw_empty()
        return

    cmap_name = self.cmap_var.get()
    thr_cmap_name = self.threshold_cmap_var.get()

    vmin, vmax = self.get_display_limits()
    if vmin is None and self.vmin_var.get().strip() != "":
        return
    if vmax is None and self.vmax_var.get().strip() != "":
        return

    # display용 안전 배열
    disp = np.array(self.current_data, dtype=float)
    finite_mask = np.isfinite(disp)

    if not np.any(finite_mask):
        if self.cbar_raw is not None:
            try:
                self.cbar_raw.remove()
            except Exception:
                pass
            self.cbar_raw = None

        if self.cbar_thr is not None:
            try:
                self.cbar_thr.remove()
            except Exception:
                pass
            self.cbar_thr = None

        self.ax_raw.clear()
        self.ax_thr.clear()
        self.ax_raw.set_title("Raw / Cropped Image")
        self.ax_thr.set_title("Threshold Regions")
