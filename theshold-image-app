def to_dict(self) -> dict:
    return self.__dict__.copy()

@classmethod
def from_dict(cls, d: dict) -> "ProcessingParams":
    p = cls()
    for k, v in d.items():
        if hasattr(p, k):
            setattr(p, k, v)
    return p

def summary(self) -> str:
    """Human-readable parameter summary for debug mode."""
    lines = []
    lines.append("📋 **Current Parameters**")
    lines.append(f"- Crop: {'enabled' if self.crop_enable else 'disabled'}"
                 + (f" (x={self.crop_x}, y={self.crop_y}, w={self.crop_w}, h={self.crop_h})" if self.crop_enable else ""))
    lines.append(f"- Flattening: mode={self.flatten_mode}, orders={self.flatten_orders or 'none'}"
                 + (f", robust=True (k={self.flatten_robust_k})" if self.flatten_robust else ""))
    pp_active = []
    if self.pp_median_enable:
        pp_active.append(f"Median(kernel={self.pp_median_size})")
    if self.pp_gaussian_enable:
        pp_active.append(f"Gaussian(sigma={self.pp_gaussian_sigma})")
    if self.pp_tv_enable:
        pp_active.append(f"TV(weight={self.pp_tv_weight})")
    if self.pp_wavelet_enable:
        pp_active.append(f"Wavelet(sigma={self.pp_wavelet_sigma})")
    lines.append(f"- PreProcessing: {', '.join(pp_active) if pp_active else 'none'}")
    lines.append(f"- Threshold: method={self.threshold_method}, count={self.threshold_count}"
                 + (" [MANUAL]" if self.use_manual_thresholds else ""))
    if self.use_manual_thresholds and self.manual_thresholds:
        lines.append(f"  Manual values: {self.manual_thresholds}")
    lines.append(f"- Binary Processing: {'enabled' if self.bp_enable else 'disabled'}"
                 + (f" (min_region={self.bp_min_region_size}px)" if self.bp_enable else ""))
    lines.append(f"- Display: colormap={self.raw_colormap}, vmin={'auto' if not self.raw_min_enable else self.raw_vmin}, vmax={'auto' if not self.raw_max_enable else self.raw_vmax}")
    lines.append(f"  Boundaries: {'on' if self.show_boundaries else 'off'}"
                 + (f" ({self.boundary_color}, thickness={self.boundary_thickness})" if self.show_boundaries else ""))
    return "\n".join(lines)
