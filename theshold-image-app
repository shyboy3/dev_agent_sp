def multi_threshold_masks(data: np.ndarray, thresholds: List[float]) -> Tuple[List[np.ndarray], List[Tuple[float, float]]]:
    """
    Convert K thresholds into K+1 regions.
    Region ranges:
      (-inf, t1), [t1, t2), ..., [tK, +inf)
    """
    ts = sorted(thresholds)
    masks: List[np.ndarray] = []
    ranges: List[Tuple[float, float]] = []

    prev = -np.inf
    for t in ts:
        mask = (data >= prev) & (data < t)
        masks.append(mask)
        ranges.append((prev, t))
        prev = t

    mask = data >= prev
    masks.append(mask)
    ranges.append((prev, np.inf))
    return masks, ranges


def auto_thresholds_equal_interval(data: np.ndarray, n_thresh: int) -> List[float]:
    dmin = float(np.nanmin(data))
    dmax = float(np.nanmax(data))
    if n_thresh <= 0:
        return []
    return np.linspace(dmin, dmax, n_thresh + 2)[1:-1].tolist()


def _otsu_from_hist(hist: np.ndarray, bin_centers: np.ndarray) -> float:
    hist = hist.astype(float)
    prob = hist / np.sum(hist)
    omega = np.cumsum(prob)
    mu = np.cumsum(prob * bin_centers)
    mu_t = mu[-1]

    denom = omega * (1.0 - omega)
    sigma_b2 = np.full_like(denom, -1.0)
    valid = denom > 0
    sigma_b2[valid] = ((mu_t * omega[valid] - mu[valid]) ** 2) / denom[valid]

    idx = int(np.argmax(sigma_b2[:-1])) if len(sigma_b2) > 1 else 0
    return float(bin_centers[idx])


def auto_thresholds_otsu(data: np.ndarray, n_bins: int = 256) -> List[float]:
    vals = data[np.isfinite(data)].ravel()
    if vals.size == 0:
        return []
    if np.min(vals) == np.max(vals):
        return [float(vals[0])]
    hist, bin_edges = np.histogram(vals, bins=n_bins)
    bin_centers = 0.5 * (bin_edges[:-1] + bin_edges[1:])
    return [_otsu_from_hist(hist, bin_centers)]


def auto_thresholds_multi_otsu(data: np.ndarray, n_thresh: int, n_bins: int = 128) -> List[float]:
    vals = data[np.isfinite(data)].ravel()
    if vals.size == 0 or n_thresh <= 0:
        return []
    vmin, vmax = float(np.min(vals)), float(np.max(vals))
    if vmin == vmax:
        return [vmin] * n_thresh

    hist, bin_edges = np.histogram(vals, bins=n_bins, range=(vmin, vmax))
    hist = hist.astype(float)
    p = hist / np.sum(hist)
    centers = 0.5 * (bin_edges[:-1] + bin_edges[1:])

    omega = np.cumsum(p)
    mu = np.cumsum(p * centers)
    mu_t = mu[-1]

    def class_stats(a: int, b: int) -> Tuple[float, float]:
        if a == 0:
            w = omega[b]
            m = mu[b]
        else:
            w = omega[b] - omega[a - 1]
            m = mu[b] - mu[a - 1]
        if w <= 0:
            return 0.0, 0.0
        return w, m / w

    num_classes = n_thresh + 1
    n = len(hist)
    if num_classes <= 1 or n < num_classes:
        return auto_thresholds_equal_interval(vals, n_thresh)

    best_sigma = -np.inf
    best_breaks = None
    for breaks in combinations_with_replacement(range(n - 1), n_thresh):
        valid = True
        prev = 0
        sigma = 0.0
        for br in list(breaks) + [n - 1]:
            if br < prev:
                valid = False
                break
            w, mean_c = class_stats(prev, br)
            sigma += w * (mean_c - mu_t) ** 2
            prev = br + 1
        if valid and sigma > best_sigma:
            best_sigma = sigma
            best_breaks = breaks

    if best_breaks is None:
        return auto_thresholds_equal_interval(vals, n_thresh)

    thresholds = [float(bin_edges[b + 1]) for b in best_breaks]
    return sorted(thresholds)


def auto_thresholds_kmeans(data: np.ndarray, n_thresh: int, random_state: int = 0) -> List[float]:
    vals = data[np.isfinite(data)].ravel().reshape(-1, 1)
    if vals.size == 0 or n_thresh <= 0:
        return []
    n_clusters = n_thresh + 1
    if vals.shape[0] < n_clusters:
        return auto_thresholds_equal_interval(data, n_thresh)
    km = KMeans(n_clusters=n_clusters, n_init=10, random_state=random_state)
    km.fit(vals)
    centers = np.sort(km.cluster_centers_.ravel())
    thresholds = [(centers[i] + centers[i + 1]) / 2.0 for i in range(len(centers) - 1)]
    return [float(t) for t in thresholds]


def auto_thresholds_gmm(data: np.ndarray, n_thresh: int, random_state: int = 0) -> List[float]:
    vals = data[np.isfinite(data)].ravel().reshape(-1, 1)
    if vals.size == 0 or n_thresh <= 0:
        return []
    n_components = n_thresh + 1
    if vals.shape[0] < n_components:
        return auto_thresholds_equal_interval(data, n_thresh)

    gmm = GaussianMixture(n_components=n_components, covariance_type="full", random_state=random_state)
    gmm.fit(vals)

    means = gmm.means_.ravel()
    variances = np.array([c[0, 0] for c in gmm.covariances_], dtype=float)
    weights = gmm.weights_.ravel()

    order = np.argsort(means)
    means = means[order]
    variances = variances[order]
    weights = weights[order]

    thresholds: List[float] = []
    for i in range(len(means) - 1):
        m1, m2 = means[i], means[i + 1]
        s1, s2 = np.sqrt(max(variances[i], 1e-12)), np.sqrt(max(variances[i + 1], 1e-12))
        w1, w2 = max(weights[i], 1e-12), max(weights[i + 1], 1e-12)

        a = 1.0 / (2.0 * s2 ** 2) - 1.0 / (2.0 * s1 ** 2)
        b = m1 / (s1 ** 2) - m2 / (s2 ** 2)
        c = (m2 ** 2) / (2.0 * s2 ** 2) - (m1 ** 2) / (2.0 * s1 ** 2) + np.log((w2 * s1) / (w1 * s2))

        if abs(a) < 1e-12:
            if abs(b) < 1e-12:
                x = (m1 + m2) / 2.0
            else:
                x = -c / b
        else:
            disc = b ** 2 - 4.0 * a * c
            if disc < 0:
                x = (m1 + m2) / 2.0
            else:
                roots = [(-b + np.sqrt(disc)) / (2.0 * a), (-b - np.sqrt(disc)) / (2.0 * a)]
                between = [r for r in roots if min(m1, m2) <= r <= max(m1, m2)]
                x = between[0] if between else (m1 + m2) / 2.0
        thresholds.append(float(x))

    return sorted(thresholds)[:n_thresh]


def auto_threshold_count_by_unique(data: np.ndarray, max_thresholds: int = 10) -> int:
    """
    Heuristic:
    - if unique count is small, use unique_count-1
    - otherwise use sqrt-based capped count
    """
    flat = data.ravel()
    unique_count = len(np.unique(np.round(flat, decimals=8)))
    if unique_count <= 1:
        return 1
    if unique_count <= max_thresholds + 1:
        return max(1, unique_count - 1)
    n = int(np.clip(np.sqrt(unique_count) / 2, 2, max_thresholds))
    return n


def build_region_map(data: np.ndarray, thresholds: List[float]) -> np.ndarray:
    ts = np.array(sorted(thresholds), dtype=float)
    return np.digitize(data, bins=ts, right=False)


