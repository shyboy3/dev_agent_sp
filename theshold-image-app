# ------------------------------------------------------------
# Data loading
# ------------------------------------------------------------

def load_nanoscope_txt(filepath: str) -> Tuple[np.ndarray, Dict[str, str]]:
    """
    Load NanoScope numerical data exported as txt.

    Expected format:
    - metadata lines begin with '#'
    - numerical data are whitespace-separated rows
    """
    metadata: Dict[str, str] = {}
    numeric_rows: List[List[float]] = []

    with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
        for line in f:
            s = line.strip()
            if not s:
                continue
            if s.startswith("#"):
                line2 = s.lstrip("#").strip()
                if ":" in line2:
                    k, v = line2.split(":", 1)
                    metadata[k.strip()] = v.strip()
                else:
                    metadata[f"meta_{len(metadata)+1}"] = line2
                continue

            parts = re.split(r"\s+", s)
            try:
                row = [float(x) for x in parts if x != ""]
            except ValueError:
                # Skip malformed lines that are neither valid metadata nor numeric rows
                continue

            if row:
                numeric_rows.append(row)

    if not numeric_rows:
        raise ValueError("No numerical data found in the TXT file.")

    widths = {len(r) for r in numeric_rows}
    if len(widths) != 1:
        raise ValueError("Inconsistent row lengths found in numerical data.")

    arr = np.array(numeric_rows, dtype=float)
    return arr, metadata


# ------------------------------------------------------------
# Threshold analysis
# ------------------------------------------------------------

def multi_threshold_masks(data: np.ndarray, thresholds: List[float]) -> Tuple[List[np.ndarray], List[Tuple[float, float]]]:
    """
    Convert K thresholds into K+1 regions.
    Region ranges:
      (-inf, t1), [t1, t2), ..., [tK, +inf)
    """
    ts = sorted(thresholds)
    masks: List[np.ndarray] = []
    ranges: List[Tuple[float, float]] = []

    prev = -np.inf
    for t in ts:
        mask = (data >= prev) & (data < t)
        masks.append(mask)
        ranges.append((prev, t))
        prev = t

    mask = data >= prev
    masks.append(mask)
    ranges.append((prev, np.inf))
    return masks, ranges


def auto_thresholds_equal_interval(data: np.ndarray, n_thresh: int) -> List[float]:
    dmin = float(np.nanmin(data))
    dmax = float(np.nanmax(data))
    if n_thresh <= 0:
        return []
    return np.linspace(dmin, dmax, n_thresh + 2)[1:-1].tolist()


def auto_thresholds_quantile(data: np.ndarray, n_thresh: int) -> List[float]:
    if n_thresh <= 0:
        return []
    qs = np.linspace(0, 1, n_thresh + 2)[1:-1]
    return np.quantile(data.ravel(), qs).tolist()


def auto_threshold_count_by_unique(data: np.ndarray, max_thresholds: int = 10) -> int:
    """
    Heuristic:
    - if unique count is small, use unique_count-1
    - otherwise use sqrt-based capped count
    """
    flat = data.ravel()
    unique_count = len(np.unique(np.round(flat, decimals=8)))
    if unique_count <= 1:
        return 1
    if unique_count <= max_thresholds + 1:
        return max(1, unique_count - 1)
    n = int(np.clip(np.sqrt(unique_count) / 2, 2, max_thresholds))
    return n


def build_region_map(data: np.ndarray, thresholds: List[float]) -> np.ndarray:
    ts = np.array(sorted(thresholds), dtype=float)
    return np.digitize(data, bins=ts, right=False)


