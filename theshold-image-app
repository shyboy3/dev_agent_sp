        lines.append(f"Show boundaries: {self.show_boundaries_var.get()} | color={self.boundary_color_var.get()} | contour thickness={self.boundary_thickness_var.get()}")
        lines.append("")

        lines.append("[Threshold Group Percentages]")
        for i, pct in enumerate(self.group_percentages):
            lines.append(f"Group {i}: {pct:.4f}%")

        with open(path, 'w', encoding='utf-8') as f:
            f.write("\n".join(lines))
        self.status_var.set(f"Exported summary: {os.path.basename(path)}")

    def save_raw_image(self):
        if self.last_raw_figure is None:
