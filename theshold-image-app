    def apply_threshold(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            thresholds = self._parse_thresholds()
        except Exception as e:
            messagebox.showerror("Threshold Error", str(e))
            return

        self.region_map = build_region_map(self.current_data, thresholds)
        masks, ranges = multi_threshold_masks(self.current_data, thresholds)
        total = self.current_data.size

        lines: List[str] = []
        lines.append("[Threshold Summary]")
        lines.append(f"Thresholds: {', '.join(f'{t:.6g}' for t in thresholds)}")
        lines.append("")

        for idx, (mask, rg) in enumerate(zip(masks, ranges)):
            count = int(mask.sum())
            pct = 100.0 * count / total if total > 0 else 0.0

            lo, hi = rg
            lo_s = "-inf" if np.isneginf(lo) else f"{lo:.6g}"
            hi_s = "+inf" if np.isposinf(hi) else f"{hi:.6g}"
            label = f"Region {idx}: [{lo_s}, {hi_s})" if not np.isposinf(hi) else f"Region {idx}: [{lo_s}, {hi_s}]"
            lines.append(f"{label}")
            lines.append(f"  Pixels: {count}")
            lines.append(f"  Percent: {pct:.3f}%")

        self.region_summary = lines
        self.update_info_panel()
        self.refresh_display()

