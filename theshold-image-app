    def get_parameter_state(self):
        return {name: var.get() for name, var in self._parameter_specs()}

    def apply_parameter_state(self, state):
        applied = 0
        for name, var in self._parameter_specs():
            if name in state:
                try:
                    var.set(state[name])
                    applied += 1
                except Exception:
                    pass
        return applied

    def save_parameters_to_file(self):
        state = self.get_parameter_state()
        default_name = "nanoscope_threshold_params.json"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_params.json"
        path = filedialog.asksaveasfilename(
            defaultextension=".json",
            initialfile=default_name,
            filetypes=[("JSON", "*.json"), ("All files", "*.*")],
        )
        if not path:
            return
        payload = {
            "app": "NanoScope Threshold App",
            "version": 1,
            "parameters": state,
        }
        with open(path, "w", encoding="utf-8") as f:
            json.dump(payload, f, indent=2, ensure_ascii=False)
        self.status_var.set(f"Saved parameter file: {os.path.basename(path)}")

    def load_parameters_from_file(self):
        path = filedialog.askopenfilename(
            title="Load parameter file",
            filetypes=[("JSON", "*.json"), ("All files", "*.*")],
        )
        if not path:
            return
        try:
            with open(path, "r", encoding="utf-8") as f:
                payload = json.load(f)
            state = payload.get("parameters", payload)
            applied = self.apply_parameter_state(state)
            self._refresh_spm_channel_ui_for_current_file()
            self.status_var.set(f"Loaded parameter file: {os.path.basename(path)} | applied={applied}")
            if self.raw_image is not None:
                self.process_all()
        except Exception as e:
            messagebox.showerror("Load Params Error", str(e))

    # Export / Save
    def export_processing_summary(self):
        if self.preprocessed_image is None or self.label_image is None:
            messagebox.showinfo("Info", "No processed result to export.")
            return
        default_name = "processing_summary.txt"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_processing_summary.txt"
        path = filedialog.asksaveasfilename(defaultextension=".txt", initialfile=default_name, filetypes=[("Text", "*.txt")])
