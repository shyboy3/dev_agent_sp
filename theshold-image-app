    def _build_ui(self):
        outer = ttk.Frame(self.root)
        outer.pack(fill="both", expand=True)

        control_outer = ttk.Frame(outer, width=520)
        control_outer.pack(side="left", fill="y", padx=8, pady=8)
        control_outer.pack_propagate(False)

        self.control_canvas = tk.Canvas(control_outer, highlightthickness=0, width=500)
        self.control_canvas.pack(side="left", fill="both", expand=True)

        self.control_scrollbar = ttk.Scrollbar(control_outer, orient="vertical", command=self.control_canvas.yview)
        self.control_scrollbar.pack(side="right", fill="y")
        self.control_canvas.configure(yscrollcommand=self.control_scrollbar.set)

        control = ttk.Frame(self.control_canvas)
        self.control_frame = control
        self._control_window_id = self.control_canvas.create_window((0, 0), window=control, anchor="nw")

        control.bind("<Configure>", self._on_control_frame_configure)
        self.control_canvas.bind("<Configure>", self._on_control_canvas_configure)
        self.control_canvas.bind("<Enter>", self._bind_mousewheel)
        self.control_canvas.bind("<Leave>", self._unbind_mousewheel)

        view = ttk.Frame(outer)
        view.pack(side="right", fill="both", expand=True, padx=8, pady=8)

        self._build_file_group(control)
        self._build_action_group(control)
        self._build_crop_group(control)
        self._build_preprocessing_group(control)
        self._build_threshold_group(control)
        self._build_binary_processing_group(control)
        self._build_display_group(control)

        ttk.Label(control, textvariable=self.status_var, foreground="blue", wraplength=470).pack(fill="x", padx=4, pady=6)
        self._build_view_group(view)


    def _on_control_frame_configure(self, event=None):
        self.control_canvas.configure(scrollregion=self.control_canvas.bbox("all"))

    def _on_control_canvas_configure(self, event):
        self.control_canvas.itemconfigure(self._control_window_id, width=event.width)

    def _bind_mousewheel(self, event=None):
        self.control_canvas.bind_all("<MouseWheel>", self._on_mousewheel)
        self.control_canvas.bind_all("<Button-4>", self._on_mousewheel_linux)
        self.control_canvas.bind_all("<Button-5>", self._on_mousewheel_linux)

    def _unbind_mousewheel(self, event=None):
        self.control_canvas.unbind_all("<MouseWheel>")
        self.control_canvas.unbind_all("<Button-4>")
        self.control_canvas.unbind_all("<Button-5>")

    def _on_mousewheel(self, event):
        self.control_canvas.yview_scroll(int(-1 * (event.delta / 120)), "units")

    def _on_mousewheel_linux(self, event):
        if event.num == 4:
            self.control_canvas.yview_scroll(-1, "units")
        elif event.num == 5:
            self.control_canvas.yview_scroll(1, "units")

