            f"Mean = {self._format_number_with_unit(mean_val)}\n"
            f"Std = {self._format_number_with_unit(std_val)}"
        )
        ax.text(0.98, 0.98, stats_text, transform=ax.transAxes, ha='right', va='top', fontsize=9,
