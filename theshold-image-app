import json
import os
import csv
import numpy as np
from pathlib import Path

from ..core.processor import AFMProcessor, ProcessingParams, ProcessingResult
from ..core.renderer import AFMRenderer
from .tool_definitions import ToolResult

class ToolExecutor:

```
def __init__(self):
    self.processor = AFMProcessor()
    self.renderer = AFMRenderer()
    self.params = ProcessingParams()
    self.result = ProcessingResult()
    self.current_file_path: str | None = None

# ──────────────────────────────────────────
# Dispatch
# ──────────────────────────────────────────

def execute(self, tool_name: str, arguments: dict) -> ToolResult:
    handlers = {
        "load_image": self._load_image,
        "list_channels": self._list_channels,
        "process_image": self._process_image,
        "show_image": self._show_image,
        "get_statistics": self._get_statistics,
        "suggest_thresholds": self._suggest_thresholds,
        "get_parameters": self._get_parameters,
        "save_result": self._save_result,
        "save_parameters": self._save_parameters,
        "load_parameters": self._load_parameters,
        "export_summary": self._export_summary,
        "export_histogram_csv": self._export_histogram_csv,
    }
    handler = handlers.get(tool_name)
    if handler is None:
        return ToolResult(success=False, message=f"Unknown tool: {tool_name}")
    try:
        return handler(arguments)
    except Exception as e:
        return ToolResult(success=False, message=f"Tool '{tool_name}' failed: {e}")

# ──────────────────────────────────────────
# Tool Handlers
# ──────────────────────────────────────────

def _load_image(self, args: dict) -> ToolResult:
    path = args.get("file_path", "")
    if not path:
        return ToolResult(success=False, message="file_path is required.")
    if not os.path.exists(path):
        return ToolResult(success=False, message=f"File not found: {path}")

    channel = args.get("channel", "")
    self.current_file_path = path

    # Get available channels first for SPM files
    channels = self.processor.get_spm_channels(path)
    if channels and not channel:
        channel = self.processor.choose_default_channel(channels) or ""
        if channel:
            self.params.selected_spm_channel = channel

    load_result = self.processor.load_image(path, channel)
    if load_result.error:
        return ToolResult(success=False, message=f"Load failed: {load_result.error}")

    self.result.raw_image = load_result.raw_image
    self.result.source_info = load_result.source_info

    h, w = load_result.raw_image.shape
    msg = f"✅ Loaded: {os.path.basename(path)} | Size: {w} x {h} px"
    if channel:
        msg += f" | Channel: {channel}"
    if channels:
        msg += f"\nAvailable channels: {', '.join(channels)}"
    if load_result.source_info:
        msg += f"\nSource: {load_result.source_info}"
    return ToolResult(success=True, message=msg)

def _list_channels(self, args: dict) -> ToolResult:
    path = args.get("file_path", self.current_file_path or "")
    if not path:
        return ToolResult(success=False, message="file_path is required.")
    channels = self.processor.get_spm_channels(path)
    if not channels:
        return ToolResult(success=True, message="No AFM channels found (may not be a SPM file).")
    return ToolResult(success=True, message=f"Channels in {os.path.basename(path)}:\n" +
                      "\n".join(f"  {i}: {name}" for i, name in enumerate(channels)))

def _process_image(self, args: dict) -> ToolResult:
    if self.result.raw_image is None:
        return ToolResult(success=False, message="No image loaded. Use load_image first.")

    # Apply provided args to params
    self._update_params(args)

    pipeline_result = self.processor.run_pipeline(self.result.raw_image, self.params)
    if pipeline_result.error:
        return ToolResult(success=False, message=f"Processing failed: {pipeline_result.error}")

    # Preserve metadata from load
    pipeline_result.raw_image = self.result.raw_image
    pipeline_result.source_info = self.result.source_info
    pipeline_result.data_unit = self.result.data_unit
    pipeline_result.xy_unit = self.result.xy_unit
    pipeline_result.x_total = self.result.x_total
    pipeline_result.y_total = self.result.y_total
    pipeline_result.afm_backend = self.result.afm_backend
    pipeline_result.afm_metrics = self.result.afm_metrics
    self.result = pipeline_result

    groups = int(np.max(self.result.label_image)) + 1
    thr_str = ", ".join(f"{t:.6g}" for t in self.result.threshold_values)
    msg = (f"✅ Processing complete\n"
           f"- Method: {self.params.threshold_method}\n"
           f"- Groups: {groups}\n"
           f"- Thresholds: {thr_str}\n"
           f"- Group percentages: " +
           ", ".join(f"G{i}={p:.1f}%" for i, p in enumerate(self.result.group_percentages)))
    return ToolResult(success=True, message=msg)

def _show_image(self, args: dict) -> ToolResult:
    if self.result.preprocessed_image is None and self.result.label_image is None:
        return ToolResult(success=False, message="No processed result. Run process_image first.")

    # Update display params only
    display_keys = [
        "raw_colormap", "threshold_colormap",
        "raw_min_enable", "raw_max_enable", "raw_vmin", "raw_vmax",
        "show_boundaries", "boundary_color", "boundary_thickness",
    ]
    for k in display_keys:
        if k in args:
            setattr(self.params, k, args[k])

    show_raw = args.get("show_raw", True)
    show_threshold = args.get("show_threshold", True)
    show_raw_hist = args.get("show_raw_hist", False)
    show_threshold_hist = args.get("show_threshold_hist", False)

    try:
        fig = self.renderer.render_combined(
            self.result, self.params,
            show_raw=show_raw,
            show_threshold=show_threshold,
            show_raw_hist=show_raw_hist,
            show_threshold_hist=show_threshold_hist,
        )
        pil_image = self.renderer.fig_to_pil(fig)
        return ToolResult(success=True, message="", data=pil_image, render_type="image")
    except Exception as e:
        return ToolResult(success=False, message=f"Render failed: {e}")

def _get_statistics(self, args: dict) -> ToolResult:
    if self.result.preprocessed_image is None:
        return ToolResult(success=False, message="No processed data available.")
    return ToolResult(success=True, message=self.result.stats_summary(), render_type="stats")

def _suggest_thresholds(self, args: dict) -> ToolResult:
    if self.result.raw_image is None:
        return ToolResult(success=False, message="No image loaded.")
    # Temporarily override if args provided
    tmp_params = ProcessingParams.from_dict(self.params.to_dict())
    if "threshold_method" in args:
        tmp_params.threshold_method = args["threshold_method"]
    if "threshold_count" in args:
        tmp_params.threshold_count = int(args["threshold_count"])

    thr = self.processor.suggest_thresholds(self.result.raw_image, tmp_params)
    thr_str = ", ".join(f"{t:.6g}" for t in thr)
    return ToolResult(
        success=True,
        message=f"💡 Suggested thresholds ({tmp_params.threshold_method}): {thr_str}\n"
                f"To apply manually: use process_image with use_manual_thresholds=true, manual_thresholds=[{thr_str}]"
    )

def _get_parameters(self, args: dict) -> ToolResult:
    return ToolResult(success=True, message=self.params.summary(), render_type="stats")

def _save_result(self, args: dict) -> ToolResult:
    save_type = args.get("save_type", "all")
    output_path = args.get("output_path", "")
    if not output_path:
        return ToolResult(success=False, message="output_path is required.")

    saved = []
    base, ext = os.path.splitext(output_path)
    if not ext:
        ext = ".png"

    def save_fig(fig, path):
        fig.savefig(path, bbox_inches="tight", dpi=150)
        import matplotlib.pyplot as plt
        plt.close(fig)

    if save_type in ("raw_image", "all") and self.result.preprocessed_image is not None:
        p = f"{base}_raw{ext}" if save_type == "all" else output_path
        save_fig(self.renderer.render_raw(self.result, self.params), p)
        saved.append(p)

    if save_type in ("threshold_image", "all") and self.result.label_image is not None:
        p = f"{base}_threshold{ext}" if save_type == "all" else output_path
        save_fig(self.renderer.render_threshold(self.result, self.params), p)
        saved.append(p)

    if save_type in ("raw_histogram", "all") and self.result.preprocessed_image is not None:
        p = f"{base}_raw_hist{ext}" if save_type == "all" else output_path
        save_fig(self.renderer.render_raw_histogram(self.result, self.params), p)
        saved.append(p)

    if save_type in ("threshold_histogram", "all") and self.result.label_image is not None:
        p = f"{base}_thr_hist{ext}" if save_type == "all" else output_path
        save_fig(self.renderer.render_threshold_histogram(self.result, self.params), p)
        saved.append(p)

    if not saved:
        return ToolResult(success=False, message="Nothing to save (no processed result).")
    return ToolResult(success=True, message="✅ Saved:\n" + "\n".join(f"  {p}" for p in saved))

def _save_parameters(self, args: dict) -> ToolResult:
    path = args.get("output_path", "")
    if not path:
        return ToolResult(success=False, message="output_path is required.")
    payload = {"app": "AFM Agent", "version": 1, "parameters": self.params.to_dict()}
    with open(path, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2, ensure_ascii=False)
    return ToolResult(success=True, message=f"✅ Parameters saved to {path}")

def _load_parameters(self, args: dict) -> ToolResult:
    path = args.get("file_path", "")
    if not path or not os.path.exists(path):
        return ToolResult(success=False, message=f"File not found: {path}")
    with open(path, "r", encoding="utf-8") as f:
        payload = json.load(f)
    state = payload.get("parameters", payload)
    self.params = ProcessingParams.from_dict(state)
    return ToolResult(success=True, message=f"✅ Parameters loaded from {path}\n{self.params.summary()}")

def _export_summary(self, args: dict) -> ToolResult:
    path = args.get("output_path", "")
    if not path:
        return ToolResult(success=False, message="output_path is required.")
    lines = ["AFM Agent - Processing Summary", "=" * 48]
    lines.append(f"File: {self.current_file_path or 'N/A'}")
    lines.append(f"Source: {self.result.source_info or 'N/A'}")
    lines.append("")
    lines.append(self.params.summary().replace("**", "").replace("📋 ", ""))
    lines.append("")
    lines.append(self.result.stats_summary().replace("**", "").replace("📊 ", ""))
    with open(path, "w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    return ToolResult(success=True, message=f"✅ Summary exported to {path}")

def _export_histogram_csv(self, args: dict) -> ToolResult:
    path = args.get("output_path", "")
    if not path:
        return ToolResult(success=False, message="output_path is required.")
    if self.result.preprocessed_image is None:
        return ToolResult(success=False, message="No processed data.")

    values = self.result.preprocessed_image.ravel().astype(np.float64)
    values = values[np.isfinite(values)]
    counts, edges = np.histogram(values, bins=256)
    centers = 0.5 * (edges[:-1] + edges[1:])

    with open(path, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(["[RAW_HISTOGRAM]"])
        writer.writerow(["bin_center", "count"])
        for c, n in zip(centers, counts):
            writer.writerow([f"{c:.12g}", int(n)])
        if self.result.group_percentages:
            writer.writerow([])
            writer.writerow(["[GROUP_HISTOGRAM]"])
            writer.writerow(["group", "count", "percentage"])
            labels = self.result.label_image.ravel().astype(np.int32)
            groups = int(labels.max()) + 1
            grp_counts = [(labels == i).sum() for i in range(groups)]
            for i, (c, p) in enumerate(zip(grp_counts, self.result.group_percentages)):
                writer.writerow([i, int(c), f"{p:.8f}"])
    return ToolResult(success=True, message=f"✅ Histogram CSV exported to {path}")

# ──────────────────────────────────────────
# Param Update Helper
# ──────────────────────────────────────────

def _update_params(self, args: dict):
    """Apply tool call arguments to self.params, type-safe."""
    int_keys = [
        "crop_x", "crop_y", "crop_w", "crop_h",
        "pp_median_size", "pp_tv_max_num_iter",
        "threshold_count", "kmeans_random_state", "kmeans_n_init",
        "gmm_random_state", "bp_min_region_size",
    ]
    float_keys = [
        "flatten_robust_k", "pp_gaussian_sigma", "pp_tv_weight",
        "pp_tv_eps", "pp_wavelet_sigma",
        "equal_interval_percentile_low", "equal_interval_percentile_high",
        "raw_vmin", "raw_vmax", "boundary_thickness",
    ]
    bool_keys = [
        "crop_enable", "flatten_robust",
        "pp_median_enable", "pp_gaussian_enable", "pp_gaussian_preserve_range",
        "pp_tv_enable", "pp_wavelet_enable", "pp_wavelet_rescale_sigma",
        "use_manual_thresholds", "bp_enable",
        "raw_min_enable", "raw_max_enable", "show_boundaries",
    ]
    str_keys = [
        "flatten_mode", "pp_wavelet_wavelet", "pp_wavelet_mode",
        "threshold_method", "gmm_covariance_type",
        "raw_colormap", "threshold_colormap", "boundary_color",
        "selected_spm_channel",
    ]

    for k in int_keys:
        if k in args:
            setattr(self.params, k, int(args[k]))
    for k in float_keys:
        if k in args:
            setattr(self.params, k, float(args[k]))
    for k in bool_keys:
        if k in args:
            v = args[k]
            setattr(self.params, k, bool(v) if not isinstance(v, bool) else v)
    for k in str_keys:
        if k in args:
            setattr(self.params, k, str(args[k]))

    if "flatten_orders" in args:
        self.params.flatten_orders = [int(x) for x in args["flatten_orders"]]
    if "pp_order" in args:
        self.params.pp_order = [str(x).lower() for x in args["pp_order"]]
    if "manual_thresholds" in args:
        self.params.manual_thresholds = [float(x) for x in args["manual_thresholds"]]
