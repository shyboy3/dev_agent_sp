        self.figure.tight_layout()
        self.canvas.draw()

    def suggest_thresholds(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            messagebox.showerror("Threshold Error", "Threshold count must be an integer.")
            return

        if self.auto_count_var.get():
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        method = self.auto_method_var.get()
        if method == "equal_interval":
            ts = auto_thresholds_equal_interval(self.current_data, n_thresh)
        else:
            ts = auto_thresholds_quantile(self.current_data, n_thresh)

        self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))

    def _parse_thresholds(self) -> List[float]:
        if self.current_data is None:
            raise ValueError("No data loaded.")

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            raise ValueError("Threshold count must be an integer.")

        if n_thresh < 1:
            raise ValueError("Threshold count must be >= 1.")

        if self.auto_count_var.get():
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        if self.auto_values_var.get():
            method = self.auto_method_var.get()
            if method == "equal_interval":
                ts = auto_thresholds_equal_interval(self.current_data, n_thresh)
            else:
                ts = auto_thresholds_quantile(self.current_data, n_thresh)
            self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))
            return ts

        raw = self.threshold_values_var.get().strip()
        if not raw:
            raise ValueError("Please enter threshold values or enable auto threshold values.")

        try:
            ts = [float(x.strip()) for x in raw.split(",") if x.strip() != ""]
        except ValueError:
            raise ValueError("Threshold values must be numeric and comma-separated.")

        if len(ts) != n_thresh:
            raise ValueError(f"Threshold count is {n_thresh}, but {len(ts)} values were provided.")

        return sorted(ts)

    def apply_threshold(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            thresholds = self._parse_thresholds()
        except Exception as e:
            messagebox.showerror("Threshold Error", str(e))
            return

        self.region_map = build_region_map(self.current_data, thresholds)
        masks, ranges = multi_threshold_masks(self.current_data, thresholds)
        total = self.current_data.size

        lines: List[str] = []
        lines.append("[Threshold Summary]")
        lines.append(f"Thresholds: {', '.join(f'{t:.6g}' for t in thresholds)}")
        lines.append("")

        for idx, (mask, rg) in enumerate(zip(masks, ranges)):
            count = int(mask.sum())
            pct = 100.0 * count / total if total > 0 else 0.0

            lo, hi = rg
            lo_s = "-inf" if np.isneginf(lo) else f"{lo:.6g}"
            hi_s = "+inf" if np.isposinf(hi) else f"{hi:.6g}"
            label = f"Region {idx}: [{lo_s}, {hi_s})" if not np.isposinf(hi) else f"Region {idx}: [{lo_s}, {hi_s}]"
            lines.append(f"{label}")
            lines.append(f"  Pixels: {count}")
            lines.append(f"  Percent: {pct:.3f}%")

        self.region_summary = lines
        self.update_info_panel()
        self.refresh_display()

    def update_info_panel(self):
        self.info_text.delete("1.0", tk.END)

        if self.filepath:
            self.info_text.insert(tk.END, f"File: {self.filepath}\n\n")

        if self.raw_data is not None:
            self.info_text.insert(tk.END, "[Image Info]\n")
            self.info_text.insert(tk.END, f"Raw shape: {self.raw_data.shape}\n")
        if self.current_data is not None:
            self.info_text.insert(tk.END, f"Current shape: {self.current_data.shape}\n")
            self.info_text.insert(tk.END, f"Min: {np.nanmin(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Max: {np.nanmax(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Mean: {np.nanmean(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Std: {np.nanstd(self.current_data):.6g}\n\n")

        if self.metadata:
            self.info_text.insert(tk.END, "[Metadata]\n")
            for k, v in self.metadata.items():
                self.info_text.insert(tk.END, f"{k}: {v}\n")
            self.info_text.insert(tk.END, "\n")

        if self.region_summary:
            self.info_text.insert(tk.END, "\n".join(self.region_summary))

    def save_current_plot(self, kind: str):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        filepath = filedialog.asksaveasfilename(
            title="Save image",
            defaultextension=".png",
            filetypes=[("PNG files", "*.png"), ("TIFF files", "*.tif"), ("JPEG files", "*.jpg")],
        )
        if not filepath:
            return

        try:
            fig = Figure(figsize=(6, 5), dpi=150)
            ax = fig.add_subplot(111)

            if kind == "raw":
                cmap_name = self.cmap_var.get()
                vmin, vmax = self.get_display_limits()
                im = ax.imshow(self.current_data, cmap=cmap_name, origin="upper", aspect="equal", vmin=vmin, vmax=vmax, interpolation="nearest")
                fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
                ax.set_title("Raw / Cropped Image")
            else:
                if self.region_map is None:
                    messagebox.showwarning("No threshold result", "Apply threshold first.")
                    return
                n_regions = int(np.nanmax(self.region_map)) + 1
                cmap_thr = cm.get_cmap("tab20", n_regions)
                bounds = np.arange(-0.5, n_regions + 0.5, 1)
                norm = BoundaryNorm(bounds, cmap_thr.N)
                im = ax.imshow(self.region_map, cmap=self.threshold_cmap_var.get(), origin="upper", aspect="equal", interpolation="nearest")
                fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
                ax.set_title("Threshold Regions")

            ax.set_xlabel("X")
            ax.set_ylabel("Y")
            fig.tight_layout()
            fig.savefig(filepath, bbox_inches="tight")
            messagebox.showinfo("Saved", f"Saved image to:\n{filepath}")
        except Exception as e:
            messagebox.showerror("Save Error", str(e))

    def save_summary(self):
        if not self.region_summary:
            messagebox.showwarning("No summary", "Apply threshold first.")
            return

        filepath = filedialog.asksaveasfilename(
            title="Save summary",
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")],
        )
        if not filepath:
            return

        try:
            ext = os.path.splitext(filepath)[1].lower()
            if ext == ".csv":
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write("line\n")
                    for line in self.region_summary:
                        f.write('"' + line.replace('"', '""') + '"
')
            else:
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write("\n".join(self.region_summary))
            messagebox.showinfo("Saved", f"Saved summary to:\n{filepath}")
        except Exception as e:
            messagebox.showerror("Save Error", str(e))


