            setattr(self, attr, None)

    def get_cropped_image(self):
        img = self.raw_image
        if img is None:
            return None
        if not self.crop_enable_var.get():
            return img.copy()
        h, w = img.shape
        x = max(0, int(self.crop_x_var.get()))
        y = max(0, int(self.crop_y_var.get()))
        cw = max(1, int(self.crop_w_var.get()))
        ch = max(1, int(self.crop_h_var.get()))
        x = min(x, max(0, w - 1))
        y = min(y, max(0, h - 1))
        x2 = min(w, x + cw)
        y2 = min(h, y + ch)
        if x >= x2 or y >= y2:
            raise ValueError("Invalid crop range")
        return img[y:y2, x:x2].copy()


    def _selected_flatten_orders(self):
        return [order for order, var in enumerate(self.flatten_order_vars) if var.get()]

    def _fit_polynomial_surface(self, image, order):
        if order < 0:
            raise ValueError("Flattening order must be >= 0.")
        y_idx, x_idx = np.indices(image.shape, dtype=np.float64)
        x = x_idx.ravel()
        y = y_idx.ravel()
        z = image.astype(np.float64).ravel()
        finite = np.isfinite(z)
        x = x[finite]
        y = y[finite]
        z = z[finite]
        if z.size == 0:
            raise ValueError("Flattening failed: no finite pixels in image.")
        x0 = x.mean()
        y0 = y.mean()
        sx = max(np.abs(x - x0).max(), 1.0)
        sy = max(np.abs(y - y0).max(), 1.0)
        xn = (x - x0) / sx
        yn = (y - y0) / sy

        terms = []
        powers = []
        for total_degree in range(order + 1):
            for i in range(total_degree + 1):
                j = total_degree - i
                powers.append((i, j))
                terms.append((xn ** i) * (yn ** j))
        A = np.vstack(terms).T
        coeffs, *_ = np.linalg.lstsq(A, z, rcond=None)

        full_y, full_x = np.indices(image.shape, dtype=np.float64)
        full_xn = (full_x - x0) / sx
        full_yn = (full_y - y0) / sy
        surface = np.zeros_like(image, dtype=np.float64)
        for c, (i, j) in zip(coeffs, powers):
            surface += c * (full_xn ** i) * (full_yn ** j)
        return surface

    def _apply_single_flatten_order(self, image, order):
        surface = self._fit_polynomial_surface(image, order)
        baseline = float(np.nanmean(surface))
        return (image.astype(np.float64) - surface + baseline).astype(np.float32)

    def apply_flattening(self, image):
        out = image.astype(np.float32).copy()
        orders = self._selected_flatten_orders()
        if not orders:
            return out
        for order in sorted(set(orders)):
            out = self._apply_single_flatten_order(out, order)
        return out

    def apply_preprocessing(self, image):
        out = image.astype(np.float32).copy()
        raw_order = self.pp_order_var.get().strip()
        order = [x.strip().lower() for x in raw_order.split('>')] if raw_order else ["median", "gaussian", "tv", "wavelet"]
        aliases = {
            "median": "median",
            "gaussian": "gaussian",
            "total variation": "tv",
            "tv": "tv",
            "wavelet": "wavelet",
            "wavelet denoising": "wavelet",
        }
        for name in order:
            method = aliases.get(name.lower())
            if method == "median" and self.pp_median_var.get():
                ksize = max(1, int(self.pp_median_size_var.get()))
                if ksize % 2 == 0:
                    ksize += 1
                out = ndi.median_filter(out, size=ksize)
            elif method == "gaussian" and self.pp_gaussian_var.get():
                sigma = max(0.0, float(self.pp_gaussian_sigma_var.get()))
                out = gaussian(out, sigma=sigma, preserve_range=self.pp_gaussian_preserve_range_var.get()).astype(np.float32)
            elif method == "tv" and self.pp_tv_var.get():
                weight = max(1e-8, float(self.pp_tv_weight_var.get()))
                eps = max(1e-12, float(self.pp_tv_eps_var.get()))
                n_iter = max(1, int(self.pp_tv_max_num_iter_var.get()))
                out = denoise_tv_chambolle(out, weight=weight, eps=eps, max_num_iter=n_iter).astype(np.float32)
            elif method == "wavelet" and self.pp_wavelet_var.get():
                sigma = max(0.0, float(self.pp_wavelet_sigma_var.get()))
                wavelet_name = self.pp_wavelet_wavelet_var.get().strip() or "db2"
                mode_name = self.pp_wavelet_mode_var.get().strip() or "soft"
                out = denoise_wavelet(out, sigma=sigma, wavelet=wavelet_name, mode=mode_name, rescale_sigma=self.pp_wavelet_rescale_sigma_var.get(), channel_axis=None).astype(np.float32)
        return out

    def _parse_manual_thresholds(self):
        text = self.manual_thresholds_var.get().strip()
        if not text:
            return []
        parts = [p.strip() for p in text.replace(';', ',').split(',') if p.strip()]
        return sorted(float(p) for p in parts)

    def suggest_thresholds(self):
        if self.raw_image is None:
            messagebox.showinfo("Info", "Load an image first.")
            return
        try:
            img = self.get_cropped_image()
            img = self.apply_flattening(img)
            img = self.apply_preprocessing(img)
            thr = self.compute_auto_threshold_values(img)
            self.manual_thresholds_var.set(", ".join(f"{x:.6g}" for x in thr))
            self.status_var.set("Suggested thresholds updated in manual input field")
        except Exception as e:
            messagebox.showerror("Suggestion Error", str(e))

    def compute_auto_threshold_values(self, image):
        data = image.astype(np.float32)
        flat = data.reshape(-1, 1)
        count = max(1, int(self.threshold_count_var.get()))
        groups = count + 1
        method = self.threshold_method_var.get().strip().lower()

        if method == "otsu":
            return [float(threshold_otsu(data))]
        if method == "multi-otsu":
            return [float(x) for x in threshold_multiotsu(data, classes=groups)]
        if method == "k-means":
            km = KMeans(n_clusters=groups, random_state=int(self.kmeans_random_state_var.get()), n_init=max(1, int(self.kmeans_n_init_var.get())))
            km.fit(flat)
            centers = np.sort(km.cluster_centers_.flatten())
            return self._centers_to_thresholds(centers)
        if method == "gmm":
            gm = GaussianMixture(n_components=groups, covariance_type=self.gmm_covariance_type_var.get(), random_state=int(self.gmm_random_state_var.get()))
            gm.fit(flat)
            means = np.sort(gm.means_.flatten())
            return self._centers_to_thresholds(means)
        if method == "equal interval":
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            if p_high <= p_low:
                raise ValueError("Equal Interval: High percentile must be greater than low percentile.")
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            return [float(x) for x in np.linspace(low, high, groups + 1)[1:-1]]
        raise ValueError(f"Unknown threshold method: {self.threshold_method_var.get()}")

    def compute_threshold_labels(self, image):
        data = image.astype(np.float32)
        count = max(1, int(self.threshold_count_var.get()))
        if self.use_manual_thresholds_var.get():
            thr = self._parse_manual_thresholds()
            if not thr:
                raise ValueError("Manual thresholds are enabled, but no values were entered.")
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        thr = self.compute_auto_threshold_values(data)
        if self.threshold_method_var.get().strip().lower() == "otsu":
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        if len(thr) != count:
            raise ValueError(f"Threshold count mismatch: expected {count}, got {len(thr)}")
        labels = np.digitize(data, bins=thr).astype(np.int32)
        if self.threshold_method_var.get().strip().lower() == "equal interval":
            groups = len(thr) + 1
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            labels[data < low] = 0
            labels[data >= high] = groups - 1
        return labels, thr

    def _centers_to_thresholds(self, centers_sorted):
        centers_sorted = np.asarray(centers_sorted, dtype=np.float32)
        if centers_sorted.size <= 1:
            return []
        mids = 0.5 * (centers_sorted[:-1] + centers_sorted[1:])
        return [float(x) for x in mids]

    def replace_small_regions_with_neighbors(self, label_img, max_region_size):
        out = label_img.copy()
        structure = np.ones((3, 3), dtype=np.uint8)
        unique_vals = np.unique(out)
        for val in unique_vals:
            mask = out == val
            cc, n_cc = ndi.label(mask, structure=structure)
            for idx in range(1, n_cc + 1):
                region_mask = cc == idx
                area = int(region_mask.sum())
                if area <= max_region_size:
                    dilated = ndi.binary_dilation(region_mask, structure=structure)
                    border = dilated & (~region_mask)
                    neighbor_vals = out[border]
                    neighbor_vals = neighbor_vals[neighbor_vals != val]
                    if neighbor_vals.size == 0:
                        continue
                    replacement = mode(neighbor_vals, keepdims=False).mode
                    out[region_mask] = int(replacement)
        return out.astype(np.int32)

    def compute_group_percentages(self, label_img):
        if label_img is None:
            return []
        labels = label_img.ravel().astype(np.int32)
        groups = int(labels.max()) + 1 if labels.size else 0
        counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
        total = max(1, int(counts.sum()))
        return [100.0 * c / total for c in counts]

    # Rendering
    def update_image_panels(self):
        self.draw_raw_image_panel()
        self.draw_threshold_image_panel()

    def _get_raw_vmin_vmax(self, image):
        vmin = float(np.min(image))
        vmax = float(np.max(image))
        if self.raw_min_enable_var.get():
            vmin = float(self.raw_vmin_var.get())
        if self.raw_max_enable_var.get():
            vmax = float(self.raw_vmax_var.get())
        if vmax <= vmin:
            raise ValueError("Raw display max must be greater than min.")
        return vmin, vmax

    def draw_raw_image_panel(self):
        self.clear_canvas("raw")
        if self.preprocessed_image is None:
