        for h, l in zip(handles, labels):
            if l not in uniq_l:
                uniq_h.append(h)
                uniq_l.append(l)
        if uniq_l:
            ax.legend(uniq_h, uniq_l, loc='upper left', fontsize=8)
        fig.tight_layout()
        self.last_hist_raw_data = {
            'bin_centers': centers.tolist(),
            'counts': counts.tolist(),
            'mean': mean_val,
            'std': std_val,
            'bins': int(len(centers)),
