        try:
            vmin = self._parse_float_optional(self.vmin_var.get())
            vmax = self._parse_float_optional(self.vmax_var.get())
        except ValueError:
            messagebox.showerror("Display Error", "vmin/vmax must be numeric.")
            return None, None
        return vmin, vmax

