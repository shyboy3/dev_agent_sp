        lines.append(f"TV enabled: {self.pp_tv_var.get()} | weight={self.pp_tv_weight_var.get()} | eps={self.pp_tv_eps_var.get()} | iter={self.pp_tv_max_num_iter_var.get()}")
        lines.append(f"Wavelet enabled: {self.pp_wavelet_var.get()} | sigma={self.pp_wavelet_sigma_var.get()} | wavelet={self.pp_wavelet_wavelet_var.get()} | mode={self.pp_wavelet_mode_var.get()} | rescale_sigma={self.pp_wavelet_rescale_sigma_var.get()}")
