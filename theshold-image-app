        if self.current_afm_metrics:
            lines.append("AFM metrics:")
            for key, value in self.current_afm_metrics.items():
                lines.append(f"  {key}: {self._format_number_with_unit(value) if isinstance(value, (int, float)) and key in ['rms', 'zrange', 'mean', 'min', 'max'] else value}")
        if self.preprocessed_image is not None:
            vals = self.preprocessed_image[np.isfinite(self.preprocessed_image)]
            if vals.size:
                lines.append(f"Processed mean: {self._format_number_with_unit(float(np.mean(vals)))}")
