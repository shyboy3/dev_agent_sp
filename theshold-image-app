    def _parse_int(self, text: str, default: int = 0) -> int:
        text = text.strip()
        if text == "":
            return default
        return int(text)

    def _parse_float_optional(self, text: str) -> Optional[float]:
        text = text.strip()
        if text == "":
            return None
        return float(text)

    def apply_crop(self):
        if self.raw_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return
        try:
            top = self._parse_int(self.top_var.get(), 0)
            bottom = self._parse_int(self.bottom_var.get(), 0)
            left = self._parse_int(self.left_var.get(), 0)
            right = self._parse_int(self.right_var.get(), 0)
        except ValueError:
            messagebox.showerror("Crop Error", "Crop values must be integers.")
            return

        h, w = self.raw_data.shape
        if top < 0 or bottom < 0 or left < 0 or right < 0:
            messagebox.showerror("Crop Error", "Crop values must be >= 0.")
            return
        if top + bottom >= h or left + right >= w:
            messagebox.showerror("Crop Error", "Crop size is too large for current image.")
            return

        self.current_data = self.raw_data[top:h-bottom if bottom > 0 else h,
                                         left:w-right if right > 0 else w].copy()
        self.region_map = None
        self.region_summary = []
        self.update_info_panel()
        self.refresh_display()

    def get_display_limits(self) -> Tuple[Optional[float], Optional[float]]:
        try:
            vmin = self._parse_float_optional(self.vmin_var.get())
            vmax = self._parse_float_optional(self.vmax_var.get())
        except ValueError:
            messagebox.showerror("Display Error", "vmin/vmax must be numeric.")
            return None, None
        return vmin, vmax

    def refresh_display(self):
        if self.current_data is None:
            self._draw_empty()
            return

        cmap_name = self.cmap_var.get()
        vmin, vmax = self.get_display_limits()
        if vmin is None and self.vmin_var.get().strip() != "":
            return
        if vmax is None and self.vmax_var.get().strip() != "":
            return

        self.ax_raw.clear()
        self.ax_raw.set_title("Raw / Cropped Image")
        self.current_im_raw = self.ax_raw.imshow(
            disp,
            cmap=cmap_name,
            origin="upper",
            aspect="equal",
            vmin=vmin,
            vmax=vmax,
            interpolation="nearest",
        )
        self.ax_raw.set_xlabel("X")
        self.ax_raw.set_ylabel("Y")
