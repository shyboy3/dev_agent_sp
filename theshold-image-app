            self.ax_thr.text(0.5, 0.5, "Apply threshold to view result", ha="center", va="center")
        else:
            n_regions = int(np.nanmax(self.region_map)) + 1
            cmap_thr = cm.get_cmap("tab20", n_regions)
            bounds = np.arange(-0.5, n_regions + 0.5, 1)
            norm = BoundaryNorm(bounds, cmap_thr.N)
            self.current_im_thr = self.ax_thr.imshow(
                self.region_map,
                cmap=self.threshold_cmap_var.get(),
                origin="upper",
                aspect="equal",
                interpolation="nearest",
            )
