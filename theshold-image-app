        ]

    def get_parameter_state(self):
        return {name: var.get() for name, var in self._parameter_specs()}

    def apply_parameter_state(self, state):
        applied = 0
        for name, var in self._parameter_specs():
            if name in state:
                try:
                    var.set(state[name])
                    applied += 1
                except Exception:
                    pass
        return applied

    def save_parameters_to_file(self):
        state = self.get_parameter_state()
        default_name = "nanoscope_threshold_params.json"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_params.json"
        path = filedialog.asksaveasfilename(
            defaultextension=".json",
            initialfile=default_name,
            filetypes=[("JSON", "*.json"), ("All files", "*.*")],
        )
        if not path:
            return
        payload = {
            "app": "NanoScope Threshold App",
            "version": 3,
            "parameters": state,
        }
        with open(path, "w", encoding="utf-8") as f:
            json.dump(payload, f, indent=2, ensure_ascii=False)
        self.status_var.set(f"Saved parameter file: {os.path.basename(path)}")

    def load_parameters_from_file(self):
        path = filedialog.askopenfilename(
            title="Load parameter file",
            filetypes=[("JSON", "*.json"), ("All files", "*.*")],
        )
        if not path:
            return
        try:
            with open(path, "r", encoding="utf-8") as f:
                payload = json.load(f)
            state = payload.get("parameters", payload)
            applied = self.apply_parameter_state(state)
            self._refresh_spm_channel_ui_for_current_file()
            self.status_var.set(f"Loaded parameter file: {os.path.basename(path)} | applied={applied}")
            if self.raw_image is not None:
                self.process_all()
        except Exception as e:
            messagebox.showerror("Load Params Error", str(e))

    # Export / Save
    def export_processing_summary(self):
        if self.preprocessed_image is None or self.label_image is None:
            messagebox.showinfo("Info", "No processed result to export.")
            return
        default_name = "processing_summary.txt"
        if self.filepath:
            stem = os.path.splitext(os.path.basename(self.filepath))[0]
            default_name = f"{stem}_processing_summary.txt"
        path = filedialog.asksaveasfilename(defaultextension=".txt", initialfile=default_name, filetypes=[("Text", "*.txt")])
        if not path:
            return

        lines = []
        lines.append("NanoScope Threshold App - Processing Summary")
        lines.append("=" * 48)
        lines.append(f"File: {self.filepath if self.filepath else 'N/A'}")
        lines.append(f"Source info: {self.current_source_info if self.current_source_info else 'N/A'}")
        lines.append(f"AFM backend: {self.current_afm_backend if self.current_afm_backend else 'N/A'}")
        lines.append(f"Selected AFM channel: {self.selected_spm_channel_var.get() if self.selected_spm_channel_var.get() else 'N/A'}")
        lines.append(f"Raw image shape: {None if self.raw_image is None else self.raw_image.shape}")
        lines.append(f"Crop enabled: {self.crop_enable_var.get()}")
        lines.append(f"Crop x, y, w, h: {self.crop_x_var.get()}, {self.crop_y_var.get()}, {self.crop_w_var.get()}, {self.crop_h_var.get()}")
        if self.current_afm_metrics:
            lines.append("AFM metrics:")
            for key, value in self.current_afm_metrics.items():
                lines.append(f"  {key}: {value}")
        lines.append("")

        flatten_orders = self._selected_flatten_orders()
        lines.append("[Flattening]")
        lines.append(f"Mode: {self.flatten_mode_var.get()}")
        lines.append(f"Selected polynomial orders: {flatten_orders if flatten_orders else 'None'}")
        lines.append("")

        lines.append("[Pre-Processing]")
        lines.append(f"Order: {self.pp_order_var.get()}")
        lines.append(f"Median enabled: {self.pp_median_var.get()} | kernel={self.pp_median_size_var.get()}")
        lines.append(f"Gaussian enabled: {self.pp_gaussian_var.get()} | sigma={self.pp_gaussian_sigma_var.get()} | preserve_range={self.pp_gaussian_preserve_range_var.get()}")
        lines.append(f"TV enabled: {self.pp_tv_var.get()} | weight={self.pp_tv_weight_var.get()} | eps={self.pp_tv_eps_var.get()} | iter={self.pp_tv_max_num_iter_var.get()}")
        lines.append(f"Wavelet enabled: {self.pp_wavelet_var.get()} | sigma={self.pp_wavelet_sigma_var.get()} | wavelet={self.pp_wavelet_wavelet_var.get()} | mode={self.pp_wavelet_mode_var.get()} | rescale_sigma={self.pp_wavelet_rescale_sigma_var.get()}")
