“”“Pure processing logic, no tkinter dependencies.”””

```
# ── I/O ──────────────────────────────────

def load_image(self, path: str, channel: str = "") -> ProcessingResult:
    result = ProcessingResult()
    try:
        arr, source_info = self._load_array_from_path(path, channel)
        result.raw_image = self._to_2d_float(arr)
        result.source_info = source_info or ""
    except Exception as e:
        result.error = str(e)
    return result

def _load_array_from_path(self, path: str, channel: str = ""):
    ext = os.path.splitext(path)[1].lower()
    if ext == ".npy":
        return np.load(path), None
    if ext in [".csv", ".txt"]:
        return np.loadtxt(path, delimiter="," if ext == ".csv" else None), None
    if self._is_bruker_candidate(path):
        return self._load_spm_file(path, channel)
    return skio.imread(path), None

def _is_bruker_candidate(self, path: str) -> bool:
    ext = os.path.splitext(path)[1].lower()
    return ext == ".spm" or (len(ext) == 4 and ext[1:].isdigit())

def _load_spm_file(self, path: str, channel: str = ""):
    errors = []
    if HAS_NANOSCOPE:
        try:
            return self._load_bruker_with_nanoscope(path, channel)
        except Exception as e:
            errors.append(f"nanoscope: {e}")
    if HAS_PYSPM:
        try:
            return self._load_bruker_with_pyspm(path, channel)
        except Exception as e:
            errors.append(f"pySPM: {e}")
    if not HAS_NANOSCOPE and not HAS_PYSPM:
        raise ImportError("Loading Bruker AFM files requires nanoscope or pySPM.")
    raise RuntimeError("Failed to load Bruker AFM file. " + " | ".join(errors))

def get_spm_channels(self, path: str) -> list[str]:
    if not self._is_bruker_candidate(path):
        return []
    names = []
    if HAS_NANOSCOPE and NanoscopeImageFile is not None:
        try:
            with NanoscopeImageFile(path) as f:
                names = [str(n) for n in getattr(f, "channels_data_types_desc", [])]
        except Exception:
            pass
    if not names and HAS_PYSPM:
        try:
            bruker = pySPM.Bruker(path)
            names = [str(n) for n in bruker.list_channels()]
        except Exception:
            pass
    return names

def choose_default_channel(self, channel_names: list[str]) -> str | None:
    preferred = [
        "Height Sensor", "Height", "ZSensor", "Z Sensor", "Topography",
        "Height Trace", "Topography Trace",
    ]
    lowered = {str(n).strip().lower(): n for n in channel_names}
    for p in preferred:
        if p.lower() in lowered:
            return lowered[p.lower()]
    for n in channel_names:
        ln = str(n).lower()
        if "height" in ln or "topography" in ln or "z" in ln:
            return n
    return channel_names[0] if channel_names else None

def _load_bruker_with_nanoscope(self, path: str, channel: str = ""):
    with NanoscopeImageFile(path) as f:
        channel_names = [str(n) for n in getattr(f, "channels_data_types_desc", [])]
        if not channel_names:
            raise ValueError("No channels found.")
        chosen = channel if channel in channel_names else self.choose_default_channel(channel_names)
        idx = channel_names.index(str(chosen))
        ch = f[idx]
        data, attr = self._extract_2d_from_channel(ch)
        metrics = {}
        for key in ["rms", "zrange", "mean", "min", "max"]:
            try:
                v = getattr(ch, key)
                if v is not None:
                    metrics[key] = float(v)
            except Exception:
                pass
    source = f"Backend: nanoscope | Channel: {chosen} | Attr: {attr}"
    return np.asarray(data), source

def _load_bruker_with_pyspm(self, path: str, channel: str = ""):
    bruker = pySPM.Bruker(path)
    channel_names = self.get_spm_channels(path)
    chosen = channel if channel in channel_names else self.choose_default_channel(channel_names)
    if not chosen:
        raise ValueError("No readable channel found.")
    image_obj = bruker.get_channel(chosen)
    if image_obj is None:
        raise RuntimeError(f"Failed to read channel '{chosen}'")
    pixels = getattr(image_obj, "pixels", None)
    if pixels is None:
        raise ValueError(f"Channel '{chosen}' has no pixel data.")
    source = f"Backend: pySPM | Channel: {chosen}"
    return np.asarray(pixels), source

def _extract_2d_from_channel(self, ch):
    for name in ["data", "image", "pixels", "map", "values", "raw", "height", "z"]:
        if not hasattr(ch, name):
            continue
        try:
            arr = np.asarray(getattr(ch, name))
            if arr.ndim == 2 and arr.size > 0 and np.issubdtype(arr.dtype, np.number):
                return arr, name
        except Exception:
            pass
    for name, obj in getattr(ch, "__dict__", {}).items():
        try:
            arr = np.asarray(obj)
            if arr.ndim == 2 and arr.size > 0 and np.issubdtype(arr.dtype, np.number):
                return arr, f"__dict__.{name}"
        except Exception:
            pass
    raise ValueError("Cannot find 2D numeric array in channel.")

def _to_2d_float(self, arr: np.ndarray) -> np.ndarray:
    arr = np.asarray(arr)
    if arr.ndim == 2:
        out = arr.astype(np.float32)
    elif arr.ndim == 3:
        if arr.shape[2] in [3, 4]:
            out = np.mean(arr[..., :3].astype(np.float32), axis=2)
        else:
            out = np.mean(arr.astype(np.float32), axis=0)
    else:
        raise ValueError(f"Unsupported array shape: {arr.shape}")
    if not np.isfinite(out).all():
        valid = out[np.isfinite(out)]
        fill = float(valid.mean()) if valid.size else 0.0
        out = np.nan_to_num(out, nan=fill, posinf=fill, neginf=fill)
    return out.astype(np.float32)

# ── Pipeline ──────────────────────────────

def run_pipeline(self, raw_image: np.ndarray, params: ProcessingParams) -> ProcessingResult:
    result = ProcessingResult()
    try:
        result.raw_image = raw_image
        result.cropped_image = self.crop(raw_image, params)
        result.flattened_image = self.flatten(result.cropped_image, params)
        result.preprocessed_image = self.preprocess(result.flattened_image, params)
        result.label_image, result.threshold_values = self.threshold(result.preprocessed_image, params)
        if params.bp_enable:
            result.label_image = self.replace_small_regions(
                result.label_image, params.bp_min_region_size
            )
        result.group_percentages = self.compute_group_percentages(result.label_image)
    except Exception as e:
        result.error = str(e)
    return result

# ── Crop ──────────────────────────────────

def crop(self, image: np.ndarray, params: ProcessingParams) -> np.ndarray:
    if not params.crop_enable:
        return image.copy()
    h, w = image.shape
    x = max(0, min(params.crop_x, w - 1))
    y = max(0, min(params.crop_y, h - 1))
    x2 = min(w, x + max(1, params.crop_w))
    y2 = min(h, y + max(1, params.crop_h))
    if x >= x2 or y >= y2:
        raise ValueError("Invalid crop range")
    return image[y:y2, x:x2].copy()

# ── Flattening ────────────────────────────

def flatten(self, image: np.ndarray, params: ProcessingParams) -> np.ndarray:
    out = image.astype(np.float32).copy()
    if not params.flatten_orders:
        return out
    mode = "line" if params.flatten_mode == "line" else "global"
    for order in sorted(set(params.flatten_orders)):
        out = self._apply_flatten_order(out, order, mode, params)
    return out

def _apply_flatten_order(self, image, order, mode, params):
    img = image.astype(np.float64)
    if mode == "line":
        out = np.empty_like(img)
        for r in range(img.shape[0]):
            if params.flatten_robust:
                surface = self._fit_line_robust(img[r, :], order, params.flatten_robust_k)
            else:
                surface = self._fit_line(img[r, :], order)
            out[r, :] = img[r, :] - surface
        return out.astype(np.float32)
    surface = self._fit_surface(img, order)
    return (img - surface).astype(np.float32)

def _fit_surface(self, image, order):
    if order == 0:
        return np.full_like(image, float(np.nanmean(image)))
    y_idx, x_idx = np.indices(image.shape, dtype=np.float64)
    x, y, z = x_idx.ravel(), y_idx.ravel(), image.ravel()
    finite = np.isfinite(z)
    x, y, z = x[finite], y[finite], z[finite]
    x0, y0 = x.mean(), y.mean()
    sx = max(np.abs(x - x0).max(), 1.0)
    sy = max(np.abs(y - y0).max(), 1.0)
    xn, yn = (x - x0) / sx, (y - y0) / sy
    terms, powers = [], []
    for deg in range(order + 1):
        for i in range(deg + 1):
            j = deg - i
            powers.append((i, j))
            terms.append((xn ** i) * (yn ** j))
    A = np.vstack(terms).T
    coeffs, *_ = np.linalg.lstsq(A, z, rcond=None)
    fy, fx = np.indices(image.shape, dtype=np.float64)
    fxn, fyn = (fx - x0) / sx, (fy - y0) / sy
    surface = np.zeros_like(image, dtype=np.float64)
    for c, (i, j) in zip(coeffs, powers):
        surface += c * (fxn ** i) * (fyn ** j)
    return surface

def _fit_line(self, line, order):
    line = np.asarray(line, dtype=np.float64)
    if order == 0:
        return np.full_like(line, float(np.nanmean(line)))
    finite = np.isfinite(line)
    if not np.any(finite):
        return np.full_like(line, np.nan)
    x = np.arange(line.size, dtype=np.float64)
    x_v, z_v = x[finite], line[finite]
    x0, sx = x_v.mean(), max(np.abs(x_v - x_v.mean()).max(), 1.0)
    coeffs = np.polyfit((x_v - x0) / sx, z_v, deg=min(order, x_v.size - 1))
    return np.polyval(coeffs, (x - x0) / sx)

def _fit_line_robust(self, line, order, k=3.5):
    baseline = self._fit_line(line, order)
    finite = np.isfinite(line) & np.isfinite(baseline)
    if not np.any(finite):
        return baseline
    resid = line[finite] - baseline[finite]
    med = float(np.median(resid))
    mad = float(np.median(np.abs(resid - med)))
    if not np.isfinite(mad) or mad <= 0:
        return baseline
    sigma = 1.4826 * mad
    keep = np.abs(resid - med) <= k * sigma
    if keep.sum() < max(2, order + 1):
        return baseline
    x = np.arange(line.size, dtype=np.float64)
    x_v = x[finite][keep]
    z_v = line[finite][keep]
    x0, sx = x_v.mean(), max(np.abs(x_v - x_v.mean()).max(), 1.0)
    coeffs = np.polyfit((x_v - x0) / sx, z_v, deg=min(order, x_v.size - 1))
    return np.polyval(coeffs, (x - x0) / sx)

# ── Pre-Processing ────────────────────────

def preprocess(self, image: np.ndarray, params: ProcessingParams) -> np.ndarray:
    out = image.astype(np.float32).copy()
    aliases = {
        "median": "median", "gaussian": "gaussian",
        "total variation": "tv", "tv": "tv",
        "wavelet": "wavelet", "wavelet denoising": "wavelet",
    }
    for name in params.pp_order:
        method = aliases.get(name.lower())
        if method == "median" and params.pp_median_enable:
            ksize = params.pp_median_size
            if ksize % 2 == 0:
                ksize += 1
            out = ndi.median_filter(out, size=ksize)
        elif method == "gaussian" and params.pp_gaussian_enable:
            out = gaussian(out, sigma=params.pp_gaussian_sigma,
                           preserve_range=params.pp_gaussian_preserve_range).astype(np.float32)
        elif method == "tv" and params.pp_tv_enable:
            out = denoise_tv_chambolle(out, weight=max(1e-8, params.pp_tv_weight),
                                       eps=max(1e-12, params.pp_tv_eps),
                                       max_num_iter=max(1, params.pp_tv_max_num_iter)).astype(np.float32)
        elif method == "wavelet" and params.pp_wavelet_enable:
            out = denoise_wavelet(out, sigma=params.pp_wavelet_sigma,
                                  wavelet=params.pp_wavelet_wavelet,
                                  mode=params.pp_wavelet_mode,
                                  rescale_sigma=params.pp_wavelet_rescale_sigma,
                                  channel_axis=None).astype(np.float32)
    return out

# ── Threshold ─────────────────────────────

def threshold(self, image: np.ndarray, params: ProcessingParams):
    data = image.astype(np.float32)
    count = max(1, params.threshold_count)
    groups = count + 1

    if params.use_manual_thresholds and params.manual_thresholds:
        thr = sorted(params.manual_thresholds)
        labels = np.digitize(data, bins=thr).astype(np.int32)
        return labels, thr

    method = params.threshold_method.strip().lower()
    if method == "otsu":
        thr = [float(threshold_otsu(data))]
    elif method == "multi-otsu":
        thr = [float(x) for x in threshold_multiotsu(data, classes=groups)]
    elif method == "k-means":
        flat = data.reshape(-1, 1)
        km = KMeans(n_clusters=groups,
                    random_state=params.kmeans_random_state,
                    n_init=params.kmeans_n_init)
        km.fit(flat)
        centers = np.sort(km.cluster_centers_.flatten())
        thr = self._centers_to_thresholds(centers)
    elif method == "gmm":
        flat = data.reshape(-1, 1)
        gm = GaussianMixture(n_components=groups,
                             covariance_type=params.gmm_covariance_type,
                             random_state=params.gmm_random_state)
        gm.fit(flat)
        means = np.sort(gm.means_.flatten())
        thr = self._centers_to_thresholds(means)
    elif method == "equal interval":
        low = float(np.percentile(data, params.equal_interval_percentile_low))
        high = float(np.percentile(data, params.equal_interval_percentile_high))
        thr = [float(x) for x in np.linspace(low, high, groups + 1)[1:-1]]
    else:
        raise ValueError(f"Unknown threshold method: {params.threshold_method}")

    labels = np.digitize(data, bins=thr).astype(np.int32)
    return labels, thr

def _centers_to_thresholds(self, centers):
    centers = np.asarray(centers, dtype=np.float32)
    if centers.size <= 1:
        return []
    return [float(x) for x in 0.5 * (centers[:-1] + centers[1:])]

# ── Binary Processing ─────────────────────

def replace_small_regions(self, label_img: np.ndarray, max_size: int) -> np.ndarray:
    out = label_img.copy()
    structure = np.ones((3, 3), dtype=np.uint8)
    for val in np.unique(out):
        mask = out == val
        cc, n_cc = ndi.label(mask, structure=structure)
        for idx in range(1, n_cc + 1):
            region = cc == idx
            if int(region.sum()) <= max_size:
                dilated = ndi.binary_dilation(region, structure=structure)
                border = dilated & (~region)
                neighbors = out[border]
                neighbors = neighbors[neighbors != val]
                if neighbors.size == 0:
                    continue
                replacement = mode(neighbors, keepdims=False).mode
                out[region] = int(replacement)
    return out.astype(np.int32)

# ── Stats ─────────────────────────────────

def compute_group_percentages(self, label_img: np.ndarray) -> list[float]:
    if label_img is None:
        return []
    labels = label_img.ravel().astype(np.int32)
    groups = int(labels.max()) + 1 if labels.size else 0
    counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
    total = max(1, int(counts.sum()))
    return [100.0 * c / total for c in counts]

def suggest_thresholds(self, image: np.ndarray, params: ProcessingParams) -> list[float]:
    """Run pipeline up to threshold stage and return suggested threshold values."""
    cropped = self.crop(image, params)
    flattened = self.flatten(cropped, params)
    preprocessed = self.preprocess(flattened, params)
    _, thr = self.threshold(preprocessed, params)
    return thr
```

