        xs = np.arange(groups)
        colors = self._get_threshold_hist_colors(groups)
        bars = ax.bar(xs, counts, width=0.85, color=colors)
        total = max(1, int(counts.sum()))
        ymax = counts.max() if counts.size else 1
        ax.set_ylim(0, ymax * 1.18 + 1)
        ax.set_xticks(xs)
        ax.set_title("Threshold Histogram")
        ax.set_xlabel("Threshold Group Label")
        ax.set_ylabel("Count")

        self.group_percentages = [100.0 * c / total for c in counts]
        for bar, pct, c in zip(bars, self.group_percentages, counts):
            ax.text(bar.get_x() + bar.get_width() / 2.0, bar.get_height() + max(1, ymax * 0.02), f"{pct:.1f}%", ha='center', va='bottom', fontsize=9)
        fig.tight_layout()
