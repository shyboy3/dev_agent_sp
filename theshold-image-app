        size = max(200, int(self.display_size_var.get()))
        fig = Figure(figsize=(size / 100.0, size / 100.0), dpi=100)
        ax = fig.add_subplot(111)
        vmin, vmax = self._get_raw_vmin_vmax(self.preprocessed_image)
        im = ax.imshow(self.preprocessed_image, cmap=self.raw_colormap_var.get(), vmin=vmin, vmax=vmax, interpolation="nearest")
        ax.set_title("Flattened / Preprocessed")
        ax.set_xticks([])
        ax.set_yticks([])
        fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
