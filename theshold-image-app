    def _draw_empty(self):
        if self.cbar_raw is not None:
            try:
                self.cbar_raw.remove()
            except Exception:
                pass
            self.cbar_raw = None
        if self.cbar_thr is not None:
            try:
                self.cbar_thr.remove()
            except Exception:
                pass
            self.cbar_thr = None
        self.ax_raw.clear()
        self.ax_thr.clear()
        self.ax_raw_hist.clear()
        self.ax_thr_hist.clear()
        self.ax_raw.set_title("Raw / Cropped Image")
        self.ax_thr.set_title("Threshold Regions")
        self.ax_raw_hist.set_title("Raw Histogram")
        self.ax_thr_hist.set_title("Threshold Histogram")
