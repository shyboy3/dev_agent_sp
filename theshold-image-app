        lines.append(f"Wavelet enabled: {self.pp_wavelet_var.get()} | sigma={self.pp_wavelet_sigma_var.get()} | wavelet={self.pp_wavelet_wavelet_var.get()} | mode={self.pp_wavelet_mode_var.get()} | rescale_sigma={self.pp_wavelet_rescale_sigma_var.get()}")
        lines.append("")

        lines.append("[Threshold]")
        lines.append(f"Method: {self.threshold_method_var.get()}")
        lines.append(f"Threshold Count: {self.threshold_count_var.get()}")
        lines.append(f"Use Manual Thresholds: {self.use_manual_thresholds_var.get()}")
        lines.append(f"Manual Values: {self.manual_thresholds_var.get()}")
        lines.append(f"Resolved Threshold Values: {', '.join(f'{x:.8g}' for x in self.threshold_values)}")
        lines.append(f"K-means random_state={self.kmeans_random_state_var.get()}, n_init={self.kmeans_n_init_var.get()}")
        lines.append(f"GMM random_state={self.gmm_random_state_var.get()}, covariance_type={self.gmm_covariance_type_var.get()}")
        lines.append(f"Equal interval low%={self.equal_interval_percentile_low_var.get()}, high%={self.equal_interval_percentile_high_var.get()}")
        lines.append("")

        lines.append("[Binary Processing]")
        lines.append(f"Enabled: {self.bp_enable_var.get()}")
        lines.append(f"P: {self.bp_min_region_size_var.get()}")
        lines.append("")

        lines.append("[Display]")
        lines.append(f"Raw colormap: {self.raw_colormap_var.get()}")
        lines.append(f"Threshold colormap: {self.threshold_colormap_var.get()}")
        lines.append(f"Raw min enabled: {self.raw_min_enable_var.get()} | value={self.raw_vmin_var.get()}")
        lines.append(f"Raw max enabled: {self.raw_max_enable_var.get()} | value={self.raw_vmax_var.get()}")
        lines.append(f"Show boundaries: {self.show_boundaries_var.get()} | color={self.boundary_color_var.get()} | contour thickness={self.boundary_thickness_var.get()}")
        lines.append("")

        lines.append("[Threshold Group Percentages]")
        for i, pct in enumerate(self.group_percentages):
            lines.append(f"Group {i}: {pct:.4f}%")

        with open(path, 'w', encoding='utf-8') as f:
            f.write("\n".join(lines))
        self.status_var.set(f"Exported summary: {os.path.basename(path)}")

