# ------------------------------------------------------------
# Data loading
# ------------------------------------------------------------

def load_nanoscope_txt(filepath: str) -> Tuple[np.ndarray, Dict[str, str]]:
    """
    Load NanoScope numerical data exported as txt.

    Expected format:
    - metadata lines begin with '#'
    - numerical data are whitespace-separated rows
    """
    metadata: Dict[str, str] = {}
    numeric_rows: List[List[float]] = []

    with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
        for line in f:
            s = line.strip()
            if not s:
                continue
            if s.startswith("#"):
                line2 = s.lstrip("#").strip()
                if ":" in line2:
                    k, v = line2.split(":", 1)
                    metadata[k.strip()] = v.strip()
                else:
                    metadata[f"meta_{len(metadata)+1}"] = line2
                continue

            parts = re.split(r"\s+", s)
            try:
                row = [float(x) for x in parts if x != ""]
            except ValueError:
                # Skip malformed lines that are neither valid metadata nor numeric rows
                continue

            if row:
                numeric_rows.append(row)

    if not numeric_rows:
        raise ValueError("No numerical data found in the TXT file.")

    widths = {len(r) for r in numeric_rows}
    if len(widths) != 1:
        raise ValueError("Inconsistent row lengths found in numerical data.")

    arr = np.array(numeric_rows, dtype=float)
    return arr, metadata


# ------------------------------------------------------------
# Threshold analysis
# ------------------------------------------------------------

def multi_threshold_masks(data: np.ndarray, thresholds: List[float]) -> Tuple[List[np.ndarray], List[Tuple[float, float]]]:
    """
    Convert K thresholds into K+1 regions.
    Region ranges:
      (-inf, t1), [t1, t2), ..., [tK, +inf)
    """
    ts = sorted(thresholds)
    masks: List[np.ndarray] = []
    ranges: List[Tuple[float, float]] = []

    prev = -np.inf
    for t in ts:
        mask = (data >= prev) & (data < t)
        masks.append(mask)
        ranges.append((prev, t))
        prev = t

    mask = data >= prev
    masks.append(mask)
    ranges.append((prev, np.inf))
    return masks, ranges


def auto_thresholds_equal_interval(data: np.ndarray, n_thresh: int) -> List[float]:
    dmin = float(np.nanmin(data))
    dmax = float(np.nanmax(data))
    if n_thresh <= 0:
        return []
    return np.linspace(dmin, dmax, n_thresh + 2)[1:-1].tolist()


def auto_thresholds_quantile(data: np.ndarray, n_thresh: int) -> List[float]:
    if n_thresh <= 0:
        return []
    qs = np.linspace(0, 1, n_thresh + 2)[1:-1]
    return np.quantile(data.ravel(), qs).tolist()


def auto_threshold_count_by_unique(data: np.ndarray, max_thresholds: int = 10) -> int:
    """
    Heuristic:
    - if unique count is small, use unique_count-1
    - otherwise use sqrt-based capped count
    """
    flat = data.ravel()
    unique_count = len(np.unique(np.round(flat, decimals=8)))
    if unique_count <= 1:
        return 1
    if unique_count <= max_thresholds + 1:
        return max(1, unique_count - 1)
    n = int(np.clip(np.sqrt(unique_count) / 2, 2, max_thresholds))
    return n


def build_region_map(data: np.ndarray, thresholds: List[float]) -> np.ndarray:
    ts = np.array(sorted(thresholds), dtype=float)
    return np.digitize(data, bins=ts, right=False)


# ------------------------------------------------------------
# GUI
# ------------------------------------------------------------

@dataclass
class CropBox:
    top: int = 0
    bottom: int = 0
    left: int = 0
    right: int = 0


class ThresholdApp:
    def __init__(self, root: tk.Tk):
        self.root = root
        self.root.title("NanoScope Threshold Analysis App")
        self.root.geometry("1500x920")

        self.raw_data: Optional[np.ndarray] = None
        self.current_data: Optional[np.ndarray] = None
        self.metadata: Dict[str, str] = {}
        self.filepath: Optional[str] = None

        self.figure = Figure(figsize=(10, 5.5), dpi=100, facecolor="white")
        self.ax_raw = self.figure.add_subplot(1, 2, 1)
        self.ax_thr = self.figure.add_subplot(1, 2, 2)
        self.ax_raw.set_facecolor("white")
        self.ax_thr.set_facecolor("white")
        self.canvas = None

        self.cmap_names = sorted(m for m in plt.colormaps() if not m.endswith("_r"))
        self.current_im_raw = None
        self.current_im_thr = None
        self.region_map: Optional[np.ndarray] = None
        self.region_summary: List[str] = []

        self._build_ui()
        self._draw_empty()

    def _build_ui(self):
        main = ttk.Frame(self.root, padding=8)
        main.pack(fill="both", expand=True)

        left = ttk.Frame(main)
        left.pack(side="left", fill="y")

        right = ttk.Frame(main)
        right.pack(side="right", fill="both", expand=True)

        # File section
        file_frame = ttk.LabelFrame(left, text="File", padding=8)
        file_frame.pack(fill="x", pady=4)
        ttk.Button(file_frame, text="Open TXT", command=self.open_file).pack(fill="x", pady=2)
        ttk.Button(file_frame, text="Reset to Raw", command=self.reset_to_raw).pack(fill="x", pady=2)
        ttk.Button(file_frame, text="Save Raw Image", command=lambda: self.save_current_plot("raw")).pack(fill="x", pady=2)
        ttk.Button(file_frame, text="Save Threshold Image", command=lambda: self.save_current_plot("threshold")).pack(fill="x", pady=2)
        ttk.Button(file_frame, text="Save Region Summary", command=self.save_summary).pack(fill="x", pady=2)

        # Crop section
        crop_frame = ttk.LabelFrame(left, text="Crop", padding=8)
        crop_frame.pack(fill="x", pady=4)

        self.top_var = tk.StringVar(value="0")
        self.bottom_var = tk.StringVar(value="0")
        self.left_var = tk.StringVar(value="0")
        self.right_var = tk.StringVar(value="0")

        for label, var in [
            ("Top", self.top_var),
            ("Bottom", self.bottom_var),
            ("Left", self.left_var),
            ("Right", self.right_var),
        ]:
            row = ttk.Frame(crop_frame)
            row.pack(fill="x", pady=1)
            ttk.Label(row, text=label, width=8).pack(side="left")
            ttk.Entry(row, textvariable=var, width=12).pack(side="left", fill="x", expand=True)

        ttk.Button(crop_frame, text="Apply Crop", command=self.apply_crop).pack(fill="x", pady=3)

        # Display section
        display_frame = ttk.LabelFrame(left, text="Display", padding=8)
        display_frame.pack(fill="x", pady=4)

        self.cmap_var = tk.StringVar(value="viridis")
        self.vmin_var = tk.StringVar(value="")
        self.vmax_var = tk.StringVar(value="")

        row = ttk.Frame(display_frame)
        row.pack(fill="x", pady=2)
        ttk.Label(row, text="Colormap", width=12).pack(side="left")
        cmap_box = ttk.Combobox(row, textvariable=self.cmap_var, values=self.cmap_names, state="readonly", width=22)
        cmap_box.pack(side="left", fill="x", expand=True)
        cmap_box.bind("<<ComboboxSelected>>", lambda e: self.refresh_display())

        row = ttk.Frame(display_frame)
        row.pack(fill="x", pady=2)
        ttk.Label(row, text="vmin", width=12).pack(side="left")
        ttk.Entry(row, textvariable=self.vmin_var, width=12).pack(side="left", fill="x", expand=True)

        row = ttk.Frame(display_frame)
        row.pack(fill="x", pady=2)
        ttk.Label(row, text="vmax", width=12).pack(side="left")
        ttk.Entry(row, textvariable=self.vmax_var, width=12).pack(side="left", fill="x", expand=True)

        ttk.Button(display_frame, text="Apply Display", command=self.refresh_display).pack(fill="x", pady=3)

        # Threshold section
        thr_frame = ttk.LabelFrame(left, text="Threshold", padding=8)
        thr_frame.pack(fill="x", pady=4)

        self.n_thresh_var = tk.StringVar(value="2")
        self.threshold_values_var = tk.StringVar(value="")
        self.auto_count_var = tk.BooleanVar(value=False)
        self.auto_values_var = tk.BooleanVar(value=False)
        self.auto_method_var = tk.StringVar(value="quantile")

        row = ttk.Frame(thr_frame)
        row.pack(fill="x", pady=2)
        ttk.Label(row, text="Threshold count", width=14).pack(side="left")
        ttk.Entry(row, textvariable=self.n_thresh_var, width=10).pack(side="left")

        ttk.Checkbutton(thr_frame, text="Auto threshold count", variable=self.auto_count_var).pack(anchor="w")
        ttk.Checkbutton(thr_frame, text="Auto threshold values", variable=self.auto_values_var).pack(anchor="w")

        row = ttk.Frame(thr_frame)
        row.pack(fill="x", pady=2)
        ttk.Label(row, text="Auto method", width=14).pack(side="left")
        method_box = ttk.Combobox(row, textvariable=self.auto_method_var, values=["quantile", "equal_interval"], state="readonly", width=16)
        method_box.pack(side="left", fill="x", expand=True)

        ttk.Label(thr_frame, text="Manual threshold values (comma-separated)").pack(anchor="w", pady=(6, 0))
        ttk.Entry(thr_frame, textvariable=self.threshold_values_var).pack(fill="x", pady=2)

        btns = ttk.Frame(thr_frame)
        btns.pack(fill="x", pady=4)
        ttk.Button(btns, text="Suggest Thresholds", command=self.suggest_thresholds).pack(side="left", fill="x", expand=True, padx=1)
        ttk.Button(btns, text="Apply Threshold", command=self.apply_threshold).pack(side="left", fill="x", expand=True, padx=1)

        # Metadata / summary section
        info_frame = ttk.LabelFrame(left, text="Metadata / Region Summary", padding=8)
        info_frame.pack(fill="both", expand=True, pady=4)

        self.info_text = tk.Text(info_frame, height=20, wrap="word")
        self.info_text.pack(fill="both", expand=True)

        # Plot area
        plot_frame = ttk.Frame(right)
        plot_frame.pack(fill="both", expand=True)

        self.canvas = FigureCanvasTkAgg(self.figure, master=plot_frame)
        canvas_widget = self.canvas.get_tk_widget()
        canvas_widget.pack(fill="both", expand=True)
        canvas_widget.configure(bg="white")
        self.canvas.draw()

    def _draw_empty(self):
        self.ax_raw.clear()
        self.ax_thr.clear()
        self.ax_raw.set_title("Raw / Cropped Image")
        self.ax_thr.set_title("Threshold Regions")
        self.ax_raw.text(0.5, 0.5, "No data loaded", ha="center", va="center")
        self.ax_thr.text(0.5, 0.5, "No threshold result", ha="center", va="center")
        self.canvas.draw()

    def open_file(self):
        path = filedialog.askopenfilename(
            title="Open NanoScope TXT",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")],
        )
        if not path:
            return

        try:
            data, metadata = load_nanoscope_txt(path)
        except Exception as e:
            messagebox.showerror("Load Error", str(e))
            return

        self.filepath = path
        self.raw_data = data
        self.current_data = data.copy()
        self.metadata = metadata
        self.region_map = None
        self.region_summary = []

        self.top_var.set("0")
        self.bottom_var.set("0")
        self.left_var.set("0")
        self.right_var.set("0")
        self.vmin_var.set("")
        self.vmax_var.set("")

        self.update_info_panel()
        self.refresh_display()

    def reset_to_raw(self):
        if self.raw_data is None:
            return
        self.current_data = self.raw_data.copy()
        self.region_map = None
        self.region_summary = []
        self.top_var.set("0")
        self.bottom_var.set("0")
        self.left_var.set("0")
        self.right_var.set("0")
        self.update_info_panel()
        self.refresh_display()

    def _parse_int(self, text: str, default: int = 0) -> int:
        text = text.strip()
        if text == "":
            return default
        return int(text)

    def _parse_float_optional(self, text: str) -> Optional[float]:
        text = text.strip()
        if text == "":
            return None
        return float(text)

    def apply_crop(self):
        if self.raw_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return
        try:
            top = self._parse_int(self.top_var.get(), 0)
            bottom = self._parse_int(self.bottom_var.get(), 0)
            left = self._parse_int(self.left_var.get(), 0)
            right = self._parse_int(self.right_var.get(), 0)
        except ValueError:
            messagebox.showerror("Crop Error", "Crop values must be integers.")
            return

        h, w = self.raw_data.shape
        if top < 0 or bottom < 0 or left < 0 or right < 0:
            messagebox.showerror("Crop Error", "Crop values must be >= 0.")
            return
        if top + bottom >= h or left + right >= w:
            messagebox.showerror("Crop Error", "Crop size is too large for current image.")
            return

        self.current_data = self.raw_data[top:h-bottom if bottom > 0 else h,
                                         left:w-right if right > 0 else w].copy()
        self.region_map = None
        self.region_summary = []
        self.update_info_panel()
        self.refresh_display()

    def get_display_limits(self) -> Tuple[Optional[float], Optional[float]]:
        try:
            vmin = self._parse_float_optional(self.vmin_var.get())
            vmax = self._parse_float_optional(self.vmax_var.get())
        except ValueError:
            messagebox.showerror("Display Error", "vmin/vmax must be numeric.")
            return None, None
        return vmin, vmax

    def refresh_display(self):
        if self.current_data is None:
            self._draw_empty()
            return

        cmap_name = self.cmap_var.get()
        vmin, vmax = self.get_display_limits()
        if vmin is None and self.vmin_var.get().strip() != "":
            return
        if vmax is None and self.vmax_var.get().strip() != "":
            return

        self.ax_raw.clear()
        self.ax_raw.set_title("Raw / Cropped Image")
        self.current_im_raw = self.ax_raw.imshow(
            self.current_data,
            cmap=cmap_name,
            origin="upper",
            aspect="auto",
            vmin=vmin,
            vmax=vmax,
        )
        self.ax_raw.set_xlabel("X")
        self.ax_raw.set_ylabel("Y")

        self.ax_thr.clear()
        self.ax_thr.set_title("Threshold Regions")
        if self.region_map is None:
            self.ax_thr.text(0.5, 0.5, "Apply threshold to view result", ha="center", va="center")
        else:
            n_regions = int(np.nanmax(self.region_map)) + 1
            cmap_thr = cm.get_cmap("tab20", n_regions)
            bounds = np.arange(-0.5, n_regions + 0.5, 1)
            norm = BoundaryNorm(bounds, cmap_thr.N)
            self.current_im_thr = self.ax_thr.imshow(
                self.region_map,
                cmap=cmap_thr,
                norm=norm,
                origin="upper",
                aspect="auto",
            )
            self.ax_thr.set_xlabel("X")
            self.ax_thr.set_ylabel("Y")

        self.figure.tight_layout()
        self.canvas.draw()

    def suggest_thresholds(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            messagebox.showerror("Threshold Error", "Threshold count must be an integer.")
            return

        if self.auto_count_var.get():
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        method = self.auto_method_var.get()
        if method == "equal_interval":
            ts = auto_thresholds_equal_interval(self.current_data, n_thresh)
        else:
            ts = auto_thresholds_quantile(self.current_data, n_thresh)

        self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))

    def _parse_thresholds(self) -> List[float]:
        if self.current_data is None:
            raise ValueError("No data loaded.")

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            raise ValueError("Threshold count must be an integer.")

        if n_thresh < 1:
            raise ValueError("Threshold count must be >= 1.")

        if self.auto_count_var.get():
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        if self.auto_values_var.get():
            method = self.auto_method_var.get()
            if method == "equal_interval":
                ts = auto_thresholds_equal_interval(self.current_data, n_thresh)
            else:
                ts = auto_thresholds_quantile(self.current_data, n_thresh)
            self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))
            return ts

        raw = self.threshold_values_var.get().strip()
        if not raw:
            raise ValueError("Please enter threshold values or enable auto threshold values.")

        try:
            ts = [float(x.strip()) for x in raw.split(",") if x.strip() != ""]
        except ValueError:
            raise ValueError("Threshold values must be numeric and comma-separated.")

        if len(ts) != n_thresh:
            raise ValueError(f"Threshold count is {n_thresh}, but {len(ts)} values were provided.")

        return sorted(ts)

    def apply_threshold(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            thresholds = self._parse_thresholds()
        except Exception as e:
            messagebox.showerror("Threshold Error", str(e))
            return

        self.region_map = build_region_map(self.current_data, thresholds)
        masks, ranges = multi_threshold_masks(self.current_data, thresholds)
        total = self.current_data.size

        lines: List[str] = []
        lines.append("[Threshold Summary]")
        lines.append(f"Thresholds: {', '.join(f'{t:.6g}' for t in thresholds)}")
        lines.append("")

        for idx, (mask, rg) in enumerate(zip(masks, ranges)):
            count = int(mask.sum())
            pct = 100.0 * count / total if total > 0 else 0.0

            lo, hi = rg
            lo_s = "-inf" if np.isneginf(lo) else f"{lo:.6g}"
            hi_s = "+inf" if np.isposinf(hi) else f"{hi:.6g}"
            label = f"Region {idx}: [{lo_s}, {hi_s})" if not np.isposinf(hi) else f"Region {idx}: [{lo_s}, {hi_s}]"
            lines.append(f"{label}")
            lines.append(f"  Pixels: {count}")
            lines.append(f"  Percent: {pct:.3f}%")

        self.region_summary = lines
        self.update_info_panel()
        self.refresh_display()

    def update_info_panel(self):
        self.info_text.delete("1.0", tk.END)

        if self.filepath:
            self.info_text.insert(tk.END, f"File: {self.filepath}\n\n")

        if self.raw_data is not None:
            self.info_text.insert(tk.END, "[Image Info]\n")
            self.info_text.insert(tk.END, f"Raw shape: {self.raw_data.shape}\n")
        if self.current_data is not None:
            self.info_text.insert(tk.END, f"Current shape: {self.current_data.shape}\n")
            self.info_text.insert(tk.END, f"Min: {np.nanmin(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Max: {np.nanmax(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Mean: {np.nanmean(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Std: {np.nanstd(self.current_data):.6g}\n\n")

        if self.metadata:
            self.info_text.insert(tk.END, "[Metadata]\n")
            for k, v in self.metadata.items():
                self.info_text.insert(tk.END, f"{k}: {v}\n")
            self.info_text.insert(tk.END, "\n")

        if self.region_summary:
            self.info_text.insert(tk.END, "\n".join(self.region_summary))

    def save_current_plot(self, kind: str):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        filepath = filedialog.asksaveasfilename(
            title="Save image",
            defaultextension=".png",
            filetypes=[("PNG files", "*.png"), ("TIFF files", "*.tif"), ("JPEG files", "*.jpg")],
        )
        if not filepath:
            return

        try:
            fig = Figure(figsize=(6, 5), dpi=150)
            ax = fig.add_subplot(111)

            if kind == "raw":
                cmap_name = self.cmap_var.get()
                vmin, vmax = self.get_display_limits()
                ax.imshow(self.current_data, cmap=cmap_name, origin="upper", aspect="auto", vmin=vmin, vmax=vmax)
                ax.set_title("Raw / Cropped Image")
            else:
                if self.region_map is None:
                    messagebox.showwarning("No threshold result", "Apply threshold first.")
                    return
                n_regions = int(np.nanmax(self.region_map)) + 1
                cmap_thr = cm.get_cmap("tab20", n_regions)
                bounds = np.arange(-0.5, n_regions + 0.5, 1)
                norm = BoundaryNorm(bounds, cmap_thr.N)
                ax.imshow(self.region_map, cmap=cmap_thr, norm=norm, origin="upper", aspect="auto")
                ax.set_title("Threshold Regions")

            ax.set_xlabel("X")
            ax.set_ylabel("Y")
            fig.tight_layout()
            fig.savefig(filepath, bbox_inches="tight")
            messagebox.showinfo("Saved", f"Saved image to:\n{filepath}")
        except Exception as e:
            messagebox.showerror("Save Error", str(e))

    def save_summary(self):
        if not self.region_summary:
            messagebox.showwarning("No summary", "Apply threshold first.")
            return

        filepath = filedialog.asksaveasfilename(
            title="Save summary",
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")],
        )
        if not filepath:
            return

        try:
            ext = os.path.splitext(filepath)[1].lower()
            if ext == ".csv":
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write("line\n")
                    for line in self.region_summary:
                        f.write('"' + line.replace('"', '""') + '"
')
            else:
                with open(filepath, "w", encoding="utf-8") as f:
                    f.write("\n".join(self.region_summary))
            messagebox.showinfo("Saved", f"Saved summary to:\n{filepath}")
        except Exception as e:
            messagebox.showerror("Save Error", str(e))


def main():
    root = tk.Tk()
    style = ttk.Style()
    try:
        style.theme_use("clam")
    except Exception:
        pass
    app = ThresholdApp(root)
    root.mainloop()


if __name__ == "__main__":
    main()
