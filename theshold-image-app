    def _parse_int(self, text: str, default: int = 0) -> int:
        text = text.strip()
        if text == "":
            return default
        return int(text)

    def _parse_float_optional(self, text: str) -> Optional[float]:
        text = text.strip()
        if text == "":
            return None
        return float(text)

    def apply_crop(self):
        if self.raw_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return
        try:
            top = self._parse_int(self.top_var.get(), 0)
            bottom = self._parse_int(self.bottom_var.get(), 0)
            left = self._parse_int(self.left_var.get(), 0)
            right = self._parse_int(self.right_var.get(), 0)
        except ValueError:
            messagebox.showerror("Crop Error", "Crop values must be integers.")
            return

        h, w = self.raw_data.shape
        if top < 0 or bottom < 0 or left < 0 or right < 0:
            messagebox.showerror("Crop Error", "Crop values must be >= 0.")
            return
        if top + bottom >= h or left + right >= w:
            messagebox.showerror("Crop Error", "Crop size is too large for current image.")
            return

        self.current_data = self.raw_data[top:h-bottom if bottom > 0 else h,
                                         left:w-right if right > 0 else w].copy()
        self.region_map = None
        self.region_summary = []
        self.update_info_panel()
        self.refresh_display()

    def get_display_limits(self) -> Tuple[Optional[float], Optional[float]]:
        try:
            vmin = self._parse_float_optional(self.vmin_var.get())
            vmax = self._parse_float_optional(self.vmax_var.get())
        except ValueError:
            messagebox.showerror("Display Error", "vmin/vmax must be numeric.")
            return None, None
        return vmin, vmax

    def refresh_display(self):
        if self.current_data is None:
            self._draw_empty()
            return

        cmap_name = self.cmap_var.get()
        thr_cmap_name = self.threshold_cmap_var.get()
        vmin, vmax = self.get_display_limits()
        if vmin is None and self.vmin_var.get().strip() != "":
            return
        if vmax is None and self.vmax_var.get().strip() != "":
            return

        disp = np.array(self.current_data, dtype=float)
        finite_mask = np.isfinite(disp)
        if not np.any(finite_mask):
            self._draw_empty()
            return

        finite_vals = disp[finite_mask]
        disp[~finite_mask] = float(np.median(finite_vals))

        if vmin is None:
            vmin = float(np.min(finite_vals))
        if vmax is None:
            vmax = float(np.max(finite_vals))
        if vmin == vmax:
            vmax = vmin + 1e-12

        if self.cbar_raw is not None:
            try:
                self.cbar_raw.remove()
            except Exception:
                pass
            self.cbar_raw = None
        if self.cbar_thr is not None:
            try:
                self.cbar_thr.remove()
            except Exception:
                pass
            self.cbar_thr = None

        self.ax_raw.clear()
        self.ax_thr.clear()
        self.ax_raw_hist.clear()
        self.ax_thr_hist.clear()

        self.ax_raw.set_title("Raw / Cropped Image")
        self.current_im_raw = self.ax_raw.imshow(
            disp,
            cmap=cmap_name,
            origin="upper",
            aspect="equal",
            vmin=vmin,
            vmax=vmax,
            interpolation="nearest",
        )
        self.ax_raw.set_xlabel("X")
        self.ax_raw.set_ylabel("Y")
        self.cbar_raw = self.figure.colorbar(self.current_im_raw, ax=self.ax_raw, fraction=0.046, pad=0.04)

        thresholds = []
        if self.region_map is not None:
            try:
                thresholds = self._parse_thresholds()
            except Exception:
                thresholds = []

        line_colors = plt.rcParams['axes.prop_cycle'].by_key().get('color', ['C0', 'C1', 'C2', 'C3', 'C4', 'C5'])

        self.ax_thr.set_title("Threshold Regions")
        if self.region_map is None:
            self.ax_thr.text(0.5, 0.5, "Apply threshold to view result", ha="center", va="center")
            thr_hist_vals = finite_vals
        else:
            self.current_im_thr = self.ax_thr.imshow(
                self.region_map,
                cmap=thr_cmap_name,
                origin="upper",
                aspect="equal",
                interpolation="nearest",
            )
            self.ax_thr.set_xlabel("X")
            self.ax_thr.set_ylabel("Y")
            self.cbar_thr = self.figure.colorbar(self.current_im_thr, ax=self.ax_thr, fraction=0.046, pad=0.04)
            thr_hist_vals = self.region_map[np.isfinite(self.region_map)].ravel()

        self.ax_raw_hist.set_title("Raw Histogram")
        self.ax_raw_hist.hist(finite_vals, bins=128)
        self.ax_raw_hist.set_xlim(vmin, vmax)
        self.ax_raw_hist.set_xlabel("Value")
        self.ax_raw_hist.set_ylabel("Count")
        for i, t in enumerate(thresholds):
            self.ax_raw_hist.axvline(t, linestyle="--", linewidth=1.5, color=line_colors[i % len(line_colors)], label=f"T{i+1}")
        if thresholds:
            self.ax_raw_hist.legend(fontsize=8, loc="best")

        self.ax_thr_hist.set_title("Threshold Histogram")
        if self.region_map is None:
            self.ax_thr_hist.hist(finite_vals, bins=128)
            self.ax_thr_hist.set_xlim(vmin, vmax)
            self.ax_thr_hist.set_xlabel("Value")
        else:
            bins = np.arange(-0.5, int(np.max(thr_hist_vals)) + 1.5, 1)
            self.ax_thr_hist.hist(thr_hist_vals, bins=bins)
            self.ax_thr_hist.set_xlim(-0.5, int(np.max(thr_hist_vals)) + 0.5)
            self.ax_thr_hist.set_xlabel("Threshold Region Index")
            ymax = self.ax_thr_hist.get_ylim()[1]
            for i, t in enumerate(thresholds):
                self.ax_thr_hist.text(i + 0.5, ymax * 0.95, f"T{i+1}={t:.4g}",
                                      color=line_colors[i % len(line_colors)], ha="center", va="top", fontsize=8)
        self.ax_thr_hist.set_ylabel("Count")

        self.figure.tight_layout()
        self.canvas.draw()

    def suggest_thresholds(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            messagebox.showerror("Threshold Error", "Threshold count must be an integer.")
            return

        method = self.auto_method_var.get()
        if method == "otsu":
            n_thresh = 1
            self.n_thresh_var.set("1")
        elif self.auto_count_var.get() and method != "multi_otsu":
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        ts = self._compute_auto_thresholds(method, n_thresh)
        self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))

    def _compute_auto_thresholds(self, method: str, n_thresh: int) -> List[float]:
        if method == "equal_interval":
            return auto_thresholds_equal_interval(self.current_data, n_thresh)
        if method == "quantile":
            return auto_thresholds_quantile(self.current_data, n_thresh)
        if method == "otsu":
            return auto_thresholds_otsu(self.current_data)
        if method == "multi_otsu":
            return auto_thresholds_multi_otsu(self.current_data, n_thresh)
        if method == "kmeans":
            return auto_thresholds_kmeans(self.current_data, n_thresh)
        if method == "gmm":
            return auto_thresholds_gmm(self.current_data, n_thresh)
        return auto_thresholds_quantile(self.current_data, n_thresh)

    def _parse_thresholds(self) -> List[float]:
        if self.current_data is None:
            raise ValueError("No data loaded.")

        try:
            n_thresh = self._parse_int(self.n_thresh_var.get(), 2)
        except ValueError:
            raise ValueError("Threshold count must be an integer.")

        if n_thresh < 1:
            raise ValueError("Threshold count must be >= 1.")

        method = self.auto_method_var.get()
        if method == "otsu":
            n_thresh = 1
            self.n_thresh_var.set("1")
        elif self.auto_count_var.get() and method != "multi_otsu":
            n_thresh = auto_threshold_count_by_unique(self.current_data)
            self.n_thresh_var.set(str(n_thresh))

        if self.auto_values_var.get():
            ts = self._compute_auto_thresholds(method, n_thresh)
            self.threshold_values_var.set(", ".join(f"{t:.6g}" for t in ts))
            return sorted(ts)

        raw = self.threshold_values_var.get().strip()
        if not raw:
            raise ValueError("Please enter threshold values or enable auto threshold values.")

        try:
            ts = [float(x.strip()) for x in raw.split(",") if x.strip() != ""]
        except ValueError:
            raise ValueError("Threshold values must be numeric and comma-separated.")

        if len(ts) != n_thresh:
            raise ValueError(f"Threshold count is {n_thresh}, but {len(ts)} values were provided.")

        return sorted(ts)

    def apply_threshold(self):
        if self.current_data is None:
            messagebox.showwarning("No data", "Please load a TXT file first.")
            return

        try:
            thresholds = self._parse_thresholds()
        except Exception as e:
            messagebox.showerror("Threshold Error", str(e))
            return

        self.region_map = build_region_map(self.current_data, thresholds)
        masks, ranges = multi_threshold_masks(self.current_data, thresholds)
        total = self.current_data.size

        lines: List[str] = []
        lines.append("[Threshold Summary]")
        lines.append(f"Thresholds: {', '.join(f'{t:.6g}' for t in thresholds)}")
        lines.append("")

        for idx, (mask, rg) in enumerate(zip(masks, ranges)):
            count = int(mask.sum())
            pct = 100.0 * count / total if total > 0 else 0.0

            lo, hi = rg
            lo_s = "-inf" if np.isneginf(lo) else f"{lo:.6g}"
            hi_s = "+inf" if np.isposinf(hi) else f"{hi:.6g}"
            label = f"Region {idx}: [{lo_s}, {hi_s})" if not np.isposinf(hi) else f"Region {idx}: [{lo_s}, {hi_s}]"
            lines.append(f"{label}")
            lines.append(f"  Pixels: {count}")
            lines.append(f"  Percent: {pct:.3f}%")

        self.region_summary = lines
        self.update_info_panel()
        self.refresh_display()

    def update_info_panel(self):
        self.info_text.delete("1.0", tk.END)

        if self.filepath:
            self.info_text.insert(tk.END, f"File: {self.filepath}\n\n")

        if self.raw_data is not None:
            self.info_text.insert(tk.END, "[Image Info]\n")
            self.info_text.insert(tk.END, f"Raw shape: {self.raw_data.shape}\n")
        if self.current_data is not None:
            self.info_text.insert(tk.END, f"Current shape: {self.current_data.shape}\n")
            self.info_text.insert(tk.END, f"Min: {np.nanmin(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Max: {np.nanmax(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Mean: {np.nanmean(self.current_data):.6g}\n")
            self.info_text.insert(tk.END, f"Std: {np.nanstd(self.current_data):.6g}\n\n")

        if self.metadata:
            self.info_text.insert(tk.END, "[Metadata]\n")
            for k, v in self.metadata.items():
                self.info_text.insert(tk.END, f"{k}: {v}\n")
            self.info_text.insert(tk.END, "\n")

        if self.region_summary:
            self.info_text.insert(tk.END, "\n".join(self.region_summary))

