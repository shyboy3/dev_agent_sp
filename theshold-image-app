    # I/O
    def load_images(self):
        paths = filedialog.askopenfilenames(
            title="Select image(s)",
            filetypes=[
                ("Supported", "*.png *.jpg *.jpeg *.tif *.tiff *.bmp *.npy *.csv *.txt *.spm *.000 *.001 *.002 *.003 *.004 *.005 *.006 *.007 *.008 *.009"),
                ("All files", "*.*"),
            ]
        )
        if not paths:
            return
        added = 0
        for path in paths:
            if path not in self.filepaths:
                self.filepaths.append(path)
                self.file_listbox.insert(tk.END, os.path.basename(path))
                added += 1
        if self.filepaths:
            select_idx = len(self.filepaths) - 1
            self.file_listbox.selection_clear(0, tk.END)
            self.file_listbox.selection_set(select_idx)
            self.file_listbox.activate(select_idx)
            self.file_listbox.see(select_idx)
            self._set_current_file(select_idx)
        self.status_var.set(f"Loaded {added} new file(s). Total files: {len(self.filepaths)}")

    def on_file_select(self, event=None):
        selection = self.file_listbox.curselection()
        if not selection:
            return
        self._set_current_file(selection[0])

    def _set_current_file(self, idx):
        if idx < 0 or idx >= len(self.filepaths):
            return
        self.filepath = self.filepaths[idx]
        self._refresh_spm_channel_ui_for_current_file()
        self._read_current_file()

    def on_spm_channel_select(self, event=None):
        if not self.filepath or not self._is_bruker_candidate(self.filepath):
            return
        self._read_current_file()

    def _refresh_spm_channel_ui_for_current_file(self):
        path = self.filepath
        if not path or not self._is_bruker_candidate(path):
            self.selected_spm_channel_var.set("")
            if self.spm_channel_combo is not None:
                self.spm_channel_combo.configure(values=[], state="disabled")
            return

        channel_names = self._get_spm_channel_names(path)
        display_names = [str(name) for name in channel_names]
        if self.spm_channel_combo is not None:
            state = "readonly" if display_names else "disabled"
            self.spm_channel_combo.configure(values=display_names, state=state)

        current = self.selected_spm_channel_var.get().strip()
        if current in display_names:
            return

        preferred = self._choose_default_spm_channel(channel_names)
        self.selected_spm_channel_var.set(str(preferred) if preferred is not None else "")

    def _is_bruker_candidate(self, path):
        ext = os.path.splitext(path)[1].lower()
        return ext == ".spm" or (len(ext) == 4 and ext[1:].isdigit())

    def _get_nanoscope_channel_names(self, path):
        if not HAS_NANOSCOPE or NanoscopeImageFile is None:
            return []
        try:
            with NanoscopeImageFile(path) as f:
                names = [str(name) for name in getattr(f, "channels_data_types_desc", [])]
        except Exception:
            return []
        return names

    def _get_spm_channel_names(self, path):
        if path in self.spm_channels_by_path:
            return self.spm_channels_by_path[path]

        names = []
        if self._is_bruker_candidate(path) and HAS_NANOSCOPE:
            names = self._get_nanoscope_channel_names(path)

        if not names and HAS_PYSPM:
            try:
                bruker = pySPM.Bruker(path)
                names = [str(name) for name in bruker.list_channels()]
            except Exception:
                names = []

        self.spm_channels_by_path[path] = names
        return names

    def _choose_default_spm_channel(self, channel_names):
        preferred_order = [
            "Height Sensor", "Height", "ZSensor", "Z Sensor", "Topography",
            "Height Trace", "Topography Trace", "Height Retrace", "Topography Retrace"
        ]
        lowered = {str(name).strip().lower(): name for name in channel_names}
        for pref in preferred_order:
            match = lowered.get(pref.lower())
            if match is not None:
                return match
        for name in channel_names:
            lname = str(name).lower()
            if "height" in lname or "topography" in lname or "z" in lname:
                return name
        return channel_names[0] if channel_names else None

    def remove_selected_file(self):
        selection = self.file_listbox.curselection()
        if not selection:
            messagebox.showinfo("Info", "Select a file to remove.")
            return
        idx = selection[0]
        removed = self.filepaths.pop(idx)
        self.file_listbox.delete(idx)
        if self.filepath == removed:
            self.reset_processing(keep_image=False)
            if self.filepaths:
                new_idx = min(idx, len(self.filepaths) - 1)
                self.file_listbox.selection_set(new_idx)
                self.file_listbox.activate(new_idx)
                self._set_current_file(new_idx)
            else:
                self.file_label.config(text="No file selected")
                self._refresh_spm_channel_ui_for_current_file()
        self.status_var.set(f"Removed: {os.path.basename(removed)}")

    def clear_file_list(self):
        self.filepaths = []
        self.filepath = None
        self.file_listbox.delete(0, tk.END)
        self.reset_processing(keep_image=False)
        self.file_label.config(text="No file selected")
        self.raw_shape_var.set("Raw Shape: N/A")
        self.current_source_info = None
        self.current_afm_backend = None
        self.current_afm_metrics = {}
        self.selected_spm_channel_var.set("")
        self._refresh_spm_channel_ui_for_current_file()
        self.status_var.set("File list cleared")

    def reload_image(self):
        if not self.filepath:
            messagebox.showinfo("Info", "No file selected yet.")
            return
        self._read_current_file()

    def _read_current_file(self):
        try:
            path = self.filepath
            arr, source_info = self._load_array_from_path(path)

            arr = self._to_2d_float(arr)
            self.raw_image = arr
            self.current_source_info = source_info
            if not self._is_bruker_candidate(path):
                self.current_data_unit = None
                self.current_unit_source = None
                self.current_xy_unit = None
                self.current_x_scale = None
                self.current_y_scale = None
                self.current_xy_source = None
                self.current_afm_backend = None
                self.current_afm_metrics = {}
            h, w = arr.shape
            self.raw_shape_var.set(f"Raw Shape: {h} x {w} (H x W)")
            if self.file_label is not None:
                self.file_label.config(text=path)
            # Preserve all user parameters across file changes.
            # Only initialize display min/max once when they still have their startup defaults.
            if (not self.raw_min_enable_var.get()) and (not self.raw_max_enable_var.get()) and float(self.raw_vmin_var.get()) == 0.0 and float(self.raw_vmax_var.get()) == 1.0:
                self.raw_vmin_var.set(float(np.min(arr)))
                self.raw_vmax_var.set(float(np.max(arr)))
            info_suffix = f" | {source_info}" if source_info else ""
            self.status_var.set(f"Loaded image: {os.path.basename(path)} | size={arr.shape[1]} x {arr.shape[0]}{info_suffix}")
            self.reset_processing(keep_image=True)
            self.process_all()
        except Exception as e:
            messagebox.showerror("Load Error", str(e))
            self.status_var.set("Failed to load image")

    def _load_array_from_path(self, path):
        ext = os.path.splitext(path)[1].lower()
        if ext == ".npy":
            return np.load(path), None
        if ext in [".csv", ".txt"]:
            return np.loadtxt(path, delimiter=',' if ext == '.csv' else None), None
        if self._is_bruker_candidate(path):
            return self._load_spm_file(path)
        return skio.imread(path), None

    def _load_spm_file(self, path):
        errors = []
        if HAS_NANOSCOPE:
            try:
                return self._load_bruker_with_nanoscope(path)
            except Exception as exc:
                errors.append(f"nanoscope: {exc}")

        if HAS_PYSPM:
            try:
                return self._load_bruker_with_pyspm(path)
            except Exception as exc:
                errors.append(f"pySPM: {exc}")

        if not HAS_NANOSCOPE and not HAS_PYSPM:
            raise ImportError(
                "Loading Bruker AFM files (.spm, .000, .001, ...) requires nanoscope or pySPM.\n"
                f"nanoscope import error: {NANOSCOPE_IMPORT_ERROR}\n"
                f"pySPM import error: {PYSPM_IMPORT_ERROR}"
            )

        raise RuntimeError("Failed to load Bruker AFM file. " + " | ".join(errors))

    def _get_selected_or_default_channel_name(self, channel_names):
        display_names = [str(name) for name in channel_names]
        chosen_name = self.selected_spm_channel_var.get().strip()
        if not chosen_name or chosen_name not in display_names:
            default_name = self._choose_default_spm_channel(channel_names)
            chosen_name = str(default_name) if default_name is not None else chosen_name
            self.selected_spm_channel_var.set(chosen_name)
        return chosen_name

    def _normalize_unit_text(self, unit):
        if unit is None:
            return None
        try:
            s = str(unit).strip()
        except Exception:
            return None
        if not s:
            return None
        s = s.replace("µ", "u")
        low = s.lower()
        invalid = {
            "none", "null", "n/a", "na", "unknown", "dimensionless",
            "[]", "()", "{}", "a.u", "arb", "arbitrary", "au"
        }
        if low in invalid:
            return None
        if len(s) > 32:
            return None
        return s

    def _guess_unit_from_channel_name(self, channel_name):
        name = str(channel_name).lower()
        if "phase" in name:
            return "deg"
        if "current" in name:
            return "nA"
        if "height" in name or "topography" in name or "deflection" in name or "amplitude" in name:
            return "nm"
        return None

    def _extract_unit_from_text(self, text):
        if text is None:
            return None
        try:
            s = str(text).strip()
        except Exception:
            return None
        if not s:
            return None
        for token in ["nm", "um", "µm", "pm", "mm", "m", "V", "mV", "uV", "A", "mA", "uA", "nA", "pA", "deg", "°"]:
            if token in s:
                return self._normalize_unit_text(token)
        return None

    def _infer_unit_from_object(self, obj, fallback_channel_name=None, _depth=0):
        if obj is None or _depth > 2:
            return None, None

        attrs = [
            "unit", "units", "z_unit", "z_units", "data_unit", "data_units",
            "scale_unit", "value_unit", "label", "ylabel", "name", "zscale"
        ]
        for attr in attrs:
            if not hasattr(obj, attr):
                continue
            try:
                value = getattr(obj, attr)
            except Exception:
                continue
            unit = self._normalize_unit_text(value) or self._extract_unit_from_text(value)
            if unit:
                return unit, attr

        for attr in ["scale", "meta", "metadata", "info", "header"]:
            if not hasattr(obj, attr):
                continue
            try:
                value = getattr(obj, attr)
            except Exception:
                continue
            if isinstance(value, dict):
                for k, v in value.items():
                    unit = self._normalize_unit_text(v) or self._extract_unit_from_text(v)
                    if unit and ("unit" in str(k).lower() or "scale" in str(k).lower()):
                        return unit, f"{attr}.{k}"
            else:
                unit = self._normalize_unit_text(value) or self._extract_unit_from_text(value)
                if unit:
                    return unit, attr

        if fallback_channel_name:
            guessed = self._guess_unit_from_channel_name(fallback_channel_name)
            if guessed:
                return guessed, "channel-name fallback"
        return None, None

    def _value_label_with_unit(self, base):
        unit = self.current_data_unit
        return f"{base} ({unit})" if unit else base

    def _format_number_with_unit(self, value, unit=None):
        unit = unit if unit is not None else self.current_data_unit
        try:
            s = f"{float(value):.6g}"
        except Exception:
            s = str(value)
        return f"{s} {unit}" if unit else s

    def _extract_numeric_and_unit(self, value):
        if value is None:
            return None, None
        if isinstance(value, (int, float, np.integer, np.floating)):
            return float(value), None
        text = str(value).strip()
        m = re.match(r'^\s*([-+]?\d*\.?\d+(?:[eE][-+]?\d+)?)\s*([^\d\s].*)?$', text)
        if not m:
            return None, None
        try:
            num = float(m.group(1))
        except Exception:
            return None, None
        unit = self._normalize_unit_text(m.group(2)) if m.group(2) else None
        return num, unit

    def _infer_xy_calibration_from_object(self, obj, image_shape=None, _depth=0):
        if obj is None or _depth > 2:
            return None, None, None, None

        if image_shape is None and self.raw_image is not None:
            image_shape = self.raw_image.shape

        scalar_pairs = [
            ("xreal", "yreal"), ("x_size", "y_size"), ("x_length", "y_length"),
            ("x_range", "y_range"), ("scan_width", "scan_height"), ("width_real", "height_real")
        ]
        for ax_name, ay_name in scalar_pairs:
            if hasattr(obj, ax_name) and hasattr(obj, ay_name):
                try:
                    xv = getattr(obj, ax_name)
                    yv = getattr(obj, ay_name)
                except Exception:
                    continue
                xnum, xunit = self._extract_numeric_and_unit(xv)
                ynum, yunit = self._extract_numeric_and_unit(yv)
                if xnum is not None and ynum is not None:
                    unit = xunit or yunit
                    return xnum, ynum, unit, f"{ax_name}/{ay_name}"

        # tuple/list forms like size=(x,y) or scan_size=(x,y)
        for attr in ["size", "scan_size", "xy_size", "real_size", "range", "x_y_offsets"]:
            if not hasattr(obj, attr):
                continue
            try:
                value = getattr(obj, attr)
            except Exception:
                continue
            if isinstance(value, (list, tuple)) and len(value) >= 2:
                xnum, xunit = self._extract_numeric_and_unit(value[0])
                ynum, yunit = self._extract_numeric_and_unit(value[1])
                if xnum is not None and ynum is not None:
                    unit = xunit or yunit
                    if image_shape is not None:
                        h, w = image_shape[:2]
                        # reject likely pixel counts duplicated as shape
                        if abs(xnum - w) < 1e-9 and abs(ynum - h) < 1e-9:
                            continue
                    return xnum, ynum, unit, attr

        for attr in ["meta", "metadata", "info", "header"]:
            if not hasattr(obj, attr):
                continue
            try:
                value = getattr(obj, attr)
            except Exception:
                continue
            if isinstance(value, dict):
                lower = {str(k).lower(): v for k, v in value.items()}
                for kx, ky in [("xreal", "yreal"), ("x_size", "y_size"), ("scan_width", "scan_height")]:
                    if kx in lower and ky in lower:
                        xnum, xunit = self._extract_numeric_and_unit(lower[kx])
                        ynum, yunit = self._extract_numeric_and_unit(lower[ky])
                        if xnum is not None and ynum is not None:
                            unit = xunit or yunit
                            return xnum, ynum, unit, f"{attr}.{kx}/{ky}"

        return None, None, None, None

    def _infer_xy_calibration_from_bruker_header(self, filepath, image_shape=None):
        unit_dict = {
            "pm": 1e-3,
            "nm": 1.0,
            "um": 1e3,
            "µm": 1e3,
            "μm": 1e3,
            "mm": 1e6,
        }

        def norm_unit(u):
            if u is None:
                return None
            s = str(u).strip().lower().replace("μ", "µ").replace("\x00", "")
            aliases = {
                "micron": "um", "microns": "um", "micrometer": "um", "micrometers": "um",
                "micrometre": "um", "micrometres": "um", "µm": "um", "u m": "um", "um": "um",
                "nanometer": "nm", "nanometers": "nm", "nanometre": "nm", "nanometres": "nm",
                "picometer": "pm", "picometers": "pm", "millimeter": "mm", "millimeters": "mm",
            }
            return aliases.get(s, s)

        def make_xy_from_x_total(x_total_nm):
            if image_shape is not None:
                h, w = image_shape[:2]
                y_total_nm = x_total_nm * (float(h) / float(w)) if w > 0 else x_total_nm
            else:
                y_total_nm = x_total_nm
            return x_total_nm, y_total_nm

        def compatible_nm(a, b, rel_tol=0.05):
            if a is None or b is None or a <= 0 or b <= 0:
                return False
            return abs(a - b) / max(abs(a), abs(b)) <= rel_tol

        try:
            raw = Path(filepath).read_bytes()
        except Exception as e:
            return None, None, None, f"Header read failed: {e}"

        text = raw.decode("latin1", errors="ignore").replace("\x00", "")

        candidates = []
        debug_hits = []
        for raw_line in text.splitlines():
            line = raw_line.strip()
            if not line or "scan size" not in line.lower():
                continue
            debug_hits.append(line)
            if ":" in line:
                tail = line.split(":", 1)[1].strip()
            else:
                m = re.search(r"scan\s*size\s*(.*)$", line, flags=re.IGNORECASE)
                tail = m.group(1).strip() if m else ""
            if tail:
                candidates.append(tail)

        if not candidates:
            for m in re.finditer(r"scan\s*size\s*:?[ \t]*([-+0-9.eE]+(?:[ \t]+[-+0-9.eE]+)?[ \t]*[A-Za-z~µμ]+)", text, flags=re.IGNORECASE):
                val = m.group(1).strip()
                candidates.append(val)
                debug_hits.append(f"whole-text:{val}")

        if not candidates:
            return None, None, None, "No validated Scan Size found in header"

        single_pat = re.compile(r"^\s*([-+]?\d*\.?\d+(?:[eE][-+]?\d+)?)\s*([A-Za-z~µμ]+)\s*$")
        pair_pat = re.compile(r"^\s*([-+]?\d*\.?\d+(?:[eE][-+]?\d+)?)\s+([-+]?\d*\.?\d+(?:[eE][-+]?\d+)?)\s*([A-Za-z~µμ]+)\s*$")

        trusted_nm = []
        trusted_other = []
        tilde_um_candidates = []

        for line in candidates:
            clean = line.strip()
            m2 = pair_pat.match(clean)
            if m2:
                x = float(m2.group(1))
                y = float(m2.group(2))
                unit_raw = m2.group(3)
                unit_norm = norm_unit(unit_raw)
                unit_clean = str(unit_raw).strip().lower().replace("μ", "µ")
                if x > 0 and y > 0:
                    if unit_norm == "nm":
                        trusted_nm.append((x, y, "nm", f"Bruker header Scan Size: {clean}"))
                        continue
                    if unit_norm in unit_dict:
                        trusted_other.append((x * unit_dict[unit_norm], y * unit_dict[unit_norm], "nm", f"Bruker header Scan Size: {clean}"))
                        continue
                    if unit_clean == "~m":
                        tilde_um_candidates.append((x * 1e3, y * 1e3, "nm", f"Bruker header Scan Size (~m candidate): {clean}"))
                        continue

            m1 = single_pat.match(clean)
            if m1:
                val = float(m1.group(1))
                unit_raw = m1.group(2)
                unit_norm = norm_unit(unit_raw)
                unit_clean = str(unit_raw).strip().lower().replace("μ", "µ")
                if val > 0:
                    x_total_nm, y_total_nm = make_xy_from_x_total(val)
                    if unit_norm == "nm":
                        trusted_nm.append((x_total_nm, y_total_nm, "nm", f"Bruker header Scan Size: {clean}"))
                        continue
                    if unit_norm in unit_dict:
                        trusted_other.append((x_total_nm * unit_dict[unit_norm], y_total_nm * unit_dict[unit_norm], "nm", f"Bruker header Scan Size: {clean}"))
                        continue
                    if unit_clean == "~m":
                        tilde_um_candidates.append((x_total_nm * 1e3, y_total_nm * 1e3, "nm", f"Bruker header Scan Size (~m candidate): {clean}"))
                        continue

        if trusted_nm:
            x, y, unit, source = trusted_nm[0]
            return x, y, unit, source

        if trusted_other:
            x, y, unit, source = trusted_other[0]
            return x, y, unit, source

        if tilde_um_candidates:
            for cand in tilde_um_candidates:
                cand_x, cand_y, unit, source = cand
                for nm_x, nm_y, _u, _src in trusted_nm:
                    if compatible_nm(cand_x, nm_x) and compatible_nm(cand_y, nm_y):
                        return cand_x, cand_y, unit, source.replace("(~m candidate)", "(~m validated)")
            # do not trust ~m by itself
            return None, None, None, "Only ~m Scan Size candidate found; ignored without nm cross-check"

        return None, None, None, f"Unparsed Scan Size lines: {debug_hits[:4]}"

    def _set_xy_calibration(self, x_length, y_length, unit, source, image_shape=None):
        self.current_xy_unit = unit
        self.current_xy_source = source
        self.current_x_total = float(x_length) if x_length is not None else None
        self.current_y_total = float(y_length) if y_length is not None else None
        self.current_x_scale = None
        self.current_y_scale = None
        if image_shape is None:
            image_shape = self.raw_image.shape if self.raw_image is not None else None
        if image_shape is not None:
            h, w = image_shape[:2]
            if x_length is not None and w > 0:
                self.current_x_scale = float(x_length) / float(w)
            if y_length is not None and h > 0:
                self.current_y_scale = float(y_length) / float(h)

    def _get_display_axis_unit_and_factor(self):
        unit = self.current_xy_unit
        x_total = getattr(self, "current_x_total", None)
        y_total = getattr(self, "current_y_total", None)
        if not unit or x_total is None or y_total is None:
            return None, 1.0

        max_total = max(abs(float(x_total)), abs(float(y_total)))
        if unit == "nm":
            if max_total >= 1_000_000:
                return "mm", 1_000_000.0
            if max_total >= 1_000:
                return "um", 1_000.0
            return "nm", 1.0
        if unit == "um":
            if max_total >= 1_000:
                return "mm", 1_000.0
            return "um", 1.0
        return unit, 1.0

    def _format_axis_value(self, v):
        av = abs(float(v))
        if av >= 100:
            return f"{v:.0f}"
        if av >= 10:
            return f"{v:.1f}".rstrip("0").rstrip(".")
        return f"{v:.2f}".rstrip("0").rstrip(".")

    def _get_axis_unit_text(self):
        disp_unit, _ = self._get_display_axis_unit_and_factor()
        return disp_unit if disp_unit else "pixel"

    def _axis_label(self, axis_name):
        return f"{axis_name} ({self._get_axis_unit_text()})"

    def _apply_spatial_axes(self, ax, image_shape):
        h, w = image_shape[:2]
        unit = self.current_xy_unit
        x_total = getattr(self, "current_x_total", None)
        y_total = getattr(self, "current_y_total", None)

        xticks = np.linspace(0, max(0, w - 1), num=min(6, max(2, w)))
        yticks = np.linspace(0, max(0, h - 1), num=min(6, max(2, h)))
        ax.set_xticks(xticks)
        ax.set_yticks(yticks)

        if unit and x_total is not None and y_total is not None and w > 1 and h > 1:
            disp_unit, factor = self._get_display_axis_unit_and_factor()
            xvals = np.linspace(0.0, float(x_total) / factor, num=len(xticks))
            yvals = np.linspace(0.0, float(y_total) / factor, num=len(yticks))
            ax.set_xticklabels([self._format_axis_value(v) for v in xvals])
            ax.set_yticklabels([self._format_axis_value(v) for v in yvals])
        else:
            ax.set_xticklabels([f"{int(round(x))}" for x in xticks])
            ax.set_yticklabels([f"{int(round(y))}" for y in yticks])

        ax.set_xlabel(self._axis_label("X"))
        ax.set_ylabel(self._axis_label("Y"))

    def _extract_2d_array_from_nanoscope_channel(self, ch):
        candidates = []
        for name in [
            "data", "image", "pixels", "map", "values",
            "raw", "processed", "trace", "height", "z"
        ]:
            if hasattr(ch, name):
                candidates.append(name)
        for name in dir(ch):
            if not name.startswith("_") and name not in candidates:
                candidates.append(name)

        tried = []
        for name in candidates:
            try:
                obj = getattr(ch, name)
            except Exception:
                continue
            if callable(obj):
                continue
            tried.append(name)
            try:
                arr = np.asarray(obj)
            except Exception:
                continue
            if arr.ndim == 2 and arr.size > 0 and np.issubdtype(arr.dtype, np.number):
                return arr, name
            # nested containers occasionally hold the numeric image as the first element/value
            try:
                if isinstance(obj, dict):
                    iterable = obj.values()
                elif isinstance(obj, (list, tuple)):
                    iterable = obj
                else:
                    iterable = None
                if iterable is not None:
                    for sub in iterable:
                        try:
                            subarr = np.asarray(sub)
                        except Exception:
                            continue
                        if subarr.ndim == 2 and subarr.size > 0 and np.issubdtype(subarr.dtype, np.number):
                            return subarr, f"{name}[*]"
            except Exception:
                pass

        # last-resort: inspect __dict__ values directly
        for name, obj in getattr(ch, "__dict__", {}).items():
            if callable(obj):
                continue
            try:
                arr = np.asarray(obj)
            except Exception:
                continue
            if arr.ndim == 2 and arr.size > 0 and np.issubdtype(arr.dtype, np.number):
                return arr, f"__dict__.{name}"

        raise ValueError(
            "Selected nanoscope channel does not expose a readable 2D numeric image array. "
            f"Tried attributes: {', '.join(tried[:40])}"
        )

    def _load_bruker_with_nanoscope(self, path):
        if NanoscopeImageFile is None:
            raise RuntimeError("nanoscope ImageFile API is not available in this environment.")

        with NanoscopeImageFile(path) as f:
            channel_names = [str(name) for name in getattr(f, "channels_data_types_desc", [])]
            if not channel_names:
                n = int(getattr(f, "number_of_channels", 0) or 0)
                channel_names = [f"Channel {i}" for i in range(n)]

            if not channel_names:
                raise ValueError("nanoscope ImageFile did not expose any image channels.")

            self.spm_channels_by_path[path] = channel_names
            chosen_name = self._get_selected_or_default_channel_name(channel_names)
            try:
                idx = [str(x) for x in channel_names].index(str(chosen_name))
            except ValueError:
                idx = 0
                chosen_name = str(channel_names[0])
                self.selected_spm_channel_var.set(chosen_name)

            chosen_ch = f[idx]
            data, data_attr = self._extract_2d_array_from_nanoscope_channel(chosen_ch)

            metrics = {}
            for key in ["rms", "zrange", "mean", "min", "max"]:
                try:
                    val = getattr(chosen_ch, key)
                except Exception:
                    continue
                if val is not None:
                    try:
                        metrics[key] = float(val)
                    except Exception:
                        metrics[key] = val

        unit, unit_source = self._infer_unit_from_object(chosen_ch, fallback_channel_name=chosen_name)
        xlen, ylen, xy_unit, xy_source = self._infer_xy_calibration_from_bruker_header(path, image_shape=np.asarray(data).shape)
        if xlen is None or ylen is None:
            xlen, ylen, xy_unit, xy_source = self._infer_xy_calibration_from_object(chosen_ch, image_shape=np.asarray(data).shape)
        if xlen is None or ylen is None:
            fx, fy, funit, fsource = self._infer_xy_calibration_from_object(f, image_shape=np.asarray(data).shape)
            if fx is not None and fy is not None:
                xlen, ylen, xy_unit, xy_source = fx, fy, (xy_unit or funit), fsource
        self._set_xy_calibration(xlen, ylen, xy_unit, xy_source, image_shape=np.asarray(data).shape)
        self.current_afm_backend = "nanoscope"
        self.current_afm_metrics = metrics
        self.current_data_unit = unit
        self.current_unit_source = unit_source

        source_parts = [f"Backend: nanoscope(ImageFile)", f"AFM channel: {chosen_name}", f"Data attr: {data_attr}"]
        if unit:
            source_parts.append(f"Unit: {unit}")
        if self.current_xy_unit and self.current_x_scale and self.current_y_scale:
            source_parts.append(f"XY unit: {self.current_xy_unit}")
        if "zrange" in metrics and isinstance(metrics["zrange"], (int, float)):
            source_parts.append(f"z-range: {metrics['zrange']:.6g}")
        if "rms" in metrics and isinstance(metrics["rms"], (int, float)):
            source_parts.append(f"rms: {metrics['rms']:.6g}")
        return np.asarray(data), " | ".join(source_parts)

    def _load_bruker_with_pyspm(self, path):
        bruker = pySPM.Bruker(path)
        channel_names = self._get_spm_channel_names(path)
        if not channel_names:
            try:
                channel_names = [str(name) for name in bruker.list_channels()]
                self.spm_channels_by_path[path] = channel_names
            except Exception:
                channel_names = []

        chosen_name = self._get_selected_or_default_channel_name(channel_names)
        if not chosen_name:
            raise ValueError("No readable image channel was found in this Bruker AFM file.")

        last_error = None
        image_obj = None
        for getter_args in [
            (chosen_name,),
            tuple(name for name in channel_names if str(name) == chosen_name)[:1],
            tuple(),
        ]:
            try:
                if len(getter_args) == 0:
                    continue
                image_obj = bruker.get_channel(*getter_args)
                if image_obj is not None:
                    break
            except Exception as exc:
                last_error = exc

        if image_obj is None:
            raise RuntimeError(f"Failed to read AFM channel '{chosen_name}': {last_error}")

        pixels = getattr(image_obj, "pixels", None)
        if pixels is None:
            raise ValueError(f"AFM channel '{chosen_name}' does not contain pixel data.")

        unit, unit_source = self._infer_unit_from_object(image_obj, fallback_channel_name=chosen_name)
        # For Bruker AFM XY axes, trust validated header scan-size first.
        # If it cannot be validated, keep pixel axes rather than applying uncertain conversions.
        xlen, ylen, xy_unit, xy_source = self._infer_xy_calibration_from_bruker_header(path, image_shape=np.asarray(pixels).shape)
        if xlen is None or ylen is None or not xy_unit:
            self._set_xy_calibration(None, None, None, None, image_shape=np.asarray(pixels).shape)
        else:
            self._set_xy_calibration(xlen, ylen, xy_unit, xy_source, image_shape=np.asarray(pixels).shape)
        self.current_afm_backend = "pySPM"
        self.current_afm_metrics = {}
        self.current_data_unit = unit
        self.current_unit_source = unit_source
        source_info = f"Backend: pySPM | AFM channel: {chosen_name}"
        zscale = getattr(image_obj, "zscale", None)
        if zscale:
            source_info += f" | z-scale: {zscale}"
        if unit:
            source_info += f" | Unit: {unit}"
        if self.current_xy_unit and self.current_x_scale and self.current_y_scale:
            source_info += f" | XY unit: {self.current_xy_unit}"
            if self.current_xy_source:
                source_info += f" ({self.current_xy_source})"
        return np.asarray(pixels), source_info

    def _to_2d_float(self, arr):
        arr = np.asarray(arr)
        if arr.ndim == 2:
            out = arr.astype(np.float32)
        elif arr.ndim == 3:
            if arr.shape[2] in [3, 4]:
                out = np.mean(arr[..., :3].astype(np.float32), axis=2)
            else:
                out = np.mean(arr.astype(np.float32), axis=0)
        else:
            raise ValueError(f"Unsupported array shape: {arr.shape}")

        if not np.isfinite(out).all():
            valid = out[np.isfinite(out)]
            fill = float(valid.mean()) if valid.size else 0.0
            out = np.nan_to_num(out, nan=fill, posinf=fill, neginf=fill)
        return out.astype(np.float32)

    # Processing pipeline
    def process_all(self):
        if self.raw_image is None:
            messagebox.showwarning("Warning", "Load an image first.")
            return
        try:
            self.cropped_image = self.get_cropped_image()
            self.flattened_image = self.apply_flattening(self.cropped_image)
            self.preprocessed_image = self.apply_preprocessing(self.flattened_image)
            self.label_image, self.threshold_values = self.compute_threshold_labels(self.preprocessed_image)
            if self.bp_enable_var.get():
                p = max(0, int(self.bp_min_region_size_var.get()))
                self.label_image = self.replace_small_regions_with_neighbors(self.label_image, p)
            self.group_percentages = self.compute_group_percentages(self.label_image)
            self.update_image_panels()
            self.update_histograms()
            groups = int(np.max(self.label_image)) + 1 if self.label_image is not None else 0
            self.status_var.set(f"Processed successfully | groups={groups} | thresholds={np.round(self.threshold_values, 5).tolist()}")
        except Exception as e:
            messagebox.showerror("Process Error", str(e))
            self.status_var.set("Processing failed")

    def reset_processing(self, keep_image=False):
        self.cropped_image = None
        self.flattened_image = None
        self.preprocessed_image = None
        self.label_image = None
        self.threshold_values = []
        self.group_percentages = []
        self.last_hist_raw = None
        self.last_hist_threshold = None
        self.last_raw_figure = None
        self.last_threshold_figure = None

        if not keep_image:
            self.raw_image = None
            self.filepath = None
            self.current_source_info = None
            self.current_afm_backend = None
            self.current_afm_metrics = {}
            self.raw_shape_var.set("Raw Shape: N/A")

        self.clear_canvas("raw")
        self.clear_canvas("threshold")
        self.clear_canvas("raw_hist")
        self.clear_canvas("threshold_hist")
        self.status_var.set("Ready")

    def clear_canvas(self, which):
        mapping = {
            "raw": "raw_canvas",
            "threshold": "threshold_canvas",
            "raw_hist": "raw_hist_canvas",
            "threshold_hist": "threshold_hist_canvas",
        }
        attr = mapping[which]
        obj = getattr(self, attr)
        if obj is not None:
            obj.get_tk_widget().destroy()
            setattr(self, attr, None)

    def get_cropped_image(self):
        img = self.raw_image
        if img is None:
            return None
        if not self.crop_enable_var.get():
            return img.copy()
        h, w = img.shape
        x = max(0, int(self.crop_x_var.get()))
        y = max(0, int(self.crop_y_var.get()))
        cw = max(1, int(self.crop_w_var.get()))
        ch = max(1, int(self.crop_h_var.get()))
        x = min(x, max(0, w - 1))
        y = min(y, max(0, h - 1))
        x2 = min(w, x + cw)
        y2 = min(h, y + ch)
        if x >= x2 or y >= y2:
            raise ValueError("Invalid crop range")
        return img[y:y2, x:x2].copy()


    def _selected_flatten_orders(self):
        return [order for order, var in enumerate(self.flatten_order_vars) if var.get()]

    def _fit_polynomial_surface(self, image, order):
        if order < 0:
            raise ValueError("Flattening order must be >= 0.")
        if order == 0:
            mean_val = float(np.nanmean(image.astype(np.float64)))
            return np.full_like(image, mean_val, dtype=np.float64)
        y_idx, x_idx = np.indices(image.shape, dtype=np.float64)
        x = x_idx.ravel()
        y = y_idx.ravel()
        z = image.astype(np.float64).ravel()
        finite = np.isfinite(z)
        x = x[finite]
        y = y[finite]
        z = z[finite]
        if z.size == 0:
            raise ValueError("Flattening failed: no finite pixels in image.")
        x0 = x.mean()
        y0 = y.mean()
        sx = max(np.abs(x - x0).max(), 1.0)
        sy = max(np.abs(y - y0).max(), 1.0)
        xn = (x - x0) / sx
        yn = (y - y0) / sy

        terms = []
        powers = []
        for total_degree in range(order + 1):
            for i in range(total_degree + 1):
                j = total_degree - i
                powers.append((i, j))
                terms.append((xn ** i) * (yn ** j))
        A = np.vstack(terms).T
        coeffs, *_ = np.linalg.lstsq(A, z, rcond=None)

        full_y, full_x = np.indices(image.shape, dtype=np.float64)
        full_xn = (full_x - x0) / sx
        full_yn = (full_y - y0) / sy
        surface = np.zeros_like(image, dtype=np.float64)
        for c, (i, j) in zip(coeffs, powers):
            surface += c * (full_xn ** i) * (full_yn ** j)
        return surface

    def _fit_line_polynomial(self, line, order):
        line = np.asarray(line, dtype=np.float64)
        if order < 0:
            raise ValueError("Flattening order must be >= 0.")
        finite = np.isfinite(line)
        if not np.any(finite):
            return np.full_like(line, np.nan, dtype=np.float64)
        if order == 0:
            mean_val = float(np.nanmean(line))
            return np.full_like(line, mean_val, dtype=np.float64)
        x = np.arange(line.size, dtype=np.float64)
        x_valid = x[finite]
        z_valid = line[finite]
        fit_order = min(int(order), max(0, x_valid.size - 1))
        if fit_order == 0:
            mean_val = float(np.nanmean(z_valid))
            return np.full_like(line, mean_val, dtype=np.float64)
        x0 = x_valid.mean()
        sx = max(np.abs(x_valid - x0).max(), 1.0)
        xn = (x_valid - x0) / sx
        coeffs = np.polyfit(xn, z_valid, deg=fit_order)
        full_xn = (x - x0) / sx
        return np.polyval(coeffs, full_xn)

    def _apply_single_flatten_order(self, image, order, mode="global"):
        img = image.astype(np.float64)
        if mode == "line":
            out = np.empty_like(img, dtype=np.float64)
            for r in range(img.shape[0]):
                surface = self._fit_line_polynomial(img[r, :], order)
                out[r, :] = img[r, :] - surface
            return out.astype(np.float32)
        surface = self._fit_polynomial_surface(img, order)
        return (img - surface).astype(np.float32)

    def apply_flattening(self, image):
        out = image.astype(np.float32).copy()
        orders = self._selected_flatten_orders()
        if not orders:
            return out
        mode = self.flatten_mode_var.get().strip().lower()
        mode = "line" if mode in {"line", "line-by-line", "line by line"} else "global"
        for order in sorted(set(orders)):
            out = self._apply_single_flatten_order(out, order, mode=mode)
        return out

    def apply_preprocessing(self, image):
        out = image.astype(np.float32).copy()
        raw_order = self.pp_order_var.get().strip()
        order = [x.strip().lower() for x in raw_order.split('>')] if raw_order else ["median", "gaussian", "tv", "wavelet"]
        aliases = {
            "median": "median",
            "gaussian": "gaussian",
            "total variation": "tv",
            "tv": "tv",
            "wavelet": "wavelet",
            "wavelet denoising": "wavelet",
        }
        for name in order:
            method = aliases.get(name.lower())
            if method == "median" and self.pp_median_var.get():
                ksize = max(1, int(self.pp_median_size_var.get()))
                if ksize % 2 == 0:
                    ksize += 1
                out = ndi.median_filter(out, size=ksize)
            elif method == "gaussian" and self.pp_gaussian_var.get():
                sigma = max(0.0, float(self.pp_gaussian_sigma_var.get()))
                out = gaussian(out, sigma=sigma, preserve_range=self.pp_gaussian_preserve_range_var.get()).astype(np.float32)
            elif method == "tv" and self.pp_tv_var.get():
                weight = max(1e-8, float(self.pp_tv_weight_var.get()))
                eps = max(1e-12, float(self.pp_tv_eps_var.get()))
                n_iter = max(1, int(self.pp_tv_max_num_iter_var.get()))
                out = denoise_tv_chambolle(out, weight=weight, eps=eps, max_num_iter=n_iter).astype(np.float32)
            elif method == "wavelet" and self.pp_wavelet_var.get():
                sigma = max(0.0, float(self.pp_wavelet_sigma_var.get()))
                wavelet_name = self.pp_wavelet_wavelet_var.get().strip() or "db2"
                mode_name = self.pp_wavelet_mode_var.get().strip() or "soft"
                out = denoise_wavelet(out, sigma=sigma, wavelet=wavelet_name, mode=mode_name, rescale_sigma=self.pp_wavelet_rescale_sigma_var.get(), channel_axis=None).astype(np.float32)
        return out

    def _parse_manual_thresholds(self):
        text = self.manual_thresholds_var.get().strip()
        if not text:
            return []
        parts = [p.strip() for p in text.replace(';', ',').split(',') if p.strip()]
        return sorted(float(p) for p in parts)

    def suggest_thresholds(self):
        if self.raw_image is None:
            messagebox.showinfo("Info", "Load an image first.")
            return
        try:
            img = self.get_cropped_image()
            img = self.apply_flattening(img)
            img = self.apply_preprocessing(img)
            thr = self.compute_auto_threshold_values(img)
            self.manual_thresholds_var.set(", ".join(f"{x:.6g}" for x in thr))
            self.status_var.set("Suggested thresholds updated in manual input field")
        except Exception as e:
            messagebox.showerror("Suggestion Error", str(e))

    def compute_auto_threshold_values(self, image):
        data = image.astype(np.float32)
        flat = data.reshape(-1, 1)
        count = max(1, int(self.threshold_count_var.get()))
        groups = count + 1
        method = self.threshold_method_var.get().strip().lower()

        if method == "otsu":
            return [float(threshold_otsu(data))]
        if method == "multi-otsu":
            return [float(x) for x in threshold_multiotsu(data, classes=groups)]
        if method == "k-means":
            km = KMeans(n_clusters=groups, random_state=int(self.kmeans_random_state_var.get()), n_init=max(1, int(self.kmeans_n_init_var.get())))
            km.fit(flat)
            centers = np.sort(km.cluster_centers_.flatten())
            return self._centers_to_thresholds(centers)
        if method == "gmm":
            gm = GaussianMixture(n_components=groups, covariance_type=self.gmm_covariance_type_var.get(), random_state=int(self.gmm_random_state_var.get()))
            gm.fit(flat)
            means = np.sort(gm.means_.flatten())
            return self._centers_to_thresholds(means)
        if method == "equal interval":
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            if p_high <= p_low:
                raise ValueError("Equal Interval: High percentile must be greater than low percentile.")
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            return [float(x) for x in np.linspace(low, high, groups + 1)[1:-1]]
        raise ValueError(f"Unknown threshold method: {self.threshold_method_var.get()}")

    def compute_threshold_labels(self, image):
        data = image.astype(np.float32)
        count = max(1, int(self.threshold_count_var.get()))
        if self.use_manual_thresholds_var.get():
            thr = self._parse_manual_thresholds()
            if not thr:
                raise ValueError("Manual thresholds are enabled, but no values were entered.")
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        thr = self.compute_auto_threshold_values(data)
        if self.threshold_method_var.get().strip().lower() == "otsu":
            labels = np.digitize(data, bins=thr).astype(np.int32)
            return labels, thr

        if len(thr) != count:
            raise ValueError(f"Threshold count mismatch: expected {count}, got {len(thr)}")
        labels = np.digitize(data, bins=thr).astype(np.int32)
        if self.threshold_method_var.get().strip().lower() == "equal interval":
            groups = len(thr) + 1
            p_low = float(self.equal_interval_percentile_low_var.get())
            p_high = float(self.equal_interval_percentile_high_var.get())
            low = float(np.percentile(data, p_low))
            high = float(np.percentile(data, p_high))
            labels[data < low] = 0
            labels[data >= high] = groups - 1
        return labels, thr

    def _centers_to_thresholds(self, centers_sorted):
        centers_sorted = np.asarray(centers_sorted, dtype=np.float32)
        if centers_sorted.size <= 1:
            return []
        mids = 0.5 * (centers_sorted[:-1] + centers_sorted[1:])
        return [float(x) for x in mids]

    def replace_small_regions_with_neighbors(self, label_img, max_region_size):
        out = label_img.copy()
        structure = np.ones((3, 3), dtype=np.uint8)
        unique_vals = np.unique(out)
        for val in unique_vals:
            mask = out == val
            cc, n_cc = ndi.label(mask, structure=structure)
            for idx in range(1, n_cc + 1):
                region_mask = cc == idx
                area = int(region_mask.sum())
                if area <= max_region_size:
                    dilated = ndi.binary_dilation(region_mask, structure=structure)
                    border = dilated & (~region_mask)
                    neighbor_vals = out[border]
                    neighbor_vals = neighbor_vals[neighbor_vals != val]
                    if neighbor_vals.size == 0:
                        continue
                    replacement = mode(neighbor_vals, keepdims=False).mode
                    out[region_mask] = int(replacement)
        return out.astype(np.int32)

    def compute_group_percentages(self, label_img):
        if label_img is None:
            return []
        labels = label_img.ravel().astype(np.int32)
        groups = int(labels.max()) + 1 if labels.size else 0
        counts = np.array([(labels == i).sum() for i in range(groups)], dtype=np.int64)
        total = max(1, int(counts.sum()))
        return [100.0 * c / total for c in counts]

