        size = max(200, int(self.display_size_var.get()))
        fig = Figure(figsize=(size / 100.0, size / 100.0), dpi=100)
        ax = fig.add_subplot(111)
        groups = int(np.max(self.label_image)) + 1
        vmax = max(1, groups - 1)
        cmap_name = self.threshold_colormap_var.get()
        im = ax.imshow(self.label_image, cmap=cmap_name, vmin=0, vmax=vmax, interpolation="nearest")

        if self.show_boundaries_var.get() and groups > 1:
            linewidth = max(0.1, float(self.boundary_thickness_var.get()))
            levels = np.arange(0.5, groups - 0.5 + 1e-9, 1.0)
            ax.contour(self.label_image, levels=levels, colors=self.boundary_color_var.get(), linewidths=linewidth)

