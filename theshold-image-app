        lines.append(f"Selected AFM channel: {self.selected_spm_channel_var.get() if self.selected_spm_channel_var.get() else 'N/A'}")
        lines.append(f"Data unit: {self.current_data_unit if self.current_data_unit else 'N/A'}")
        lines.append(f"Unit source: {self.current_unit_source if self.current_unit_source else 'N/A'}")
        lines.append(f"XY unit: {self.current_xy_unit if self.current_xy_unit else 'N/A'}")
        lines.append(f"XY source: {self.current_xy_source if self.current_xy_source else 'N/A'}")
