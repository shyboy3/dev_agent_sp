DEFAULT_STAGE_ORDER = ["input", "ui", "pipeline", "visualization", "export", "build"]


class SpecError(Exception):
    pass


def load_json(path: Path) -> Dict[str, Any]:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def sanitize_name(name: str) -> str:
    clean = re.sub(r"[^A-Za-z0-9_\-]+", "_", name.strip())
    return clean.strip("_") or "afm_agent"


def resolve_modules(spec: Dict[str, Any]) -> List[ModuleDef]:
    requested = spec.get("modules", [])
    if not requested:
        raise SpecError("Spec must include a non-empty 'modules' list.")

    resolved: List[ModuleDef] = []
    seen = set()

    def add_module(key: str) -> None:
        if key in seen:
            return
        if key not in AFM_MODULE_REGISTRY:
            raise SpecError(f"Unknown module: {key}")
        module = AFM_MODULE_REGISTRY[key]
        for dep in module.requires:
            add_module(dep)
        resolved.append(module)
        seen.add(key)

    for item in requested:
        add_module(item)

    order = {stage: i for i, stage in enumerate(DEFAULT_STAGE_ORDER)}
    resolved.sort(key=lambda m: (order.get(m.stage, 999), m.key))
    return resolved


def validate_spec(spec: Dict[str, Any]) -> None:
    if spec.get("domain") != "AFM":
        raise SpecError("This builder currently supports only domain='AFM'.")
    if spec.get("interpretation", {}).get("enabled", False):
        raise SpecError("AFM builder v1 supports processing-only agents. Set interpretation.enabled = false.")
    if spec.get("goal") not in {"processing_only", None}:
        raise SpecError("AFM builder goal must be 'processing_only'.")


def merged_params(spec: Dict[str, Any], modules: List[ModuleDef]) -> Dict[str, Dict[str, Any]]:
    params_override = spec.get("module_params", {})
    out: Dict[str, Dict[str, Any]] = {}
    for module in modules:
        merged = dict(module.params)
        merged.update(params_override.get(module.key, {}))
        out[module.key] = merged
    return out


def generate_runtime_stub() -> str:
    return '''from __future__ import annotations

from dataclasses import dataclass
from typing import Any, Dict, List


@dataclass
class Context:
    spec: Dict[str, Any]
    state: Dict[str, Any]


class BaseModule:
    key = "base"

    def __init__(self, params: Dict[str, Any] | None = None):
        self.params = params or {}

    def process(self, ctx: Context) -> Context:
        return ctx


class Pipeline:
    def __init__(self, modules: List[BaseModule]):
        self.modules = modules

    def run(self, ctx: Context) -> Context:
        for module in self.modules:
            ctx = module.process(ctx)
        return ctx
'''


def generate_generated_agent_py(spec: Dict[str, Any], modules: List[ModuleDef], params: Dict[str, Dict[str, Any]]) -> str:
    module_lines = []
    class_defs = []
    instance_lines = []
    for module in modules:
        cls_name = ''.join(part.capitalize() for part in re.split(r'[^A-Za-z0-9]+', module.key)) + 'Module'
        class_defs.append(f'''\nclass {cls_name}(BaseModule):\n    key = "{module.key}"\n\n    def process(self, ctx: Context) -> Context:\n        ctx.state.setdefault("execution_log", []).append({{"module": self.key, "params": self.params}})\n        return ctx\n''')
        instance_lines.append(f'        {cls_name}(params["{module.key}"]),')

    module_lines.append("\n".join(class_defs))
    params_json = json.dumps(params, indent=2)
    spec_json = json.dumps(spec, indent=2)
    return f'''from __future__ import annotations

import json
from pathlib import Path

from runtime_stub import BaseModule, Context, Pipeline
{''.join(module_lines)}

SPEC = {spec_json}
PARAMS = {params_json}


def build_pipeline() -> Pipeline:
    params = PARAMS
    return Pipeline([
{chr(10).join(instance_lines)}
    ])


def run_agent(input_payload: dict | None = None) -> dict:
    ctx = Context(spec=SPEC, state={{"input": input_payload or {{}}}})
    pipeline = build_pipeline()
    ctx = pipeline.run(ctx)
    return ctx.state


if __name__ == "__main__":
    result = run_agent({{"note": "scaffold run"}})
    out = Path("agent_run_output.json")
    out.write_text(json.dumps(result, indent=2), encoding="utf-8")
    print(f"Wrote {{out}}")
'''


def generate_readme(spec: Dict[str, Any], modules: List[ModuleDef], params: Dict[str, Dict[str, Any]]) -> str:
    lines = []
    lines.append(f"# Generated AFM Agent: {spec['agent_name']}")
    lines.append("")
    lines.append("## Summary")
    lines.append(f"- Domain: {spec.get('domain')}")
    lines.append(f"- Goal: {spec.get('goal', 'processing_only')}")
    lines.append(f"- UI: {spec.get('ui_framework', 'tkinter')}")
    lines.append("")
    lines.append("## Modules")
    for module in modules:
        lines.append(f"- `{module.key}` — {module.description}")
    lines.append("")
    lines.append("## Resolved Parameters")
    for key, val in params.items():
        lines.append(f"- `{key}`: `{json.dumps(val, ensure_ascii=False)}`")
    lines.append("")
    lines.append("## Notes")
    lines.append("This output is a scaffolded AFM processing agent. The runtime pipeline is generated and logged, but scientific module implementations should be connected to your validated AFM processing library or existing V18.1 codebase.")
    lines.append("Recommended next step: replace the generated scaffold modules with production implementations from your AFM toolkit, then add GUI or batch execution entrypoints as needed.")
    return "\n".join(lines)


def write_builder_report(out_dir: Path, spec: Dict[str, Any], modules: List[ModuleDef], params: Dict[str, Dict[str, Any]]) -> None:
    report = {
        "agent_name": spec["agent_name"],
        "domain": spec["domain"],
        "goal": spec.get("goal", "processing_only"),
        "module_count": len(modules),
        "modules": [asdict(m) for m in modules],
        "resolved_params": params,
    }
    (out_dir / "builder_report.json").write_text(json.dumps(report, indent=2), encoding="utf-8")


def build_agent(spec_path: Path, output_root: Path) -> Path:
    spec = load_json(spec_path)
    validate_spec(spec)

    spec.setdefault("goal", "processing_only")
    spec.setdefault("ui_framework", "tkinter")
    spec["agent_name"] = sanitize_name(spec.get("agent_name", spec_path.stem))

    modules = resolve_modules(spec)
    params = merged_params(spec, modules)

    out_dir = output_root / spec["agent_name"]
    out_dir.mkdir(parents=True, exist_ok=True)

    (out_dir / "resolved_spec.json").write_text(json.dumps(spec, indent=2), encoding="utf-8")
    (out_dir / "runtime_stub.py").write_text(generate_runtime_stub(), encoding="utf-8")
    (out_dir / "generated_agent.py").write_text(generate_generated_agent_py(spec, modules, params), encoding="utf-8")
    (out_dir / "README_generated.md").write_text(generate_readme(spec, modules, params), encoding="utf-8")
    write_builder_report(out_dir, spec, modules, params)
    return out_dir


def main() -> None:
    parser = argparse.ArgumentParser(description="AFM processing agent builder")
    parser.add_argument("--spec", required=True, help="Path to AFM agent JSON spec")
    parser.add_argument("--out", default="generated_agents", help="Output directory")
    args = parser.parse_args()

    out_dir = build_agent(Path(args.spec), Path(args.out))
    print(f"Generated AFM agent scaffold at: {out_dir}")


if __name__ == "__main__":
    main()





