import streamlit as st
import json
import os
import datetime

# Graphviz 경로 설정
os.environ["PATH"] += os.pathsep + r'C:\Program Files\Graphviz\bin'

DB_FILE = "integrated_agent_data.json"
CLASSES = ["표면분석", "구조분석", "성분분석", "물성측정"]

# --- 1. 데이터 로드 및 마이그레이션 (호환성 유지) ---
def load_data():
    if os.path.exists(DB_FILE):
        try:
            with open(DB_FILE, "r", encoding="utf-8") as f:
                data = json.load(f)
                for cls in CLASSES:
                    if cls not in data: data[cls] = {}
                    for g in data[cls]:
                        for i in list(data[cls][g].keys()):
                            # 구버전(문자열) 데이터를 신규 객체 구조로 변환
                            if not isinstance(data[cls][g][i], dict):
                                data[cls][g][i] = {"features": str(data[cls][g][i]), "workflows": {}}
                            if "workflows" not in data[cls][g][i]:
                                data[cls][g][i]["workflows"] = {}
                return data
        except:
            return {cls: {} for cls in CLASSES}
    return {cls: {} for cls in CLASSES}

def save_data(data):
    with open(DB_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

# --- 2. 시각화 엔진 (메인 트리 & 워크플로우) ---
def generate_main_tree(selected_cls, data):
    dot = [
        'digraph G { rankdir=LR; splines=ortho; nodesep=0.5; ranksep=1.0; fontname="Malgun Gothic";',
        'node [fontname="Malgun Gothic", fontsize=10, style=filled];',
        'edge [fontname="Malgun Gothic", arrowhead=vee, color="#7f8c8d"];'
    ]
    dot.append(f'  "root" [label="{selected_cls}", shape=box, color="#1e3a8a", fontcolor=white];')
    for n_name, m_dict in data.items():
        n_id = f"n_{hash(n_name)}"
        dot.append(f'  "{n_id}" [label="{n_name}", shape=parallelogram, color="#3b82f6", fontcolor=white];')
        dot.append(f'  "root" -> "{n_id}":w;')
        for m_name, m_data in m_dict.items():
            m_id = f"m_{hash(n_name + m_name)}"
            dot.append(f'  "{m_id}" [label="{m_name}", shape=component, color="#10b981", fontcolor=white];')
            dot.append(f'  "{n_id}" -> "{m_id}":w;')
            # 특징 표시
            feats = [f.strip() for f in m_data.get("features", "").replace('\n',';').split(';') if f.strip()]
            for idx, feat in enumerate(feats):
                f_id = f"f_{m_id}_{idx}"
                has_wf = len(m_data.get("workflows", {}).get(feat, [])) > 0
                color = "#e67e22" if has_wf else "#f39c12"
                dot.append(f'  "{f_id}" [label="{feat}", shape=note, color="{color}", fontcolor=white];')
                dot.append(f'  "{m_id}" -> "{f_id}":w [style=dashed];')
    dot.append('}')
    return "\n".join(dot)

def generate_wf_viz(steps):
    dot = ['digraph W { rankdir=TB; fontname="Malgun Gothic"; node [fontname="Malgun Gothic", shape=record, style=filled];']
    dot.append('  start [label="START", shape=ellipse, color="#2ecc71", fontcolor=white];')
    if steps:
        for s in steps:
            s_id = f"s{s['id']}"
            tasks = "<br/>".join([f"- {t}" for t in s['tasks']])
            label = f"{{Step {s['id']}: {s['name']} | {tasks} | Agent: {s['agent']}}}"
            dot.append(f'  {s_id} [label=<{label}>, color="#9b59b6", fontcolor=white];')
        dot.append(f'  start -> s{steps[0]["id"]};')
        for s in steps:
            if s.get('next_id'): dot.append(f'  s{s["id"]} -> s{s["next_id"]} [label="ok", color=green];')
            else: dot.append(f'  s{s["id"]} -> end [color=green];')
            if s.get('fail_id'): dot.append(f'  s{s["id"]} -> s{s["fail_id"]} [label="fail", color=red, style=dashed];')
    dot.append('  end [label="END", shape=ellipse, color="#e74c3c", fontcolor=white];')
    dot.append('}')
    return "\n".join(dot)

# --- 3. 메인 앱 로직 ---
def main():
    st.set_page_config(page_title="Agent Architecture Master", layout="wide")
    if 'master_data' not in st.session_state:
        st.session_state.master_data = load_data()

    st.title("🏗️ Integrated Agent Orchestration Designer")
    selected_cls = st.sidebar.selectbox("분석 클래스 선택", CLASSES)
