    sel_m = col_sel2.selectbox("아이템", list(current_data[sel_n].keys())) if sel_n else None
    
    if sel_m:
        feats = [f.strip() for f in current_data[sel_n][sel_m].get("features", "").replace('\n',';').split(';') if f.strip()]
        sel_f = col_sel3.selectbox("특징(Feature)", feats) if feats else None
        
        if sel_f:
            st.divider()
            if "workflows" not in current_data[sel_n][sel_m]:
                st.session_state.master_data[selected_cls][sel_n][sel_m]["workflows"] = {}
            
            wf_data = st.session_state.master_data[selected_cls][sel_n][sel_m]["workflows"].get(sel_f, [])
            
            # --- 워크플로우 설계 편집기 ---
            col_edit, col_view = st.columns([1, 1.2])
            
            with col_edit:
                st.subheader("🛠️ 스텝 정의 (ID 기반)")
                with st.form("step_form"):
                    s_id = st.number_input("Step ID (고유번호)", min_value=1, value=len(wf_data)+1)
                    s_name = st.text_input("스텝 명칭", placeholder="데이터 정제 등")
                    s_tasks = st.text_area("수행 항목들 (여러 개일 경우 엔터로 구분)", height=100)
                    s_agent = st.text_input("담당 에이전트")
                    
                    st.write("🔗 연결 로직")
                    c1, c2 = st.columns(2)
                    next_id = c1.number_input("성공 시 다음 ID (0은 종료)", min_value=0, value=0)
                    fail_id = c2.number_input("실패 시 복귀 ID (0은 무시)", min_value=0, value=0)
                    
                    if st.form_submit_button("➕ 스텝 저장/수정"):
                        # 기존 ID가 있으면 업데이트, 없으면 추가
                        task_list = [t.strip() for t in s_tasks.split('\n') if t.strip()]
