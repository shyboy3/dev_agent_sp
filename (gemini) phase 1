from graphviz import Digraph

def generate_wf_viz(steps):
    dot = Digraph(engine='dot')
    dot.attr(rankdir='TB', splines='polyline', nodesep='0.4', ranksep='0.6')
    dot.attr('node', fontname='Malgun Gothic', fontsize='11')
    dot.attr('edge', fontname='Malgun Gothic', fontsize='9')
    
    # START 노드
    dot.node('start', label='START', shape='ellipse', style='filled', fillcolor='#2ecc71', fontcolor='white')
    
    step_ids = [str(s['id']) for s in steps]
    
    # =========================================================
    # 1. 진짜 시작 노드 판별 로직 (아무도 나를 지목하지 않은 노드 찾기)
    # =========================================================
    has_incoming = {sid: False for sid in step_ids}
    
    for s in steps:
        s_id = str(s['id'])
        
        # 내가 부모를 명시했다면, 나는 부모로부터 선을 받는 것임
        if s.get('parent_id') and str(s['parent_id']) in step_ids:
            has_incoming[s_id] = True
            
        # 누군가 나를 next_id로 지목했다면
        next_id = str(s.get('next_id', ''))
        if next_id in step_ids:
            has_incoming[next_id] = True
            
        # 누군가 나를 fail_id로 지목했다면
        fail_id = str(s.get('fail_id', ''))
        if fail_id in step_ids:
            has_incoming[fail_id] = True

    # =========================================================
    # 2. 노드 그리기 및 START 연결
    # =========================================================
    for s in steps:
        s_id = str(s['id'])
        label_text = f"Step {s_id}: {s['name']}\n(Agent: {s['agent']})"
        
        style_str = s.get('style', '')
        if style_str:
            node_attrs = parse_drawio_style(style_str)
        else:
            node_attrs = {'shape': 'box', 'style': 'filled', 'fillcolor': '#9b59b6', 'fontcolor': 'white'}
            
        node_attrs['label'] = label_text
        dot.node(s_id, **node_attrs)
        
        # '진짜 시작 노드'인 경우에만 START와 연결
        if not has_incoming[s_id]:
            # 단, drawio의 시스템 레이어(0, 1) 같은 보이지 않는 그룹은 연결 제외
            d_parent = str(s.get('drawio_parent', ''))
            if not d_parent or d_parent not in ['0', '1']:
                dot.edge('start', s_id)

    # =========================================================
    # 3. 간선 그리기 (중복 방지 및 초록/빨강 선 통일)
    # =========================================================
    all_edges = set() 

    for s in steps:
        curr_id = str(s['id'])
        
        parent_id = str(s.get('parent_id', ''))
        if parent_id and parent_id in step_ids:
            if (parent_id, curr_id) not in all_edges:
                dot.edge(parent_id, curr_id, color='green', label='ok')
                all_edges.add((parent_id, curr_id))

        next_id = str(s.get('next_id', ''))
        if next_id and next_id in step_ids:
            if (curr_id, next_id) not in all_edges:
                dot.edge(curr_id, next_id, color='green', label='ok')
                all_edges.add((curr_id, next_id))

        fail_id = str(s.get('fail_id', ''))
        if fail_id and fail_id in step_ids:
            if (curr_id, fail_id) not in all_edges:
                dot.edge(curr_id, fail_id, color='red', style='dashed', label='fail')
                all_edges.add((curr_id, fail_id))

    # draw.io 그룹핑 간선 처리 (회색 점선)
    for s in steps:
        curr_id = str(s['id'])
        d_parent = str(s.get('drawio_parent', ''))
        
        if d_parent and d_parent in step_ids and d_parent != curr_id:
            if (d_parent, curr_id) not in all_edges and (curr_id, d_parent) not in all_edges:
                dot.edge(d_parent, curr_id, style='dashed', color='gray', label='')

    return dot







