import xmltodict
import re
import base64
import zlib
from urllib.parse import unquote

def clean_html(raw_html):
    if not raw_html: return ""
    clean_text = re.sub(r'<br\s*/?>|</div>|</p>', '\n', str(raw_html))
    return re.sub(r'<[^>]+>', '', clean_text).strip()

def decode_drawio_diagram(xml_string):
    """draw.io의 압축된 다이어그램 문자열을 해독합니다."""
    try:
        data = xmltodict.parse(xml_string)
        diagram = data['mxfile']['diagram']
        
        # 압축되어 있는 경우 해독
        if isinstance(diagram, dict) and '#text' in diagram:
            b64_data = diagram['#text']
            decoded = base64.b64decode(b64_data)
            decompressed = zlib.decompress(decoded, -15)
            xml_string = unquote(decompressed.decode('utf-8'))
            # 해독된 내용을 다시 최상위 <mxGraphModel>로 감싸서 반환
            return xmltodict.parse(f"<root>{xml_string}</root>")['root']
        else:
            return data['mxfile']['diagram']['mxGraphModel']
    except Exception as e:
        return None

def drawio_to_wf_dict(xml_content):
    """draw.io XML을 프로그램 내부의 워크플로우 dict 형태로 변환합니다."""
    graph_model = decode_drawio_diagram(xml_content)
    if not graph_model: return None

    try:
        cells = graph_model['root']['mxCell']
        if isinstance(cells, dict): cells = [cells] # 노드가 1개일 경우 리스트로 강제 변환
    except KeyError:
        return None

    wf_dict = {}
    
    # 1. 노드(Vertex) 먼저 수집
    for cell in cells:
        if cell.get('@vertex') == '1':
            node_id = cell.get('@id')
            name = clean_html(cell.get('@value', '')) or f"Step_{node_id}"
            
            wf_dict[node_id] = {
                "id": node_id,
                "name": name,
                "agent": "Auto",     # 기본 에이전트명 할당
                "task": "draw.io에서 임포트됨",
                "parent": "",
                "next": "",
                "fail": ""
            }

    # 2. 연결선(Edge)을 바탕으로 parent, next, fail 매핑
    for cell in cells:
        if cell.get('@edge') == '1':
            source = cell.get('@source')
            target = cell.get('@target')
            label = clean_html(cell.get('@value', '')).lower()
            
            if source in wf_dict and target in wf_dict:
                wf_dict[target]['parent'] = source
                # 라벨에 fail, 실패, no 등이 들어가면 실패 분기로 처리
                if any(x in label for x in ['fail', '실패', 'no', '아니오']):
                    wf_dict[source]['fail'] = target
                else:
                    wf_dict[source]['next'] = target

    return wf_dict



