    return dot



def parse_drawio_style(style_str):
    """
    draw.io의 style 문자열을 Graphviz(Viz.js)가 이해하는 dict로 변환합니다.
    """
    # 기본 스타일
    attrs = {
        'shape': 'box', 
        'style': 'filled', 
        'fillcolor': '#ffffff', 
        'fontcolor': 'black'
    }
    
    if not style_str:
        return attrs

    # 스타일 문자열 파싱 (예: "rounded=1;fillColor=#dae8fe;shape=rhombus;")
    style_map = {}
    for part in style_str.split(';'):
        if '=' in part:
            k, v = part.split('=')
            style_map[k.strip()] = v.strip()
        elif part.strip():
            style_map[part.strip()] = True

    # 1. 도형 모양 (Shape) 매핑
    drawio_shape = style_map.get('shape', '')
    shape_map = {
        'rhombus': 'diamond',
        'ellipse': 'ellipse',
        'parallelogram': 'parallelogram',
        'hexagon': 'hexagon',
        'trapezoid': 'trapezoid',
        'step': 'component',
        'process': 'box'
    }
    attrs['shape'] = shape_map.get(drawio_shape, 'box')

    # 2. 둥근 모서리 처리 (rounded=1)
    if style_map.get('rounded') == '1':
        attrs['style'] = 'filled, rounded'

    # 3. 배경색 (fillColor)
    f_color = style_map.get('fillColor')
    if f_color and f_color != 'none':
        attrs['fillcolor'] = f_color
        # 배경이 너무 어두우면 글자색을 흰색으로 (간단한 로직)
        if f_color.startswith('#') and len(f_color) == 7:
            # 어두운 색인지 대략 판단 (R+G+B 합이 낮으면 어두움)
            r, g, b = int(f_color[1:3], 16), int(f_color[3:5], 16), int(f_color[5:7], 16)
            if (r + g + b) < 300:
                attrs['fontcolor'] = 'white'

    return attrs



    # generate_wf_viz 함수 내부의 노드 반복문 부분
    for s in steps:
        s_id = str(s['id'])
        label_text = f"Step {s_id}: {s['name']}\n(Agent: {s['agent']})"
        
        # 스타일 적용
        style_str = s.get('style', '')
        node_attrs = parse_drawio_style(style_str)
        node_attrs['label'] = label_text # 라벨 추가
        
        # ⭐ 중요: node_attrs에 담긴 모든 속성(shape, style, fillcolor 등)을 주입
        dot.node(s_id, **node_attrs)




