def drawio_to_wf_dict(xml_content):
    """draw.io XML을 프로그램 내부의 워크플로우 dict 형태로 변환합니다."""
    graph_model = decode_drawio_diagram(xml_content)
    if not graph_model: return None

    try:
        cells = graph_model['root']['mxCell']
        if isinstance(cells, dict): cells = [cells] # 노드가 1개일 경우 리스트로 강제 변환
    except KeyError:
        return None

    wf_dict = {}
    
    # 1. 노드(Vertex) 먼저 수집
    for cell in cells:
        if cell.get('@vertex') == '1':
            node_id = cell.get('@id')
            name = clean_html(cell.get('@value', '')) or f"Step_{node_id}"
            
            wf_dict[node_id] = {
                "id": node_id,
                "name": name,
                "agent": "Auto",     
                "task": "draw.io에서 임포트됨",
                "parent": "",
                "next": "",
                "fail": "",
                # ==========================================
                # [수정된 부분] Q1, Q2를 위한 정보 추가 추출
                # ==========================================
                "style": cell.get('@style', ''),          # [Q1] 도형 및 색상 정보
                "drawio_parent": cell.get('@parent', '')  # [Q2] draw.io 상의 구조적 부모 (간선 중복 해결용)
            }

    # 2. 연결선(Edge)을 바탕으로 parent, next, fail 매핑
    for cell in cells:
        if cell.get('@edge') == '1':
            source = cell.get('@source')
            target = cell.get('@target')
            label = clean_html(cell.get('@value', '')).lower()
            
            if source in wf_dict and target in wf_dict:
                wf_dict[target]['parent'] = source
                # 라벨에 fail, 실패, no 등이 들어가면 실패 분기로 처리
                if any(x in label for x in ['fail', '실패', 'no', '아니오']):
                    wf_dict[source]['fail'] = target
                else:
                    wf_dict[source]['next'] = target

    return wf_dict



from graphviz import Digraph

def create_integrated_svg_chart_from_dict(wf_dict, output_filename):
    """wf_dict 데이터를 바탕으로 도형과 연결선이 최적화된 SVG를 생성합니다."""
    dot = Digraph(format='svg', engine='dot')
    dot.attr('node', fontname='Malgun Gothic')
    dot.attr('edge', fontname='Malgun Gothic')

    all_edges = [] # 중복 체크용 간선 리스트 [{'source': x, 'target': y}]

    # 1. 노드 그리기 (Q1 도형 정보 반영)
    for node_id, node_info in wf_dict.items():
        node_label = node_info.get('name', '')
        
        # 앞서 만든 parse_drawio_style을 이용해 문자열을 Graphviz 속성으로 바꿉니다.
        node_attrs = parse_drawio_style(node_info.get('style', ''))
        node_attrs['label'] = node_label
        
        dot.node(node_id, **node_attrs)

    # 2. 명시적 연결선 그리기 (next, fail을 바탕으로)
    for node_id, node_info in wf_dict.items():
        # 성공/다음(next) 간선
        next_id = node_info.get('next')
        if next_id and next_id in wf_dict:
            all_edges.append({'source': node_id, 'target': next_id})
            dot.edge(node_id, next_id, label='') 
            
        # 실패(fail) 간선 (시각적 구분을 위해 빨간색 지정)
        fail_id = node_info.get('fail')
        if fail_id and fail_id in wf_dict:
            all_edges.append({'source': node_id, 'target': fail_id})
            dot.edge(node_id, fail_id, label='Fail', color='red', fontcolor='red')

    # 3. 구조적 부모-자식 관계 그리기 (Q2 선 누락/중복 해결)
    for node_id, node_info in wf_dict.items():
        d_parent = node_info.get('drawio_parent')
        
        # 부모가 유효한 노드(0, 1번 레이어가 아님)이고 자기 자신이 아닐 때
        if d_parent and d_parent in wf_dict and d_parent != node_id:
            # 이미 next나 fail로 연결된 선이 있는지 중복 체크
            edge_exists = any(e['source'] == d_parent and e['target'] == node_id for e in all_edges)
            
            # 명시적 선(Edge)이 없을 때만 부모 관계를 선으로 이어줌 (점선으로 차별화)
            if not edge_exists:
                dot.edge(d_parent, node_id, label='', style='dashed', color='gray')

    # SVG 파일로 렌더링
    dot.render(output_filename, cleanup=True, view=False)
    print(f"--- SVG 차트 생성 완료: {output_filename}.svg ---")










import xmltodict
import re
import os
from graphviz import Digraph

# --- 설정 및 매핑 데이터 ---

# 1. draw.io 도형 스타일 -> Graphviz shape 매핑
DRAWIO_SHAPE_MAP = {
    # 모양(shape)에 따른 매핑
    'ellipse': 'ellipse',
    'rhombus': 'diamond',
    'rounded': 'box', # rounded는 box에 style=rounded를 추가해야 함
    'trapezoid': 'trapezoid',
    'parallelogram': 'parallelogram',
    'hex': 'hexagon',
    'cloud': 'egg', # cloud는 유사한 모양으로 매핑
    # 추가적인 매핑은 필요에 따라 확장
}

# 2. 시스템 기본 ID (제외 대상)
SYSTEM_PARENTS = ['0', '1', '2', 'defaultLayer']

# --- 핵심 함수들 ---

def clean_html(raw_html):
    if not raw_html:
        return ""
    # 간단한 태그 제거 및 텍스트 정제
    clean_text = re.sub(r'<[^>]+>', ' ', str(raw_html))
    return clean_text.strip()

def parse_drawio_style(style_str):
    """
    draw.io의 style 문자열을 파싱하여 Graphviz 속성을 추출합니다.
    """
    style_data = {}
    graphviz_attrs = {'style': 'filled', 'fillcolor': '#ffffff'} # 기본 스타일
    
    if not style_str:
        return graphviz_attrs
        
    # 스타일 문자열을 딕셔너리로 변환
    pairs = style_str.split(';')
    for pair in pairs:
        if '=' in pair:
            key, value = pair.split('=')
            style_data[key.strip()] = value.strip()
        else:
            style_data[pair.strip()] = True

    # 1. 모양(shape) 처리
    drawio_shape = style_data.get('shape')
    gv_shape = DRAWIO_SHAPE_MAP.get(drawio_shape, 'box') # 매핑 실패 시 기본값 box
    graphviz_attrs['shape'] = gv_shape

    # 2. rounded 처리 (box 모양일 때만 의미 있음)
    if style_data.get('rounded') == '1':
        graphviz_attrs['style'] += ', rounded'

    # 3. 색상(fillColor) 처리
    fill_color = style_data.get('fillColor')
    if fill_color and fill_color != 'none':
        graphviz_attrs['fillcolor'] = fill_color

    return graphviz_attrs

def create_integrated_svg_chart(diagram_xml_path, output_filename):
    """
    XML 파일을 읽어 노드 모양과 parent 관계가 통합된 SVG 차트를 생성합니다.
    """
    # 1. XML 파싱
    with open(diagram_xml_path, 'r', encoding='utf-8') as f:
        data = xmltodict.parse(f.read())

    # 엔진 및 폰트 설정
    dot = Digraph(format='svg', engine='dot')
    dot.attr('node', fontname='Malgun Gothic') # Windows 한글 폰트
    dot.attr('edge', fontname='Malgun Gothic')

    # 셀 데이터 리스트 가져오기 (구조에 따라 확인 필요)
    try:
        cells = data['mxfile']['diagram']['mxGraphModel']['root']['mxCell']
    except (KeyError, TypeError):
        cells = []

    # --- 통합 데이터 수집 ---
    
    all_nodes = {}
    all_edges = [] # [{'source', 'target', 'label'}] 형태

    for cell in cells:
        cell_id = str(cell.get('@id'))
        
        # 1. 노드 수집 (Q1 도형 정보 포함)
        if cell.get('@vertex') == '1' and cell_id not in SYSTEM_PARENTS:
            raw_value = cell.get('@value', '')
            node_label = clean_html(raw_value) or f"Node_{cell_id}"
            
            # 스타일 분석 및 반영
            style_str = cell.get('@style')
            node_attrs = parse_drawio_style(style_str)
            node_attrs['label'] = node_label
            
            all_nodes[cell_id] = node_attrs

        # 2. 엣지 수집 (검토 내용 반영: parent 관계 통합)
        if cell.get('@edge') == '1':
            source_id = str(cell.get('@source'))
            target_id = str(cell.get('@target'))
            edge_label = clean_html(cell.get('@value', ''))
            
            # 유효한 연결선만 추가
            if source_id != 'None' and target_id != 'None' and source_id not in SYSTEM_PARENTS and target_id not in SYSTEM_PARENTS:
                all_edges.append({
                    'source': source_id,
                    'target': target_id,
                    'label': edge_label
                })

    # 3. parent 관계 기반 엣지 추가 (검토 내용 반영)
    # 노드 ID를 순회하며 0, 1을 제외한 유효한 parent를 가진 경우 연결선 생성
    for node_id, node_data in all_nodes.items():
        # 원본 cell 데이터를 다시 찾아서 parent 정보 확인
        original_cell = next((c for c in cells if str(c.get('@id')) == node_id), None)
        parent_id = str(original_cell.get('@parent')) if original_cell else None
        
        # 유효한 parent이고, 이미 연결선이 정의되지 않은 경우에만 추가
        if parent_id and parent_id not in SYSTEM_PARENTS and parent_id != node_id:
            # 중복 체크 (방향성 고려)
            edge_exists = any(
                (e['source'] == parent_id and e['target'] == node_id) for e in all_edges
            )
            if not edge_exists:
                all_edges.append({
                    'source': parent_id,
                    'target': node_id,
                    'label': '' # parent 관계는 기본적으로 라벨 없음
                })

    # --- Graphviz 렌더링 ---

    # 노드 추가
    for node_id, node_attrs in all_nodes.items():
        # node_id를 넘기고 나머지 속성을 unpacking (**node_attrs)
        dot.node(node_id, **node_attrs)

    # 통합된 엣지 추가
    for edge in all_edges:
        # parent 관계는 label이 비어있어서 기본값 'OK'가 아닌 깔끔한 선으로 그려짐
        dot.edge(edge['source'], edge['target'], label=edge['label'])

    # 최종 출력
    dot.render(output_filename, cleanup=True, view=True)
    print(f"--- 통합 SVG 차트 생성 완료: {output_filename}.svg ---")

