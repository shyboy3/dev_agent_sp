import torch
import torch.nn as nn

class ResidualBlock(nn.Module):
    def __init__(self, in_channels, out_channels, stride=1, dropout_p=0.15):
        super(ResidualBlock, self).__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, kernel_size=3, padding=1, stride=stride),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, stride=1),
            # BatchNorm 없이 원본의 질감을 보존
        )
        self.dropout = nn.Dropout2d(p=dropout_p)
        self.shortcut = nn.Sequential()
        # 차원이 맞지 않을 때를 대비한 숏컷
        if stride != 1 or in_channels != out_channels:
            self.shortcut = nn.Sequential(
                nn.Conv2d(in_channels, out_channels, kernel_size=1, stride=stride)
            )

    def forward(self, x):
        out = self.conv(x)
        out = self.dropout(out)
        return nn.functional.relu(out + self.shortcut(x))


class ResUNet_Deep(nn.Module):
    def __init__(self, filters=64):
        super(ResUNet_Deep, self).__init__()
        
        # --- Encoder (Down-sampling): BN 미사용 ---
        self.enc1 = ResidualBlock(1, filters)
        self.enc2 = ResidualBlock(filters, filters*2, stride=2)
        self.enc3 = ResidualBlock(filters*2, filters*4, stride=2)
        self.enc4 = ResidualBlock(filters*4, filters*8, stride=2)
        
        self.pool = nn.MaxPool2d(2)
        self.bridge = ResidualBlock(filters*8, filters*16, stride=2)
        
        # --- Decoder (Up-sampling): BN 사용으로 잡음 억제 ---
        self.up4 = nn.ConvTranspose2d(filters*16, filters*8, kernel_size=2, stride=2)
        self.dec4 = nn.Sequential(
            nn.Conv2d(filters*16, filters*8, kernel_size=3, padding=1),
            nn.BatchNorm2d(filters*8),
            nn.ReLU(inplace=True)
        )
        
        self.up3 = nn.ConvTranspose2d(filters*8, filters*4, kernel_size=2, stride=2)
        self.dec3 = nn.Sequential(
            nn.Conv2d(filters*8, filters*4, kernel_size=3, padding=1),
            nn.BatchNorm2d(filters*4),
            nn.ReLU(inplace=True)
        )
        
        self.up2 = nn.ConvTranspose2d(filters*4, filters*2, kernel_size=2, stride=2)
        self.dec2 = nn.Sequential(
            nn.Conv2d(filters*4, filters*2, kernel_size=3, padding=1),
            nn.BatchNorm2d(filters*2),
            nn.ReLU(inplace=True)
        )
        
        self.up1 = nn.ConvTranspose2d(filters*2, filters, kernel_size=2, stride=2)
        self.dec1 = nn.Sequential(
            nn.Conv2d(filters*2, filters, kernel_size=3, padding=1),
            nn.BatchNorm2d(filters),
            nn.ReLU(inplace=True)
        )
        
        # 최종 출력 레이어 직전 정규화로 배경 잡음 최종 억제
        self.final_bn = nn.BatchNorm2d(filters)
        self.final_conv = nn.Conv2d(filters, 1, kernel_size=1)

    def forward(self, x):
        # Encoder
        s1 = self.enc1(x)
        s2 = self.enc2(s1)
        s3 = self.enc3(s2)
        s4 = self.enc4(s3)
        
        # Bridge
        b = self.bridge(s4)
        
        # Decoder (Skip connection 결합 후 BN 처리된 Sequential 통과)
        d4 = self.up4(b)
        d4 = self.dec4(torch.cat([d4, s4], dim=1))
        
        d3 = self.up3(d4)
        d3 = self.dec3(torch.cat([d3, s3], dim=1))
        
        d2 = self.up2(d3)
        d2 = self.dec2(torch.cat([d2, s2], dim=1))
        
        d1 = self.up1(d2)
        d1 = self.dec1(torch.cat([d1, s1], dim=1))
        
        return self.final_conv(self.final_bn(d1))



