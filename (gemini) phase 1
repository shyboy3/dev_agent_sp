def apply_workflow_tags(features, saves_directory):
    """
    saves 폴더에 연동된 draw.io 파일이 있는 특징 항목에 'workflow' 태그를 추가합니다.
    """
    for feature in features:
        # 특징 항목의 id를 기반으로 파일명 생성 (예: feature_123.drawio)
        feature_id = feature.get('id')
        diagram_filename = f"{feature_id}.drawio"
        diagram_path = os.path.join(saves_directory, diagram_filename)

        # 1. 파일 존재 여부 확인
        if os.path.exists(diagram_path):
            try:
                # 2. XML 데이터 유효성 검사 (mxGraphModel이나 diagram 태그가 있는지 확인)
                with open(diagram_path, 'r', encoding='utf-8') as f:
                    data = xmltodict.parse(f.read())
                
                mx_model = data['mxfile']['diagram']['mxGraphModel']
                if mx_model:
                    # 3. 데이터가 유효하면 'workflow' 태그 추가 (중복 체크 필수)
                    if 'tags' not in feature:
                        feature['tags'] = []
                    
                    if 'workflow' not in feature['tags']:
                        feature['tags'].append('workflow')
                        print(f"--- 태그 추가 완료: 특징 '{feature_id}'에 'workflow' 태그가 생성되었습니다. ---")
            
            except Exception as e:
                # 파싱 에러 등의 경우 무시하거나 로깅
                print(f"--- 태그 추가 실패: 특징 '{feature_id}'의 파일을 읽을 수 없습니다. ({e}) ---")

    return features

