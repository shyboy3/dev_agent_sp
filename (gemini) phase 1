def save_data(data):
    with open(DB_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

def generate_complex_workflow_viz(feat_name, steps):
    """조건부 루프와 병렬 항목이 포함된 워크플로우 시각화"""
    dot = ['digraph W { rankdir=TB; fontname="Malgun Gothic"; node [fontname="Malgun Gothic", shape=record, style=filled];']
    dot.append('  start [label="START", shape=ellipse, color="#2ecc71", fontcolor=white];')
    
    if not steps:
        dot.append('  none [label="No Steps Defined", shape=none];')
    else:
        # 노드 생성
        for step in steps:
            s_id = f"s{step['id']}"
            # 병렬 항목 처리 (항목이 여러 개면 리스트로 표시)
            tasks_label = "<br/>".join([f"• {t}" for t in step['tasks']])
            label = f"{{Step {step['id']}: {step['name']} | {tasks_label} | Agent: {step['agent']}}}"
            dot.append(f'  {s_id} [label=<{label}>, color="#9b59b6", fontcolor=white];')

        # 연결선 생성 (성공/실패 분기)
        dot.append(f'  start -> s{steps[0]["id"]};')
        for step in steps:
            s_id = f"s{step['id']}"
            # 기본 다음 단계
            if step.get('next_id'):
                dot.append(f'  {s_id} -> s{step["next_id"]} [label="success", color="#27ae60", fontsize=9];')
            else:
                dot.append(f'  {s_id} -> end [label="complete", color="#27ae60"];')
            
            # 실패 시 되돌아가기(Backtrack)
            if step.get('fail_goto_id'):
                dot.append(f'  {s_id} -> s{step["fail_goto_id"]} [label="fail/retry", color="#e74c3c", style=dashed, fontsize=9];')

    dot.append('  end [label="END", shape=ellipse, color="#e74c3c", fontcolor=white];')
    dot.append('}')
    return "\n".join(dot)

def main():
    st.set_page_config(page_title="Agent Flow Designer Pro", layout="wide")
    if 'master_data' not in st.session_state:
        st.session_state.master_data = load_data()

