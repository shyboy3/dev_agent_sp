def parse_drawio_xml(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        data = xmltodict.parse(f.read())
    
    # draw.io는 mxGraphModel 태그 안에 노드(mxCell) 정보를 담습니다.
    # 만약 파일이 압축되어 있다면 복호화 과정이 필요할 수 있습니다.
    return data

